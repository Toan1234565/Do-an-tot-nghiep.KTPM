<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ thống Đăng nhập | Logistics Smart System</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        :root {
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --error-bg: #fef2f2;
            --error-text: #b91c1c;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1920&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 480px;
            padding: 20px;
            margin-right: 400px;
        }

        .card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            padding: 40px;
            border-radius: 28px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.3);
           
        }

        h2 {
            color: var(--text-main);
            font-size: 1.75rem;
            text-align: center;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .sub-title {
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 30px;
        }

        .input-group {
            position: relative;
            margin-bottom: 20px;
        }

            .input-group input {
                width: 100%;
                padding: 14px 16px;
                padding-right: 45px;
                font-size: 1rem;
                border: 1.5px solid #e5e7eb;
                border-radius: 12px;
                outline: none;
                background: white;
                transition: all 0.2s;
            }

            .input-group label {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                pointer-events: none;
                transition: all 0.2s;
                background: white;
                padding: 0 4px;
            }

            .input-group input:focus ~ label,
            .input-group input:not(:placeholder-shown) ~ label {
                top: 0;
                font-size: 0.8rem;
                color: var(--primary-color);
                font-weight: 600;
            }

            .input-group input:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
            }

        .toggle-password {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--text-muted);
        }

        .btn {
            width: 100%;
            padding: 14px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

            .btn:hover:not(:disabled) {
                background: var(--primary-hover);
                transform: translateY(-1px);
            }

            .btn:disabled {
                opacity: 0.7;
                cursor: not-allowed;
            }

        .error-message {
            background: var(--error-bg);
            color: var(--error-text);
            padding: 12px;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 20px;
            border: 1px solid #fecaca;
            text-align: center;
        }

        .form-footer {
            margin-top: 25px;
            text-align: center;
            font-size: 0.9rem;
        }

            .form-footer a {
                color: var(--primary-color);
                text-decoration: none;
                font-weight: 600;
            }

        .form-content {
            display: none;
        }

            .form-content.active {
                display: block;
                animation: fadeIn 0.4s ease;
            }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .loader {
            width: 18px;
            height: 18px;
            border: 2px solid #ffffff;
            border-bottom-color: transparent;
            border-radius: 50%;
            display: none;
            animation: rotation 1s linear infinite;
        }
      
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-message">
                    <i class="fas fa-exclamation-circle"></i> @Html.ValidationSummary(true)
                </div>
            }

            <form id="login-form" method="post" action="/QuanLyPhanQuyen/DangNhap" class="form-content active" onsubmit="return handleBtnLoading(this)">
                <h2>Chào mừng trở lại</h2>
                <p class="sub-title">Hệ thống quản lý vận tải & điều phối logistics</p>

                <div class="input-group">
                    <input type="text" name="TenDangNhap" placeholder=" " required autocomplete="username">
                    <label>Tên đăng nhập hoặc Email</label>
                </div>

                <div class="input-group">
                    <input type="password" id="password" name="MatKhau" placeholder=" " required autocomplete="current-password">
                    <label>Mật khẩu</label>
                    <i class="fas fa-eye toggle-password" onclick="togglePass()"></i>
                </div>

                <button type="submit" class="btn" id="btn-submit">
                    <span class="loader" id="loader"></span>
                    <span id="btn-text">Đăng nhập hệ thống</span>
                </button>

                <div class="form-footer">
                    <p>Quên mật khẩu? <a href="javascript:void(0)" onclick="toggleForm('forgot')">Khôi phục ngay</a></p>
                </div>
            </form>

            <form id="forgot-form" class="form-content">
                <h2>Khôi phục mật khẩu</h2>
                <p class="sub-title">Nhập email để nhận mật khẩu mới</p>

                <div class="input-group">
                    <input type="email" name="Email" placeholder=" " required>
                    <label>Email đăng ký</label>
                </div>

                <button type="button" class="btn" id="btn-forgot" onclick="handleForgotPassword()">
                    Gửi yêu cầu
                </button>

                <div class="form-footer">
                    <p>Đã nhớ mật khẩu? <a href="javascript:void(0)" onclick="toggleForm('login')">Quay lại đăng nhập</a></p>
                </div>
            </form>
        </div>
    </div>

    <script>
        // 1. Chuyển đổi giữa 2 form
        function toggleForm(type) {
            const login = document.getElementById('login-form');
            const forgot = document.getElementById('forgot-form');
            if(type === 'forgot') {
                login.classList.remove('active');
                forgot.classList.add('active');
            } else {
                forgot.classList.remove('active');
                login.classList.add('active');
            }
        }

        // 2. Ẩn/hiện mật khẩu
        function togglePass() {
            const passInput = document.getElementById('password');
            const icon = document.querySelector('.toggle-password');
            if (passInput.type === 'password') {
                passInput.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                passInput.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        // 3. Xử lý Gửi yêu cầu Quên mật khẩu qua API
        async function handleForgotPassword() {
            const form = document.getElementById('forgot-form');
            const emailInput = form.querySelector('input[name="Email"]');
            const btn = document.getElementById('btn-forgot');
            const email = emailInput.value.trim();

            if (!email) {
                alert("Vui lòng nhập địa chỉ Email!");
                return;
            }

            // Hiệu ứng Loading
            const originalText = btn.innerText;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';

            try {
                // Lưu ý: Kiểm tra URL port có khớp với server của bạn không (VD: 7022 hoặc 5001)
                const response = await fetch('/api/quanlytaikhoan/quen-mat-khau', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ Email: email })
                });

                const result = await response.json();

                if (response.ok) {
                    alert("Thành công: " + result.message);
                    toggleForm('login');
                } else {
                    alert("Lỗi: " + (result.message || "Email không tồn tại trong hệ thống."));
                }
            } catch (error) {
                console.error("Fetch error:", error);
                alert("Lỗi kết nối server. Hãy đảm bảo API đang chạy!");
            } finally {
                btn.disabled = false;
                btn.innerText = originalText;
            }
        }

        // 4. Hiệu ứng loading cho form Đăng nhập
        function handleBtnLoading(form) {
            const btn = document.getElementById('btn-submit');
            const loader = document.getElementById('loader');
            const btnText = document.getElementById('btn-text');

            btn.disabled = true;
            loader.style.display = 'inline-block';
            btnText.innerText = 'Đang xác thực...';
            return true;
        }
    </script>
</body>
</html>