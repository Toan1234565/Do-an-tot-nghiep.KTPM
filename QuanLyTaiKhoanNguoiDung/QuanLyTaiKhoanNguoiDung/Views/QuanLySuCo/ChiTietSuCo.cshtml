@model QuanLyTaiKhoanNguoiDung.Models12.QuanLyLoTrinhTheoDoi.SuCoModels
@{
    ViewData["Title"] = "Chi tiết sự cố";
}

<style>
    :root {
        --primary-color: #4e73df;
        --success-color: #1cc88a;
        --danger-color: #e74a3b;
        --warning-color: #f6c23e;
        --dark-color: #5a5c69;
    }

    
    .main-content-container {
        background-color: #ffffff;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        margin-top: 20px;
    }

    .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
        margin-bottom: 24px;
        background: white;
    }

    .card-header-title {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        padding: 15px 20px;
        border-bottom: 1px solid #e3e6f0;
    }

    .status-pill {
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .media-box {
        border-radius: 8px;
        background: #f1f3f9;
        overflow: hidden;
        position: relative;
        transition: transform 0.2s;
        border: 1px solid #e3e6f0;
    }

        .media-box:hover {
            transform: translateY(-3px);
        }

        .media-box img, .media-box video {
            width: 100%;
            height: 250px;
            object-fit: cover;
            cursor: pointer;
        }

    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px dashed #e3e6f0;
    }

        .info-item:last-child {
            border: none;
        }

    .label-text {
        color: #858796;
        font-size: 0.85rem;
    }

    .value-text {
        font-weight: 700;
        color: #3a3b45;
        font-size: 0.85rem;
    }

    .map-frame {
        width: 100%;
        height: 200px;
        border-radius: 8px;
        border: 1px solid #e3e6f0;
    }
</style>
<div class="main-content-container">
        @* Header Section *@
        <div class="d-flex justify-content-between align-items-center px-2 mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/QuanLySuCo/DanhSachSuCo" class="text-decoration-none">Quản lý</a></li>
                        <li class="breadcrumb-item active">Chi tiết sự cố</li>
                    </ol>
                </nav>
                
                
            </div>
            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 10px; background: white;">
                <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
            </a>
        </div>
        <div class="row">
            @* --- CỘT TRÁI (3/12): THÔNG TIN ĐỊNH DANH --- *@
            <div class="col-lg-4">
                @* Thông tin chung *@
                <div class="card">
                    <div class="card-header-title bg-warning text-white rounded-top">
                        <i class="bi bi-info-circle me-2"></i>Trạng thái & Phân loại
                    </div>
                    <div class="card-body text-center py-4">
                        <h4 class="fw-bold text-dark mb-1">@(Model?.MaLoaiSuCoNavigation?.TenLoaiSuCo ?? "N/A")</h4>
                        <p class="text-muted small mb-3">Mã lộ trình: <span class="text-primary fw-bold">@Model?.MaLoTrinh</span></p>

                        @{
                            var statusClass = Model?.TrangThai switch
                            {
                                "Đã xử lý" => "bg-success text-white",
                                "Mới" => "bg-primary text-white",
                                "Từ chối" => "bg-danger text-white",
                                _ => "bg-warning text-dark"
                            };
                        }
                        <div class="mb-4">
                            <span class="status-pill @statusClass shadow-sm">@(Model?.TrangThai ?? "Chờ xử lý")</span>
                        </div>

                        <div class="text-start">
                            <div class="info-item">
                                <span class="label-text">Mức độ:</span>
                                <span class="badge bg-danger">@Model?.MaLoaiSuCoNavigation?.MucDoNghiemTrong</span>
                            </div>
                            <div class="info-item">
                                <span class="label-text">Thời gian báo:</span>
                                <span class="value-text">@Model?.ThoiGianBaoCao?.ToString("HH:mm - dd/MM/yyyy")</span>
                            </div>
                            <div class="info-item">
                                <span class="label-text">Thời gian xử lý:</span>
                                <span class="value-text text-success">@(Model?.ThoiGianXuLy?.ToString("dd/MM/yyyy") ?? "---")</span>
                            </div>
                            <div class="info-item">
                                <span class="label-text">Tài xế thực hiện chuyến hàng:</span>
                                @if(ViewBag.TaiXe != null)
                                {
                                    var tx = ViewBag.TaiXe;
                                    <a href="@Url.Action("ChiTietNhanVien", "QuanLyNguoiDung", new { maNhanVien = @tx.MaNguoiDung })" class="fw-bold text-dark text-decoration-none d-block">
                                        <span class="value-text text-success">@tx.HoTenNhanVien</span>
                                    </a>
                                    
                                    
                                }
                                
                            </div>
                        </div>
                    </div>
                </div>

                @* Thông tin phương tiện *@
                <div class="card">
                    <div class="card-header-title bg-dark text-white rounded-top">
                        <i class="bi bi-truck me-2"></i>Phương tiện liên quan
                    </div>
                    <div class="card-body">
                        @if (ViewBag.PhuongTien != null)
                        {
                            var pt = ViewBag.PhuongTien;
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light p-2 rounded me-3">
                                    <i class="bi bi-front fs-3 text-primary"></i>
                                </div>
                                <div>
                                    <a href="@Url.Action("ChiTietPhuongTien", "QuanLyPhuongTien", new { maPhuongTien = @pt.MaPhuongTien })" class="fw-bold text-dark text-decoration-none d-block">
                                        <h5 class="fw-bold mb-0">@pt.BienSo</h5>
                                        <small class="text-muted">@pt.TenLoaiXe</small>
                                    </a>
                                    
                                </div>
                            </div>
                            <div class="small">
                                <div class="info-item"><span class="label-text">Tải trọng:</span><span class="value-text">@pt.TaiTrongToiDaKg kg</span></div>
                                <div class="info-item"><span class="label-text">Kho quản lý:</span><span class="value-text">@pt.TenKho</span></div>
                                <div class="info-item"><span class="label-text">Trạng thái:</span><span class="text-success fw-bold">@pt.TrangThai</span></div>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-3">
                                <p class="text-muted small italic mb-0">Không tìm thấy thông tin xe</p>
                            </div>
                        }
                    </div>
                </div>

                @* Vị trí *@
                <div class="card">
                    <div class="card-header-title bg-danger text-white rounded-top">
                        <i class="bi bi-geo-alt me-2"></i>Vị trí hiện trường
                    </div>
                    <div class="card-body p-3">
                        @if (Model.ViDo.HasValue)
                        {
                            <div class="map-frame mb-3 bg-light d-flex align-items-center justify-content-center">
                                <i class="bi bi-map fs-1 opacity-25"></i>
                                @* Thêm iframe map thật tại đây nếu cần *@
                            </div>
                            <p class="small text-muted mb-3"><i class="bi bi-pin-map me-1"></i>@(Model?.DiaChiCuThe ?? "Chưa có địa chỉ chính xác")</p>
                            <a href="https://www.google.com/maps/search/?api=1&query=@Model?.ViDo,@Model?.KinhDo" target="_blank" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-cursor"></i> Xem trên Google Maps
                            </a>
                        }
                        else
                        {
                            <p class="text-center text-muted small py-4">Không có dữ liệu GPS</p>
                        }
                    </div>
                </div>
            </div>

            @* --- CỘT PHẢI (8/12): CHI TIẾT & BẰNG CHỨNG --- *@
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-body p-4">
                        @* Mô tả *@
                        <div class="mb-4">
                            <h5 class="fw-bold text-primary mb-3"><i class="bi bi-chat-left-text me-2"></i>Nội dung báo cáo</h5>
                            <div class="p-3 bg-light rounded" style="border-left: 5px solid #4e73df; min-height: 100px;">
                                <p class="mb-0 text-dark" style="white-space: pre-line;">
                                    @(string.IsNullOrEmpty(Model.MoTa) ? "Người báo không để lại mô tả chi tiết." : Model.MoTa)
                                </p>
                            </div>
                        </div>

                        @* Media *@
                        <h5 class="fw-bold text-primary mb-3"><i class="bi bi-camera me-2"></i>Hình ảnh & Video hiện trường</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="label-text fw-bold mb-2">HÌNH ẢNH</label>
                                <div class="media-box shadow-sm">
                                    @if (!string.IsNullOrEmpty(Model.UrlHinhAnhSuCo))
                                    {
                                        <img src="@Model.UrlHinhAnhSuCo" onclick="window.open(this.src)" alt="Photo">
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                                            <i class="bi bi-image fs-1 opacity-25"></i>
                                            <span class="small">Không có ảnh</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="label-text fw-bold mb-2">VIDEO</label>
                                <div class="media-box shadow-sm">
                                    @if (!string.IsNullOrEmpty(Model.UrlVideoSuCo))
                                    {
                                        <video controls><source src="@Model.UrlVideoSuCo" type="video/mp4"></video>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                                            <i class="bi bi-play-btn fs-1 opacity-25"></i>
                                            <span class="small">Không có video</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @* Nút bấm hành động *@
                        <div class="mt-5 pt-4 border-top">
                            @if (Model.TrangThai == "Mới")
                            {
                                <div class="d-flex gap-2">
                                    <button class="btn btn-success px-4" onclick="confirmUpdate('@Model.MaSuCo', 'Đang xử lý')">
                                        <i class="bi bi-check2-circle me-1"></i> Xác nhận sự cố
                                    </button>
                                    <button class="btn btn-outline-danger px-4" onclick="showRejectModal('@Model.MaSuCo')">
                                        <i class="bi bi-x-circle me-1"></i> Từ chối
                                    </button>
                                </div>
                            }
                            else if (Model.TrangThai == "Đã xử lý")
                            {
                                <div class="d-flex gap-2">
                                    <button class="btn btn-success px-4" onclick="confirmUpdate('@Model.MaSuCo', 'Xác nhận')">
                                        <i class="bi bi-check2-circle me-1"></i> Xác nhận sự cố
                                    </button>
                                    <button class="btn btn-outline-danger px-4" onclick="showRejectModal('@Model.MaSuCo')">
                                        <i class="bi bi-x-circle me-1"></i> Từ chối
                                    </button>
                                </div>
                            }
                            else if (Model.TrangThai == "Xác nhận")
                            {
                                <div class="alert alert-success border-0 shadow-sm d-flex align-items-center">
                                    <i class="bi bi-patch-check-fill fs-4 me-3"></i>
                                    <div>
                                        <div class="fw-bold">Sự cố này đã được đóng</div>
                                        <small>Kết thúc xử lý vào lúc @Model.ThoiGianXuLy?.ToString("HH:mm - dd/MM/yyyy")</small>
                                    </div>
                                </div>
                            }
                            else if (Model.TrangThai == "Từ chối")
                            {
                                <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center">
                                    <i class="bi bi-x-octagon-fill fs-4 me-3"></i>
                                    <div>
                                        <div class="fw-bold">Sự cố đã bị từ chối</div>
                                        <p class="mb-0 small">Lý do: @Model.GhiChuTuChoi</p>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header bg-danger text-white">
                                        <h5 class="modal-title">Lý do từ chối</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <textarea id="rejectReason" class="form-control" rows="4" placeholder="Vui lòng nhập lý do cụ thể..."></textarea>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                        <button type="button" class="btn btn-danger" onclick="submitReject()">Gửi từ chối</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let currentMaSuCo = null;

    // 1. Hàm xác nhận hoàn thành (Dành cho nút Xác nhận/Hoàn thành)
    async function confirmUpdate(maSuCo, status) {
        const result = await Swal.fire({
            title: 'Xác nhận?',
            text: "Bạn xác nhận sự cố này đã được xử lý xong?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#198754',
            confirmButtonText: 'Đúng, hoàn thành nó!',
            cancelButtonText: 'Hủy'
        });

        if (result.isConfirmed) {
            sendRequest(maSuCo, { trangThai: status });
        }
    }

    // 2. Hàm hiển thị Modal từ chối
    function showRejectModal(maSuCo) {
        currentMaSuCo = maSuCo;
        const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
        modal.show();
    }

    // 3. Gửi dữ liệu từ chối
    function submitReject() {
        const reason = document.getElementById('rejectReason').value;
        if (!reason.trim()) {
            Swal.fire('Lỗi', 'Vui lòng nhập lý do từ chối', 'error');
            return;
        }

        sendRequest(currentMaSuCo, {
            trangThai: 'Từ chối',
            ghiChuTuChoi: reason
        });
    }

    // 4. Hàm dùng chung để Call API
    async function sendRequest(maSuCo, data) {
        try {
            const response = await fetch(`https://localhost:7097/api/baocaosuco/capnhatsuco/${maSuCo}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok) {
                await Swal.fire('Thành công!', result.message, 'success');
                location.reload(); // Tải lại trang để cập nhật trạng thái mới
            } else {
                Swal.fire('Thất bại', result.message || 'Có lỗi xảy ra', 'error');
            }
        } catch (error) {
            console.error('Error:', error);
            Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ', 'error');
        }
    }
</script>