@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyNguoiDung.QuanLyNguoiDung.QuanLyNhanVien
@using QuanLyTaiKhoanNguoiDung.Models12.SeverQuanLyKhachHang.QuanLyDiaChi
@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyLoTrinh.QuanLyLoTrinhTheoDoi
@model ChiTietLoTrinhModels

@{
    ViewData["Title"] = "Chi Tiết Lộ Trình #" + Model?.MaLoTrinh;

    var tentaixe = ViewBag.LayTenTaiXe as TenNhanVienModel;
    var tentaixephu = ViewBag.LayTenTaiXePhu as TenNhanVienModel;
    var dictDiaChi = ViewBag.DictionaryDiaChi as System.Collections.Concurrent.ConcurrentDictionary<int, DiaChiModel>;
    var dictDonHang = ViewBag.DictionaryDonHang as System.Collections.Concurrent.ConcurrentDictionary<int, ChiTietDonHangViewModel>;
}

<style>
    :root {
        --primary-soft: #eef2ff;
        --primary-hr: #4e73df;
    }

    .main-content-container {
        background-color: #ffffff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
    }

    /* Timeline Styling */
    .timeline {
        position: relative;
        padding-left: 1.5rem;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 7px;
            top: 0;
            height: 100%;
            width: 2px;
            background: #e3e6f0;
            border-radius: 1px;
        }

    .timeline-item {
        position: relative;
        padding-left: 25px;
    }

    .timeline-marker {
        transition: all 0.3s ease;
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px var(--primary-hr);
    }

    /* Tabs Styling */
    .nav-tabs-custom {
        border-bottom: 2px solid #f8f9fa;
    }

        .nav-tabs-custom .nav-link {
            border: none;
            color: #858796;
            font-weight: 600;
            padding: 1rem 1.5rem;
            transition: 0.3s;
        }

            .nav-tabs-custom .nav-link.active {
                color: var(--primary-hr);
                background: transparent;
                border-bottom: 3px solid var(--primary-hr);
            }

    /* Card Info */
    .info-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #b7b9cc;
        margin-bottom: 2px;
        display: block;
    }

    .driver-card {
        cursor: pointer;
        transition: background 0.2s;
        border-radius: 10px;
        padding: 10px;
    }

        .driver-card:hover {
            background-color: #f8f9fc;
        }

    .badge-status {
        padding: 0.5em 1em;
        border-radius: 50rem;
    }

    @@media print {
        .no-print

    {
        display: none !important;
    }

    .main-content-container {
        box-shadow: none;
        padding: 0;
    }

    }
</style>

<div class="container-fluid py-4">
    @if (Model == null)
    {
        <div class="alert alert-danger shadow-sm border-start-danger">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-circle fa-2x me-3"></i>
                <div>
                    <h5 class="mb-0">Không tìm thấy dữ liệu!</h5>
                    <p class="mb-0 small">@ViewBag.Error</p>
                </div>
            </div>
            <a href="@Url.Action("QuanLyLoTrinhTheoDoi")" class="btn btn-danger mt-3 btn-sm">Quay lại danh sách</a>
        </div>
    }
    else
    {
        <!-- Header & Breadcrumb -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 no-print">
            <nav aria-label="breadcrumb">
                <h4 class="fw-bold text-dark mb-1">Chi tiết lộ trình #@Model.MaLoTrinh</h4>
                <ol class="breadcrumb bg-transparent p-0 mb-0">
                    <li class="breadcrumb-item"><a href="#">Hệ thống</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("QuanLyLoTrinhTheoDoi")">Lộ trình</a></li>
                    <li class="breadcrumb-item active">Theo dõi</li>
                </ol>
            </nav>
            <div class="mt-2 mt-md-0">
                <button onclick="window.print()" class="btn btn-white shadow-sm border px-3 text-dark me-2">
                    <i class="fas fa-print me-2 text-primary"></i>In phiếu
                </button>
                <a href="javascript:history.back()" class="btn btn-primary shadow-sm px-4">
                    <i class="fas fa-chevron-left me-2"></i>Quay lại
                </a>
            </div>
        </div>

        <div class="row">
            <!-- Sidebar: Thông tin chung -->
            <div class="col-xl-4 col-lg-5">
                <div class="card border-0 shadow-sm mb-4 overflow-hidden">
                    <div class="card-header bg-primary py-3">
                        <h6 class="m-0 font-weight-bold text-white"><i class="fas fa-info-circle me-2"></i>Tổng quan vận hành</h6>
                    </div>
                    <div class="card-body">
                        <!-- Trạng thái -->
                        <div class="text-center mb-4">
                            <span class="badge bg-soft-primary text-primary border border-primary px-3 py-2 badge-status">
                                <i class="fas fa-sync-alt fa-spin me-1"></i> @Model.TrangThai
                            </span>
                        </div>

                        <!-- Phương tiện -->
                        <div class="mb-4 text-center border-bottom pb-3">
                            <span class="info-label">Phương tiện vận tải</span>
                            <div class="h4 fw-bold text-dark mb-1">
                                <i class="fas fa-truck-moving text-primary me-2"></i>
                                @(Model.MaPhuongTien?.ToString() ?? "Chưa gán xe")
                            </div>
                            @if (Model.MaPhuongTien != null)
                            {
                                <a href="@Url.Action("ChiTietPhuongTien", "QuanLyPhuongTien", new { maPhuongTien = Model.MaPhuongTien })" class="small text-decoration-none">
                                    Xem hồ sơ xe <i class="fas fa-arrow-right ms-1" style="font-size: 0.7rem;"></i>
                                </a>
                            }
                        </div>

                        <!-- Nhân sự -->
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="driver-card text-center border" onclick="location.href='@Url.Action("ChiTietNhanVien", "QuanLyNguoiDung", new { id = Model.MaTaiXeChinh })'">
                                    <span class="info-label">Tài xế chính</span>
                                    <div class="fw-bold text-primary text-truncate">
                                        @(tentaixe?.TenTaiXeThucHien ?? "N/A")
                                    </div>
                                    <code class="small text-muted">ID: @Model.MaTaiXeChinh</code>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div class="driver-card border @(Model.MaTaiXePhu == null ? "opacity-50" : "")" onclick="@(Model.MaTaiXePhu != null ? $"location.href='{Url.Action("ChiTietNhanVien", "QuanLyNguoiDung", new { id = Model.MaTaiXePhu })}'" : "")">
                                    <span class="info-label">Tài xế phụ</span>
                                    <div class="fw-bold text-dark text-truncate">
                                        @(tentaixephu?.TenTaiXeThucHien ?? "Trống")
                                    </div>
                                    <code class="small text-muted">ID: @(Model.MaTaiXePhu?.ToString() ?? "--")</code>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card Thời gian -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-0">
                        <div class="p-3 border-bottom bg-light">
                            <h6 class="m-0 font-weight-bold text-dark fs-6"><i class="fas fa-clock me-2 text-success"></i>Lịch trình thời gian</h6>
                        </div>
                        <div class="p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Kế hoạch xuất phát:</span>
                                <span class="fw-bold small">@(Model.ThoiGianBatDauKeHoach?.ToString("dd/MM/yyyy HH:mm") ?? "--")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">Bắt đầu thực tế:</span>
                                <span class="text-success fw-bold small">@(Model.ThoiGianBatDauThucTe?.ToString("dd/MM/yyyy HH:mm") ?? "Chờ khởi hành")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main: Chi tiết các tab -->
            <div class="col-xl-8 col-lg-7">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white p-0 border-bottom">
                        <ul class="nav nav-tabs nav-tabs-custom border-bottom-0" id="detailTab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="stops-tab" data-bs-toggle="tab" href="#stops" role="tab">
                                    <i class="fas fa-map-marked-alt me-2"></i>Điểm dừng (@Model.TongSoDiemDung)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="cargo-tab" data-bs-toggle="tab" href="#cargo" role="tab">
                                    <i class="fas fa-boxes me-2"></i>Kiện hàng (@Model.TongSoDonHang)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" id="costs-tab" data-bs-toggle="tab" href="#costs" role="tab">
                                    <i class="fas fa-file-invoice-dollar me-2"></i>Chi phí vận hành
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="card-body p-4">
                        <div class="tab-content" id="myTabContent">
                            <!-- TAB: ĐIỂM DỪNG -->
                            <div class="tab-pane fade show active" id="stops" role="tabpanel">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h5 class="mb-0 fw-bold">Trình tự di chuyển</h5>
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fas fa-map-marker-alt me-1"></i> Xem bản đồ
                                    </button>
                                </div>
                                <div class="timeline">
                                    @if (Model.DiemDungs != null && Model.DiemDungs.Any())
                                    {
                                        foreach (var dd in Model.DiemDungs.OrderBy(x => x.ThuTuDung))
                                        {
                                            <div class="timeline-item mb-4">
                                                <div class="timeline-marker position-absolute rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                                     style="width: 24px; height: 24px; left: -4px; top: 0; z-index: 2; font-size: 0.7rem;">
                                                    @dd.ThuTuDung
                                                </div>
                                                <div class="card border shadow-none rounded-3 p-3 bg-light bg-opacity-10">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        @* <div>
                                                            <div class="fw-bold text-dark mb-1">@dd.LoaiDung</div>
                                                            @{
                                                                dictDiaChi.TryGetValue(dd.MaDiaChi, out var dc);
                                                            }
                                                            <div class="small text-muted">
                                                                <i class="fas fa-location-dot me-1"></i>
                                                                @(dc != null ? $"{dc.Duong}, {dc.Phuong}, {dc.ThanhPho}" : "N/A")
                                                            </div>
                                                        </div> *@
                                                        <span class="badge @(dd.LoaiDung == "Giao hàng" ? "bg-info" : "bg-warning") text-dark">
                                                            @dd.LoaiDung
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- TAB: KIỆN HÀNG -->
                            <div class="tab-pane fade" id="cargo" role="tabpanel">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle border-0">
                                        <thead class="bg-light shadow-none">
                                            <tr class="text-muted small">
                                                <th class="border-0">MÃ ĐƠN</th>
                                                <th class="border-0">THÔNG TIN VẬN CHUYỂN</th>
                                                <th class="border-0 text-center">TRẠNG THÁI</th>
                                                <th class="border-0 text-end">THAO TÁC</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.ChiTietLoTrinhKienHangs != null && Model.ChiTietLoTrinhKienHangs.Any())
                                            {
                                                foreach (var ct in Model.ChiTietLoTrinhKienHangs)
                                                {
                                                    <tr>
                                                        <td class="fw-bold text-primary">#@ct.MaDonHang</td>
                                                        <td>
                                                            @if (dictDonHang != null && ct.MaDonHang.HasValue && dictDonHang.TryGetValue(ct.MaDonHang.Value, out var dh))
                                                            {
                                                                <div class="mb-1"><strong>Nhận:</strong> @dh.TenNguoiNhan <span class="text-muted ms-1">(@dh.SdtNguoiNhan)</span></div>
                                                                <div class="customer-info small" data-ma-khach-hang="@dh.MakhachHang">
                                                                    <span class="text-muted">Gửi:</span>
                                                                    <span class="loading-spinner-small"><i class="fas fa-spinner fa-spin ms-1"></i></span>
                                                                    <span class="content-khach-hang d-none fw-medium text-dark">
                                                                        <span class="ten-kh"></span>
                                                                    </span>
                                                                </div>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="badge bg-light text-secondary border">@ct.TrangThaiTrenXe</span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a href="@Url.Action("ChiTietDonHang", "QuanLyDonHang", new { maDonHang = ct.MaDonHang })" class="btn btn-sm btn-light">
                                                                <i class="fas fa-eye text-primary"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- TAB: CHI PHÍ -->
                            <div class="tab-pane fade" id="costs" role="tabpanel">
                                <div class="table-responsive">
                                    <table class="table table-bordered">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Loại phí</th>
                                                <th>Ghi chú</th>
                                                <th class="text-end">Số tiền</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.ChiPhiLoTrinhs != null && Model.ChiPhiLoTrinhs.Any())
                                            {
                                                foreach (var cp in Model.ChiPhiLoTrinhs)
                                                {
                                                    <tr>
                                                        <td>@cp.LoaiChiPhi</td>
                                                        <td class="text-muted small">@cp.GhiChu</td>
                                                        <td class="text-end fw-bold">@cp.SoTien?.ToString("N0") VNĐ</td>
                                                    </tr>
                                                }
                                                <tr class="bg-light">
                                                    <td colspan="2" class="text-end fw-bold">Tổng chi phí:</td>
                                                    <td class="text-end fw-bold text-danger fs-5">
                                                        @Model.ChiPhiLoTrinhs.Sum(x => x.SoTien ?? 0).ToString("N0") VNĐ
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="3" class="text-center py-5 text-muted">
                                                        <i class="fas fa-receipt fa-3x mb-3 opacity-25"></i>
                                                        <p>Chưa ghi nhận chi phí phát sinh.</p>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Hàm tải dữ liệu khách hàng từ API
        async function loadCustomerDetails() {
            const containers = document.querySelectorAll('.customer-info');
            const uniqueIds = [...new Set(Array.from(containers).map(c => c.dataset.maKhachHang).filter(id => id && id > 0))];

            for (const maKH of uniqueIds) {
                try {
                    const response = await fetch(`https://localhost:7149/api/quanlykhachhang/chi-tiet-khach-hang/${maKH}`);
                    const elements = document.querySelectorAll(`.customer-info[data-ma-khach-hang="${maKH}"]`);

                    if (response.ok) {
                        const data = await response.json();
                        elements.forEach(el => {
                            el.querySelector('.ten-kh').innerText = data.tenKhachHang || 'N/A';
                            el.querySelector('.loading-spinner-small').classList.add('d-none');
                            el.querySelector('.content-khach-hang').classList.remove('d-none');
                        });
                    } else {
                        elements.forEach(el => {
                            el.querySelector('.loading-spinner-small').innerHTML = '<span class="text-muted">Error</span>';
                        });
                    }
                } catch (error) {
                    console.error("Lỗi API:", error);
                }
            }
        }

        // Tự động load khi mở tab Kiện hàng hoặc ngay khi load trang nếu tab kiện hàng đang active
        loadCustomerDetails();
    });
</script>