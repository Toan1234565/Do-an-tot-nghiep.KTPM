@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyNguoiDung.QuanLyNhanVien
@model IEnumerable<DanhSachNguoiDungModel>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Lý Nhân Sự</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/giaodiendanhsach.css" asp-append-version="true" />
    <style>
        .role-badge {
            background: #edf2ff;
            color: #4361ee;
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.8rem;
        }

        .gender-pill {
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            display: inline-flex;
            align-items: center;
        }

        .pill-nam {
            background: #e0f2ff;
            color: #0077cc;
        }

        .pill-nu {
            background: #fff0f6;
            color: #d63384;
        }

        .btn-add-new {
            background-color: var(--primary-color);
            color: white;
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
            border: none;
            transition: 0.3s;
        }

            .btn-add-new:hover {
                background-color: var(--secondary-color);
                color: white;
                box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
            }

        .modal-content {
            border-radius: 20px;
            overflow: hidden;
        }

        .modal-header {
            background: #fff;
            border-bottom: 1px solid #f1f5f9;
            padding: 20px 30px;
        }

        .btn-nhat-ky:hover {
            background-color: #e9ecef !important;
            transform: scale(1.1);
        }

            .btn-nhat-ky:hover i {
                animation: ring 0.5s ease;
            }

    </style>
</head>
<body>
    <main class="container-fluid py-4">
        <div class="main-card">
            <div class="page-header d-flex justify-content-between align-items-center mb-4">
                <h1 class="h4 fw-bold m-0 text-dark">
                    <i class="fa-solid fa-users-gear me-2 text-primary"></i>Quản Lý Nhân Viên
                </h1>

                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-primary rounded-pill px-3 shadow-sm btn-add-new" data-bs-toggle="modal" data-bs-target="#ThemNhanVienModal">
                        <i class="fas fa-plus-circle me-2"></i>Thêm nhân viên mới
                    </button>

                    <div class="position-relative">
                        <button type="button"
                                class="btn btn-light rounded-circle shadow-sm btn-nhat-ky d-flex align-items-center justify-content-center"
                                style="width: 42px; height: 42px; border: 1px solid #dee2e6;"
                                data-bs-toggle="modal"
                                data-bs-target="#detailModal"
                                data-service="Quản lý nhân viên"
                                title="Xem nhật ký hoạt động">
                            <i class="fa-solid fa-bell text-primary fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">Hoạt động mới</span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="filter-section">
                <form asp-action="DanhSachNhanVien" method="get" id="filterForm" class="row g-3">
                    <div class="col-md-3">
                        <div class="input-group border rounded-3 bg-white shadow-sm">
                            <span class="input-group-text bg-transparent border-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                            <input type="text" name="searchTerm" class="form-control border-0 bg-transparent"
                                   placeholder="Tìm kiếm tên, ID..." value="@ViewBag.CurrentSearch">
                        </div>
                    </div>

                    <div class="col-md-2">
                        <select name="trangthai" class="form-select border rounded-3 shadow-sm" onchange="this.form.submit()">
                            <option value="true" selected="@(ViewBag.CurrentTrangThai == true)">Đang hoạt động</option>
                            <option value="false" selected="@(ViewBag.CurrentTrangThai == false)">Đã vô hiệu hóa</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select name="maChucVu" class="form-select border rounded-3 shadow-sm" onchange="this.form.submit()">
                            <option value="">-- Chức vụ --</option>
                            @if (ViewBag.DanhSachChucVu != null)
                            {
                                foreach (var cv in ViewBag.DanhSachChucVu)
                                {
                                    <option value="@cv.maChucVu" selected="@(ViewBag.CurrentMaChucVu == cv.maChucVu)">@cv.tenChucVu</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <select name="maKho" id="selectFilterDonVi" class="form-select border rounded-3 shadow-sm">
                            <option value="">-- Tất cả kho/đơn vị --</option>
                        </select>
                    </div>

                    <div class="col-md-1">
                        <a asp-action="DanhSachNhanVien" class="btn btn-outline-secondary w-100">Xóa</a>
                    </div>
                </form>
            </div>

            <div>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th class="text-center">STT</th>
                            <th>Thông Tin Nhân Viên</th>
                            <th class="text-center">Ngày Sinh</th>
                            <th class="text-center">Giới Tính</th>
                            <th>Chức Vụ</th>
                            <th>Đơn vị</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = ((ViewBag.CurrentPage - 1) * 20) + 1;
                            foreach (var item in Model)
                            {
                                <tr onclick="location.href='@Url.Action("ChiTietNhanVien", "QuanLyNguoiDung", new { maNhanVien = item.MaNguoiDung })'"
                                    style="cursor: pointer;"
                                    class="align-middle">
                                    <td class="text-center text-muted fw-bold">@stt</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; border: 1px solid #e2e8f0;">
                                                <i class="fa-solid fa-user text-secondary"></i>
                                            </div>
                                            <div>
                                                @item.HoTenNhanVien
                                                <small class="text-muted">ID: #@item.MaNguoiDung</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        <span class="gender-pill @(item.GioiTinh == "Nam" ? "pill-nam" : "pill-nu")">
                                            <i class="fa-solid @(item.GioiTinh == "Nam" ? "fa-mars" : "fa-venus") me-1"></i> @item.GioiTinh
                                        </span>
                                    </td>
                                    <td><span class="role-badge">@item.TenChucVu</span></td>
                                    <td>@item.DonViLamViec</td>
                                    <td>
                                        @if (item.TrangThai == true) // Giả định true là đang hoạt động
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                    onclick="event.stopPropagation(); vôHiệuHóa('@item.MaNguoiDung')">
                                                <i class="fas fa-ban"></i> Vô hiệu hóa
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-success btn-sm"
                                                    onclick="event.stopPropagation(); kichHoat('@item.MaNguoiDung')">
                                                <i class="fas fa-check"></i> Kích hoạt
                                            </button>
                                        }
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="80" class="mb-3 opacity-50">
                                    <p class="text-muted">Không tìm thấy dữ liệu.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <p class="text-muted small mb-0">Hiển thị trang @ViewBag.CurrentPage/@ViewBag.TotalPages</p>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link shadow-sm border-0 mx-1 rounded"
                                       href="@Url.Action("DanhSachNhanVien", new { searchTerm = ViewBag.CurrentSearch, maChucVu = ViewBag.CurrentMaChucVu, maKho = ViewBag.CurrentDonVi, page = i })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>

        <div class="modal fade" id="ThemNhanVienModal" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-id-card me-2 text-primary"></i>Đăng Ký Nhân Viên</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="formThemNhanVien">
                            <h6 class="text-primary fw-bold mb-3"><i class="fas fa-lock me-2"></i>Tài khoản</h6>
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Tên đăng nhập *</label>
                                    <input type="text" class="form-control" name="TenDangNhap" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Mật khẩu *</label>
                                    <input type="password" class="form-control" name="MatKhau" required>
                                </div>
                            </div>

                            <h6 class="text-primary fw-bold mb-3"><i class="fas fa-user-circle me-2"></i>Cá nhân</h6>
                            <div class="row mb-3">
                                <div class="col-md-8">
                                    <label class="form-label small fw-semibold">Họ và tên *</label>
                                    <input type="text" class="form-control" name="HoTenNhanVien" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Chức vụ *</label>
                                    <select class="form-select" id="selectChucVu" name="MaChucVu" required>
                                        <option value="">-- Chọn --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="form-label small fw-semibold">Đơn vị làm việc *</label>
                                    <select class="form-select" id="selectDonViLamViec" name="MaKho" required>
                                        <option value="">-- Chọn --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Email *</label>
                                    <input type="email" class="form-control" name="Email" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Số điện thoại *</label>
                                    <input type="text" class="form-control" name="SoDienThoai" required>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Ngày sinh</label>
                                    <input type="date" class="form-control" name="NgaySinh">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">Giới tính</label>
                                    <select class="form-select" name="GioiTinh">
                                        <option value="Nam">Nam</option>
                                        <option value="Nữ">Nữ</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold">CCCD</label>
                                    <input type="text" class="form-control" name="SoCccd">
                                </div>
                            </div>
                            <div class="mt-4 pt-3 border-top text-end">
                                <button type="button" class="btn btn-light px-4 me-2" data-bs-dismiss="modal">Đóng</button>
                                <button type="submit" class="btn btn-primary px-5 fw-bold" id="btnSubmitForm">Lưu nhân viên</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nhật ký hệ thống</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="modalBodyNhatKy">
                    @await Html.PartialAsync("_NhatKyPartial")
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/quanlytaikhoan/kichhoat-vohieuhoa.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- 1. KHỞI TẠO DỮ LIỆU ---
            loadChucVuData();
            loadDonViData();

            // --- 2. XỬ LÝ LỌC ĐỒNG THỜI (AUTO-SUBMIT) ---
            const filterForm = document.getElementById('filterForm');
            const autoSubmitElements = ['selectFilterChucVu', 'selectFilterDonVi'];

            autoSubmitElements.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener('change', function () {
                        filterForm.submit(); // Tự động load lại trang kèm các tham số lọc
                    });
                }
            });

            // --- 3. XỬ LÝ THÊM NHÂN VIÊN ---
        const form = document.getElementById('formThemNhanVien');
            if (form) {
                form.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const btnSubmit = document.getElementById('btnSubmitForm');
                    if (btnSubmit) {
                        btnSubmit.disabled = true;
                        btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang lưu...';
                    }

                    const formData = new FormData(form);
                    const payload = Object.fromEntries(formData.entries());

                    const selectDonVi = document.getElementById('selectDonViLamViec');
                    const selectedText = selectDonVi.options[selectDonVi.selectedIndex].text;

                    // Gán thêm thuộc tính DonViLamViec vào payload trước khi gửi đi
                    payload.DonViLamViec = selectedText;

                    try {
                        const response = await fetch('https://localhost:7022/api/quanlynguoidung/themnhanvien', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });

                        const result = await response.json();

                        if (response.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: result.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: result.message || 'Không thể thêm nhân viên'
                            });
                            resetButton(btnSubmit);
                        }
                    } catch (error) {
                        Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Máy chủ không phản hồi' });
                        resetButton(btnSubmit);
                    }
                });
            }
        });

        // Hàm hỗ trợ reset trạng thái nút
        function resetButton(btn) {
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = 'Lưu nhân viên';
            }
        }

        // --- HÀM LOAD CHỨC VỤ ---
        async function loadChucVuData() {
            const selectFilter = document.getElementById('selectFilterChucVu');
            const selectModal = document.getElementById('selectChucVu');
            const currentCV = "@ViewBag.CurrentMaChucVu"; // Nhận giá trị từ Controller

            try {
                const response = await fetch('https://localhost:7022/api/quanlynguoidung/danhsachchucvu');
                const data = await response.json();

                data.forEach(item => {
                    // 1. Thêm vào bộ lọc (Dropdown lọc)
                    if (selectFilter) {
                        const optFilter = new Option(item.tenChucVu, item.maChucVu);
                        // Ép kiểu về string để so sánh chính xác
                        if (String(item.maChucVu) === String(currentCV)) {
                            optFilter.selected = true;
                        }
                        selectFilter.add(optFilter);
                    }

                    // 2. Thêm vào dropdown trong Modal
                    if (selectModal) {
                        selectModal.add(new Option(item.tenChucVu, item.maChucVu));
                    }
                });
            } catch (e) { console.error("Lỗi load chức vụ:", e); }
        }

        // --- HÀM LOAD ĐƠN VỊ ---
        async function loadDonViData() {
            const selectFilter = document.getElementById('selectFilterDonVi');
            const selectModal = document.getElementById('selectDonViLamViec');
            // Lấy giá trị mã kho hiện tại từ ViewBag (đã đổi tên ở Controller)
            const currentMK = "@ViewBag.CurrentMaKho";

            try {
                const response = await fetch('https://localhost:7286/api/quanlykhobai/gettenkhobai');
                const data = await response.json();

                data.forEach(item => {
                    // Lưu ý: item.maKhoBai là giả định dựa trên API của bạn, hãy kiểm tra đúng tên trường ID kho
                   const valueId = item.maKhoBai || item.maKho || item.id;

                    // 1. Thêm vào bộ lọc
                    if (selectFilter) {
                        const optFilter = new Option(item.tenKhoBai, valueId);
                        if (String(valueId) === String(currentMK)) {
                            optFilter.selected = true;
                        }
                        selectFilter.add(optFilter);
                    }

                    // 2. Thêm vào dropdown trong Modal (để lưu ma_kho khi thêm mới)
                    if (selectModal) {
                        selectModal.add(new Option(item.tenKhoBai, valueId));
                    }
                });
            } catch (e) { console.error("Lỗi load đơn vị:", e); }
        }
    </script>
</body>
</html>