@using Microsoft.AspNetCore.Http
@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyNguoiDung.QuanLyNguoiDung.QuanLyNhanVien
@model QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyNguoiDung.QuanLyNguoiDung.QuanLyNhanVien.NguoiDungDetailModel
@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyNguoiDung.QuanLyNguoiDung.QuanLyTaiXe
@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyNguoiDung.QuanLyPhanQuyen
@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyTaiSan.QuanLyKhoBai
@using QuanLyTaiKhoanNguoiDung.Models12.SeverQuanLyKhachHang.QuanLyDiaChi
@inject IHttpContextAccessor HttpContextAccessor
@{
    var context = HttpContextAccessor.HttpContext;
    var session = context?.Session;
    int maNguoiDungDangNhap = 0;
    if (session != null)
    {
        int.TryParse(session.GetString("MaNguoiDung") ?? "0", out maNguoiDungDangNhap);
    }
    var diaChi = ViewBag.DiaChi as DiaChiModel;
    // Lấy danh sách vi phạm từ ViewBag đã call ở Controller
    var listViPham = ViewBag.LichSuViPham as List<LichSuViPhamModels>;

    var tx = Model.ThongTinTaiXe as TaiXeDetailModel;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Lý Nhân Sự</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"> 
    <link rel="stylesheet" href="~/css/chitietnhanvien.css" asp-append-version="true" />
</head>
<body>
    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/QuanLyNguoiDung/DanhSachNhanVien" class="text-decoration-none">Nhân sự</a></li>
                    <li class="breadcrumb-item active fw-bold">Hồ sơ chi tiết</li>
                </ol>
            </nav>
            <a href="javascript:history.back()" class="btn btn-white shadow-sm rounded-pill px-4 border">
                <i class="fa-solid fa-chevron-left me-2"></i>Quay lại
            </a>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card card-custom">
                    <div class="profile-card-header"></div>
                    <div class="profile-avatar-wrapper text-center">
                        <img src="https://ui-avatars.com/api/?name=@Model.HoTenNhanVien&background=4361ee&color=fff&size=128" class="rounded-circle mb-3">
                        <h4 class="fw-bold mb-1">@Model.HoTenNhanVien</h4>
                        <span class="badge bg-primary bg-opacity-10 text-primary mb-3">@Model.TenChucVu</span>
                        <p class="text-muted small"><i class="fa-solid fa-building me-1"></i> @Model.DonViLamViec</p>
                    </div>

                    <div class="card-body border-top mt-2 px-4">
                        <div class="info-label">Thông tin liên hệ</div>
                        <div class="info-value"><i class="fa-solid fa-envelope"></i> @Model.Email</div>
                        <div class="info-value"><i class="fa-solid fa-phone"></i> @Model.SoDienThoai</div>
                        <div class="info-value">
                            <i class="fa-solid fa-map-location-dot"></i>
                            <span>@(diaChi != null ? $"{diaChi.Duong}, {diaChi.Phuong}, {diaChi.ThanhPho}" : "Chưa cập nhật địa chỉ")</span>
                        </div>

                        <div class="mt-4">
                            @if (maNguoiDungDangNhap == Model.MaNguoiDung)
                            {
                                <button class="btn btn-primary w-100 mb-2 rounded-pill shadow-sm" onclick="openEditModal01()">
                                    <i class="fa-solid fa-user-pen me-2"></i>Chỉnh sửa hồ sơ
                                </button>
                                <button class="btn btn-outline-warning w-100 rounded-pill" onclick="openEditModal02()">
                                    <i class="fa-solid fa-shield-halved me-2"></i>Đổi mật khẩu
                                </button>
                            }
                            else
                            {
                                
                                <button class="btn btn-success w-100 rounded-pill shadow-sm" onclick='openEditModal({
                                        maNguoiDung: "@Model.MaNguoiDung",
                                        hoTenNhanVien: "@Model.HoTenNhanVien",
                                        ngaySinh: "@Model.NgaySinh?.ToString("yyyy-MM-dd")",
                                        baoHiemXaHoi: "@Model.BaoHiemXaHoi",
                                        maChucVu: "@Model.MaChucVu",
                                        maKho: "@Model.MaKho"
                                    })'>
                                    <i class="fa-solid fa-user-gear me-2"></i>Quản trị nhân sự
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card card-custom p-4 d-flex flex-row align-items-center mb-0 border-start border-primary border-4">
                            <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3 text-primary">
                                <i class="fa-solid fa-truck-fast fs-4"></i>
                            </div>
                            <div>
                                <div class="info-label mb-0">Chuyến hàng</div>
                                <h3 class="mb-0 fw-bold">@(ViewBag.OrdersCount ?? 0)</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card card-custom p-4 d-flex flex-row align-items-center mb-0 border-start border-success border-4">
                            <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3 text-success">
                                <i class="fa-solid fa-medal fs-4"></i>
                            </div>
                            <div>
                                <div class="info-label mb-0">Điểm đánh giá</div>
                                <h3 class="mb-0 fw-bold">4.9 / 5.0</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-custom">
                    <ul class="nav nav-tabs nav-tabs-custom px-3" id="myTab" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#info" type="button">Hồ sơ nghiệp vụ</button>
                        </li>
                        @if (Model.MaChucVu == 16)
                        { @* 16 là mã Tài xế *@

                            <li class="nav-item">
                                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#violations" type="button">
                                    Lịch sử vi phạm
                                    @if (listViPham?.Count > 0)
                                    {
                                        <span class="badge bg-danger ms-1">@listViPham.Count</span>
                                    }
                                </button>
                            </li>
                        }
                    </ul>
                    <div class="tab-content p-4">
                        <div class="tab-pane fade show active" id="info">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="info-label">Căn cước công dân</div>
                                    <div class="info-value"><i class="fa-solid fa-id-card"></i> @(Model.SoCccd ?? "---")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-label">Mã số thuế / BHXH</div>
                                    <div class="info-value"><i class="fa-solid fa-file-invoice-dollar"></i> @(Model.BaoHiemXaHoi ?? "Chưa có")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-label">Ngân hàng</div>
                                    <div class="info-value"><i class="fa-solid fa-landmark"></i> @(Model.TenNganHang ?? "---")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-label">Số tài khoản</div>
                                    <div class="info-value"><i class="fa-solid fa-credit-card"></i> @(Model.SoTaiKhoan ?? "---")</div>
                                </div>
                                @if (Model.MaChucVu == 16)
                                {
                                    <div class="col-12">
                                        <hr class="my-3 opacity-25">
                                        <h6 class="text-primary mb-3">
                                            <i class="fa-solid fa-truck-steering me-2"></i>Thông tin bằng lái & Nghiệp vụ
                                        </h6>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="info-label text-uppercase small text-muted fw-bold">Trạng thái hiện tại</div>
                                        <div class="info-value">
                                            @if (tx.TrangThaiHoatDong == "Sẵn sàng" || tx.TrangThaiHoatDong == "Đang hoạt động")
                                            {
                                                <span class="badge rounded-pill bg-success">
                                                    <i class="fa-solid fa-circle-check me-1"></i> @tx.TrangThaiHoatDong
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-secondary text-white">
                                                    <i class="fa-solid fa-circle-pause me-1"></i> @(tx.TrangThaiHoatDong ?? "Ngoại tuyến")
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="info-label text-uppercase small text-muted fw-bold">Điểm uy tín hệ thống</div>
                                        <div class="info-value">
                                            <span class="fw-bold text-warning">
                                                <i class="fa-solid fa-star me-1"></i> @(tx.DiemUyTin ?? 0)
                                            </span>
                                            <div class="progress mt-2" style="height: 5px; width: 120px;">
                                                <div class="progress-bar bg-warning" role="progressbar" style="width: @(tx.DiemUyTin ?? 0)%"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="info-label text-uppercase small text-muted fw-bold">Số giấy phép lái xe</div>
                                        <div class="info-value text-success fw-bold">
                                            <i class="fa-solid fa-address-card me-2"></i> @(tx.SoBangLai ?? "Chưa cập nhật")
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="info-label text-uppercase small text-muted fw-bold">Hạng bằng / Ngày hết hạn</div>
                                        <div class="info-value">
                                            <span class="badge bg-primary me-2">Hạng @(tx.LoaiBangLai ?? "---")</span>
                                            <span class="small text-muted italic">
                                                <i class="fa-regular fa-calendar-times me-1"></i>
                                                @(tx.NgayCapBang != null ? tx.NgayHetHanBang.ToString("dd/MM/yyyy") : "---")
                                            </span>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="info-label text-uppercase small text-muted fw-bold">Kinh nghiệm lái xe</div>
                                        <div class="info-value">
                                            <i class="fa-solid fa-clock-rotate-left text-primary me-2"></i> @(tx.KinhNghiemNam ?? 0) năm
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(tx.AnhBangLaiTruoc))
                                    {
                                        <div class="col-12 mt-3">
                                            <div class="info-label text-uppercase small text-muted fw-bold mb-2">Hình ảnh bằng lái (Minh họa)</div>
                                            <div class="d-flex gap-2">
                                                <img src="@tx.AnhBangLaiTruoc" class="img-thumbnail" style="height: 100px; cursor: pointer;" alt="Mặt trước" />
                                                <img src="@tx.AnhBangLaiSau" class="img-thumbnail" style="height: 100px; cursor: pointer;" alt="Mặt sau" />
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <div class="tab-pane fade" id="violations">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Thời gian</th>
                                            <th>Loại vi phạm</th>
                                            <th>Mô tả chi tiết</th>
                                            <th class="text-end">Mức phạt</th>
                                            <th>Xử lý</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (listViPham != null && listViPham.Any())
                                        {
                                            foreach (var vp in listViPham)
                                            {
                                                <tr>
                                                    <td class="small fw-bold text-muted">
                                                        @(vp.NgayViPham.HasValue? vp.NgayViPham.Value.ToString("dd/MM/yyyy HH:mm") : "---")
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-info bg-opacity-10 text-info fw-bold">@vp.LoaiViPham</span>
                                                    </td>
                                                    <td>
                                                        <div class="small text-wrap" style="max-width: 250px;">
                                                            @vp.MoTaChiTiet
                                                        </div>
                                                    </td>
                                                    <td class="text-end fw-bold text-danger">
                                                        @(vp.MucPhat.HasValue? vp.MucPhat.Value.ToString("N0") + " VNĐ" : "0")
                                                    </td>
                                                    <td>
                                                        <div>
                                                            <span class="d-block small fw-medium">@vp.HinhThucXuLy</span>
                                                            @if (vp.TrangThaiXuLy == "Đã xử lý")
                                                            {
                                                                <span class="badge bg-success-subtle text-success" style="font-size: 0.65rem;">
                                                                    <i class="fa-solid fa-check me-1"></i>@vp.TrangThaiXuLy
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-warning-subtle text-warning" style="font-size: 0.65rem;">
                                                                    <i class="fa-solid fa-clock me-1"></i>@vp.TrangThaiXuLy
                                                                </span>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <i class="fa-solid fa-circle-check fa-3x mb-3 text-success opacity-25"></i>
                                                    <p class="mb-0">Nhân viên này chưa có lịch sử vi phạm.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @* sửa thông tin nhân viên (dành cho admin) *@
        <div class="modal fade" id="editProfileModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                    <div class="modal-header bg-primary text-white" style="border-radius: 20px 20px 0 0;">
                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-user-gear me-2"></i>Cập nhật nhân viên</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="editEmployeeForm">
                            <input type="hidden" id="editMaNguoiDung" value="@Model.MaNguoiDung">
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">HỌ TÊN</label>
                                <input type="text" class="form-control" id="editHoTen" value="@Model.HoTenNhanVien">
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">NGÀY SINH</label>
                                    <input type="date" class="form-control" id="editNgaySinh" value="@Model.NgaySinh?.ToString("yyyy-MM-dd")">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">MÃ BHXH</label>
                                    <input type="text" class="form-control" id="editBHXH" value="@Model.BaoHiemXaHoi">
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="form-label small fw-semibold">Chức vụ *</label>
                                    <select name="maChucVu" id="editMaChucVu" class="form-select border rounded-3 shadow-sm">
                                        <option value="">-- Chức vụ --</option>
                                        @if (ViewBag.DanhSachChucVu != null)
                                        {
                                            foreach (var cv in (List<ChucVuModel>)ViewBag.DanhSachChucVu)
                                            {
                                                <option value="@cv.MaChucVu" selected="@(ViewBag.CurrentMaChucVu == cv.MaChucVu)">@cv.TenChucVu</option>
                                            }
                                        }
                                    </select>
                                </div>                                
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="form-label small fw-semibold">Đơn vị làm việc *</label>
                                    <select name="maKho" id="editMaKho" class="form-select">
                                        <option value="">-- Tất cả kho bãi --</option>
                                        @if (ViewBag.DanhSachKho != null)
                                        {
                                            foreach (var cv in (List<TenKhobaiModels>)ViewBag.DanhSachKho)
                                            {
                                                <option value="@cv.MaKho" selected="@(ViewBag.CurrentMaKho?.ToString() == cv.MaKho.ToString())">@cv.TenKhoBai</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" class="btn btn-primary rounded-pill px-4" id="btnSaveUpdate" onclick="handleUpdateEmployee()">Lưu thay đổi</button>
                    </div>
                </div>
            </div>
        </div>
        
        @* đổi mật khẩu  *@
        <div class="modal fade" id="modalDoiMatKhau" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius: 15px;">
                    <div class="modal-header bg-primary text-white" style="border-radius: 15px 15px 0 0;">
                        <h5 class="modal-title"><i class="fa-solid fa-key me-2"></i>Thay đổi mật khẩu</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="formDoiMatKhau">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                                <input type="password" id="matKhauCu" class="form-control" placeholder="Nhập mật khẩu cũ" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Mật khẩu mới</label>
                                <input type="password" id="matKhauMoi" class="form-control" placeholder="Nhập mật khẩu mới" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                                <input type="password" id="xacNhanMatKhau" class="form-control" placeholder="Nhập lại mật khẩu mới" required>
                            </div>
                            <div id="errorMsg" class="text-danger small mb-2" style="display:none;"></div>
                        </form>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" class="btn btn-primary" onclick="handleDoiMatKhau()">
                            <span id="btnText">Lưu thay đổi</span>
                            <span id="btnSpinner" class="spinner-border spinner-border-sm d-none"></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* sửa thông tin cá nhân (dành cho chính nhân viên đó) *@
        <div class="modal fade" id="editPersonalInfoModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                    <div class="modal-header bg-success text-white" style="border-radius: 20px 20px 0 0;">
                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-user-pen me-2"></i>Cập nhật hồ sơ cá nhân</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="formSuaThongTinCaNhan">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">HỌ TÊN</label>
                                    <input type="text" class="form-control" id="personalHoTen" value="@Model.HoTenNhanVien">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">EMAIL</label>
                                    <input type="email" class="form-control" id="personalEmail" value="@Model.Email">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">SỐ ĐIỆN THOẠI</label>
                                    <input type="text" class="form-control" id="personalSdt" value="@Model.SoDienThoai">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">NGÀY SINH</label>
                                    <input type="date" class="form-control" id="personalNgaySinh" value="@Model.NgaySinh?.ToString("yyyy-MM-dd")">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">GIỚI TÍNH</label>
                                    <select class="form-select" id="personalGioiTinh">
                                        <option value="Nam" selected="@(Model.GioiTinh == "Nam")">Nam</option>
                                        <option value="Nữ" selected="@(Model.GioiTinh == "Nữ")">Nữ</option>
                                        <option value="Khác" selected="@(Model.GioiTinh == "Khác")">Khác</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">SỐ CCCD</label>
                                    <input type="text" class="form-control" id="personalCccd" value="@Model.SoCccd">
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold small text-muted">TÊN NGÂN HÀNG</label>
                                    <input type="text" class="form-control" id="personalTenNganHang" value="@Model.TenNganHang">
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold small text-muted">SỐ TÀI KHOẢN NGÂN HÀNG</label>
                                    <input type="text" class="form-control" id="personalStk" value="@Model.SoTaiKhoan">
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" class="btn btn-success rounded-pill px-4" id="btnSavePersonal" onclick="handleUpdatePersonal()">Cập nhật ngay</button>
                    </div>
                </div>
            </div>
        </div> 
    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

                // Khởi tạo các biến global nếu cần hoặc xử lý sự kiện khi DOM load xong
        document.addEventListener("DOMContentLoaded", function () {
            // Có thể gọi load dữ liệu Chức vụ / Đơn vị ở đây nếu cần thiết
        });        
        // ==========================================
        // 1. MODAL: SỬA THÔNG TIN NHÂN VIÊN (ADMIN)
        // ==========================================
        function openEditModal(emp) {
            // Nếu dữ liệu truyền vào là chuỗi JSON, ta parse nó thành Object
            if (typeof emp === 'string') {
                emp = JSON.parse(emp);
            }

            // Đổ dữ liệu vào các input text và hidden
            document.getElementById('editMaNguoiDung').value = emp.maNguoiDung || "";
            document.getElementById('editHoTen').value = emp.hoTenNhanVien || "";
            document.getElementById('editBHXH').value = emp.baoHiemXaHoi || "";

            // Xử lý ngày sinh (Chỉ lấy phần YYYY-MM-DD để hiển thị lên <input type="date">)
            if (emp.ngaySinh) {
                document.getElementById('editNgaySinh').value = emp.ngaySinh.split('T')[0];
            }

            // Đổ dữ liệu vào các thẻ SELECT
            // Quan trọng: Giá trị emp.maChucVu và emp.maKho phải khớp với thuộc tính 'value' của <option>
            const selectChucVu = document.getElementById('editMaChucVu');
            const selectKho = document.getElementById('editMaKho');
            const selecttenkho = document.getElementById('editTenKho');
            if (selectChucVu) selectChucVu.value = emp.maChucVu;
            if (selectKho) selectKho.value = emp.maKho;
            if (selecttenkho) selecttenkho.value = emp.donViLamViec;

            // Hiển thị Modal
            const modalElement = document.getElementById('editProfileModal');
            const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
            modalInstance.show();
        }

        async function handleUpdateEmployee() {
            const btnSave = document.getElementById('btnSaveUpdate');
            const maNhanVien = document.getElementById('editMaNguoiDung').value;

            // 1. Truy vấn DOM cho các select
            const selectChucVu = document.querySelector('select[name="maChucVu"]');
            const selectKho = document.querySelector('select[name="maKho"]');

            const maChucVuStr = selectChucVu.value;
            const maKhoStr = selectKho.value; // Đây là Mã Kho (Value của option)

            // Lấy Tên Kho (Text hiển thị của option đang chọn)
            const tenKho = selectKho.options[selectKho.selectedIndex].text;

            // 2. Validation
            if (!maChucVuStr || !maKhoStr) {
                Swal.fire("Cảnh báo", "Vui lòng chọn Chức vụ và Kho làm việc", "warning");
                return;
            }

            const hoTen = document.getElementById('editHoTen').value.trim();
            if (!hoTen) {
                Swal.fire("Cảnh báo", "Họ tên không được để trống", "warning");
                return;
            }

            // 3. Chuẩn bị dữ liệu gửi đi
            const updateData = {
                hoTenNhanVien: hoTen,
                ngaySinh: document.getElementById('editNgaySinh').value,
                baoHiemXaHoi: document.getElementById('editBHXH').value.trim(),
                maChucVu: parseInt(maChucVuStr),
                maKho: maKhoStr,           // Gửi Mã Kho để lưu vào database
                donViLamViec: tenKho       // Gửi Tên Kho để lưu vào trường DonViLamViec
            };

            // 4. Trạng thái Loading
            btnSave.disabled = true;
            const originalText = btnSave.innerHTML;
            btnSave.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';

            try {
                const response = await fetch(`/api/quanlynguoidung/capnhatnhanvien/${maNhanVien}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updateData)
                });

                let result = {};
                const contentType = response.headers.get("content-type");
                if (contentType && contentType.indexOf("application/json") !== -1) {
                    result = await response.json();
                } else {
                    const text = await response.text();
                    result = text ? { message: text } : {};
                }

                if (response.ok) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: result.message || "Cập nhật thành công!",
                        timer: 1500,
                        showConfirmButton: false
                    });
                    location.reload();
                } else {
                    Swal.fire("Thất bại", result.message || "Không thể cập nhật.", "error");
                }
            } catch (error) {
                console.error("Lỗi:", error);
                Swal.fire("Lỗi hệ thống", "Đã xảy ra lỗi kết nối.", "error");
            } finally {
                btnSave.disabled = false;
                btnSave.innerHTML = originalText;
            }
        }

        // ==========================================
        // 2. MODAL: ĐỔI MẬT KHẨU
        // ==========================================
        function openEditModal02() {
            document.getElementById('formDoiMatKhau').reset();
            document.getElementById('errorMsg').style.display = 'none';
            const modalElement = document.getElementById('modalDoiMatKhau');
            const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
            modalInstance.show();
        }

        async function handleDoiMatKhau() {
            const matKhauCu = document.getElementById('matKhauCu').value.trim();
            const matKhauMoi = document.getElementById('matKhauMoi').value.trim();
            const xacNhanMatKhau = document.getElementById('xacNhanMatKhau').value.trim();
            const errorMsg = document.getElementById('errorMsg');

            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const btnSubmit = document.querySelector('#modalDoiMatKhau .btn-primary');

            // Lấy mã người dùng từ biến Razor (cần đảm bảo biến này có giá trị khi render HTML)
            // Nếu dùng ẩn, có thể lấy bằng: document.getElementById('editMaNguoiDung').value
            const maNguoiDung = document.getElementById('editMaNguoiDung')?.value || "@Model.MaNguoiDung";

            if (!maNguoiDung || maNguoiDung === "0") {
                Swal.fire("Lỗi", "Không xác định được phiên làm việc.", "error");
                return;
            }

            if (!matKhauCu || !matKhauMoi || !xacNhanMatKhau) {
                showError(errorMsg, "Vui lòng nhập đầy đủ thông tin.");
                return;
            }

            if (matKhauMoi !== xacNhanMatKhau) {
                showError(errorMsg, "Mật khẩu xác nhận không khớp.");
                return;
            }

            if (matKhauMoi.length < 6) {
                showError(errorMsg, "Mật khẩu mới phải từ 6 ký tự trở lên.");
                return;
            }

            errorMsg.style.display = 'none';
            btnSubmit.disabled = true;
            btnText.classList.add('d-none');
            btnSpinner.classList.remove('d-none');

            try {
                const response = await fetch(`/api/quanlytaikhoan/doimatkhau/${maNguoiDung}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({
                        matKhauCu: matKhauCu,
                        matKhauMoi: matKhauMoi
                    })
                });

                const text = await response.text();
                const result = text ? JSON.parse(text) : {};

                if (response.ok) {
                    const modalInstance = bootstrap.Modal.getInstance(document.getElementById('modalDoiMatKhau'));
                    if (modalInstance) modalInstance.hide();

                    await Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message || 'Mật khẩu đã được thay đổi thành công.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    document.getElementById('formDoiMatKhau').reset();
                } else {
                    showError(errorMsg, result.message || "Đã có lỗi xảy ra khi đổi mật khẩu.");
                }
            } catch (error) {
                console.error("Lỗi đổi mật khẩu:", error);
                Swal.fire("Lỗi kết nối", "Không thể kết nối đến máy chủ API.", "error");
            } finally {
                btnSubmit.disabled = false;
                btnText.classList.remove('d-none');
                btnSpinner.classList.add('d-none');
            }
        }

        function showError(element, message) {
            element.innerText = message;
            element.style.display = 'block';
        }

        // ==========================================
        // 3. MODAL: SỬA THÔNG TIN CÁ NHÂN (SELF)
        // ==========================================
        function openEditModal01() {
            const modalElement = document.getElementById('editPersonalInfoModal');
            const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
            modalInstance.show();
        }

        async function handleUpdatePersonal() {
            const btnSave = document.getElementById('btnSavePersonal');
            // Lấy mã người dùng từ input hidden nếu có, hoặc xài Razor
            const maNguoiDung = document.getElementById('editMaNguoiDung')?.value || "@Model.MaNguoiDung";

            const updateData = {
                hoTenNhanVien: document.getElementById('personalHoTen').value.trim(),
                email: document.getElementById('personalEmail').value.trim(),
                soDienThoai: document.getElementById('personalSdt').value.trim(),
                ngaySinh: document.getElementById('personalNgaySinh').value,
                gioiTinh: document.getElementById('personalGioiTinh').value,
                soCccd: document.getElementById('personalCccd').value.trim(),
                soTaiKhoan: document.getElementById('personalStk').value.trim(),
                tenNganHang: document.getElementById('personalTenNganHang').value.trim()
            };

            btnSave.disabled = true;
            btnSave.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';

            try {
                const response = await fetch(`/api/quanlytaikhoan/sua-thong-tin/${maNguoiDung}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updateData)
                });

                const text = await response.text();
                const result = text ? JSON.parse(text) : {};

                if (response.ok) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: result.message || "Thông tin cá nhân đã được cập nhật!",
                        timer: 1500,
                        showConfirmButton: false
                    });
                    location.reload();
                } else {
                    Swal.fire("Lỗi", result.message || "Cập nhật thất bại", "error");
                }
            } catch (error) {
                console.error("Lỗi cập nhật cá nhân:", error);
                Swal.fire("Lỗi kết nối", "Không thể kết nối đến máy chủ", "error");
            } finally {
                btnSave.disabled = false;
                btnSave.innerHTML = 'Cập nhật ngay';
            }
        }
    </script>
</body>
</html>
