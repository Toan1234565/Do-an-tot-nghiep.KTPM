@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyDiaChi
@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyNguoiDung.QuanLyNhanVien
@model NguoiDungModel
@{
    var diaChi = ViewBag.DiaChi as DiaChiModel;
}

<style>
    :root {
        --primary: #4361ee;
        --secondary: #3f37c9;
        --success: #2ec4b6;
        --warning: #ff9f1c;
        --danger: #e71d36;
        --light-bg: #f8f9fa;
        --card-shadow: 0 0.75rem 1.5rem rgba(18, 38, 63, 0.03);
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    .card-custom {
        border: none;
        border-radius: 12px;
        box-shadow: var(--card-shadow);
        background: #fff;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .profile-card-header {
        background: linear-gradient(to right, var(--primary), var(--secondary));
        height: 100px;
    }

    .profile-avatar-wrapper {
        margin-top: -50px;
        padding: 0 1.5rem;
    }

    .profile-avatar-wrapper img {
        width: 100px;
        height: 100px;
        border: 4px solid #fff;
        background: #fff;
        object-fit: cover;
    }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #94a3b8;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .info-value {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-value i {
        color: var(--primary);
        width: 18px;
        text-align: center;
    }

    .status-badge {
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-completed { background: #d1fae5; color: #065f46; }
    .status-pending { background: #fef3c7; color: #92400e; }

    .btn-edit {
        background: var(--primary);
        color: white;
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        border: none;
        transition: 0.3s;
    }

    .btn-edit:hover {
        background: var(--secondary);
        transform: translateY(-2px);
    }
</style>

<main class="container py-4">
    <div class="mb-4">
        <a href="/QuanLyNguoiDung/DanhSachNhanVien" class="text-decoration-none text-muted fw-bold small">
            <i class="fa-solid fa-chevron-left me-2"></i>QUAY LẠI DANH SÁCH NHÂN VIÊN
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card card-custom shadow-sm">
                <div class="profile-card-header"></div>
                <div class="profile-avatar-wrapper text-center">
                    <img src="https://ui-avatars.com/api/?name=@Model.HoTenNhanVien&background=4361ee&color=fff&size=128"
                         class="rounded-circle shadow-sm mb-3">
                    <h4 class="fw-bold mb-1">@Model.HoTenNhanVien</h4>
                    <p class="text-muted small fw-medium">@Model.TenChucVu • @Model.DonViLamViec</p>
                </div>

                <div class="card-body px-4">
                    <div class="row text-center border-top border-bottom py-3 mb-4 bg-light rounded-3">
                        <div class="col-6 border-end">
                            <div class="info-label">Mã NV</div>
                            <div class="fw-bold text-dark">#@Model.MaNguoiDung</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Giới tính</div>
                            <div class="fw-bold text-dark">@Model.GioiTinh</div>
                        </div>
                    </div>

                    <div class="info-group">
                        <div class="info-label">Liên hệ</div>
                        <div class="info-value"><i class="fa-solid fa-envelope"></i> @Model.Email</div>
                        <div class="info-value"><i class="fa-solid fa-phone"></i> @Model.SoDienThoai</div>

                        <div class="info-label">Ngày sinh</div>
                        <div class="info-value"><i class="fa-solid fa-calendar"></i> @Model.NgaySinh?.ToString("dd/MM/yyyy")</div>

                        <div class="info-label">Địa chỉ thường trú</div>
                        <div class="info-value"><i class="fa-solid fa-location-dot"></i> @diaChi?.Duong, @diaChi?.Phuong, @diaChi?.ThanhPho</div>
                    </div>

                    <button class="btn btn-edit w-100 mt-2" onclick="openEditModal()">
                        <i class="fa-solid fa-user-pen me-2"></i>Chỉnh sửa hồ sơ
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card card-custom p-4 d-flex flex-row align-items-center mb-0">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                            <i class="fa-solid fa-box-open text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="info-label">TỔNG ĐƠN HÀNG</div>
                            <h3 class="mb-0 fw-bold">@(ViewBag.OrdersCount ?? 0)</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card card-custom p-4 d-flex flex-row align-items-center mb-0">
                        <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
                            <i class="fa-solid fa-chart-line text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="info-label">HIỆU SUẤT</div>
                            <h3 class="mb-0 fw-bold">Tốt</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-custom mb-4">
                <div class="card-header bg-transparent border-bottom py-3">
                    <h6 class="mb-0 fw-bold"><i class="fa-solid fa-vault me-2 text-primary"></i>Thông tin định danh & Tài chính</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="info-label">Số Căn cước công dân</div>
                            <div class="info-value"><i class="fa-solid fa-address-card"></i> @(Model.SoCccd ?? "Chưa cập nhật")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="info-label">Mã số BHXH</div>
                            <div class="info-value"><i class="fa-solid fa-heart-pulse"></i> @(Model.BaoHiemXaHoi ?? "Chưa tham gia")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="info-label">Tên Ngân hàng</div>
                            <div class="info-value"><i class="fa-solid fa-building-columns"></i> @(ViewBag.TenNganHang ?? "Chưa liên kết")</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="info-label">Số tài khoản (Lương)</div>
                            <div class="info-value"><i class="fa-solid fa-credit-card"></i> @(ViewBag.SoTaiKhoan ?? "Chưa cập nhật")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-custom">
                <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="fa-solid fa-history me-2 text-primary"></i>Lịch sử hoạt động gần đây</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Mã Đơn</th>
                                <th>Khách Hàng</th>
                                <th>Tổng Tiền</th>
                                <th>Trạng Thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.Orders != null)
                            {
                                foreach (var order in ViewBag.Orders)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@order.OrderId</td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span class="fw-semibold">@order.CustomerName</span>
                                                <small class="text-muted">@order.OrderDate.ToString("dd/MM/yyyy")</small>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-dark">@order.TotalAmount.ToString("N0") đ</td>
                                        <td>
                                            <span class="status-badge @(order.Status == "Hoàn thành" ? "status-completed" : "status-pending")">
                                                @order.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center py-5 text-muted">Không có dữ liệu giao dịch</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="editProfileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header bg-primary text-white" style="border-radius: 20px 20px 0 0;">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-user-gear me-2"></i>Cập nhật nhân viên</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="editEmployeeForm">
                        <input type="hidden" id="editMaNguoiDung" value="@Model.MaNguoiDung">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">HỌ TÊN</label>
                            <input type="text" class="form-control" id="editHoTen" value="@Model.HoTenNhanVien">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small text-muted">NGÀY SINH</label>
                                <input type="date" class="form-control" id="editNgaySinh" value="@Model.NgaySinh?.ToString("yyyy-MM-dd")">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small text-muted">MÃ BHXH</label>
                                <input type="text" class="form-control" id="editBHXH" value="@Model.BaoHiemXaHoi">
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label small fw-semibold">Chức vụ *</label>
                                <select class="form-select" id="selectChucVu" name="MaChucVu" required>
                                    <option value="@Model.MaChucVu" selected>@Model.TenChucVu</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="form-label small fw-semibold">Đơn vị làm việc *</label>
                                <select class="form-select" id="selectDonViLamViec" name="MaKho" required>
                                    <option value="@Model.DonViLamViec" selected>@Model.DonViLamViec</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" id="btnSaveUpdate" onclick="handleUpdateEmployee()">Lưu thay đổi</button>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openEditModal() {
            // Tìm phần tử modal trong DOM
            const modalElement = document.getElementById('editProfileModal');
            // Khởi tạo instance của Bootstrap Modal
            const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
            // Hiển thị modal
            modalInstance.show();
            loadChucVuData();
            loadDonViData();          
        }
         // --- HÀM LOAD CHỨC VỤ ---
        async function loadChucVuData() {
            const selectModal = document.getElementById('selectChucVu');
            const currentMaCV = "@Model.MaChucVu"; // Lấy mã hiện tại của nhân viên

            try {
                const response = await fetch('https://localhost:7022/api/quanlynguoidung/danhsachchucvu');
                const data = await response.json();

                if (selectModal) {
                    selectModal.innerHTML = ""; // Xóa sạch các option cũ để tránh trùng lặp
                    data.forEach(item => {
                        const option = new Option(item.tenChucVu, item.maChucVu);
                        // Kiểm tra nếu là chức vụ hiện tại thì chọn nó
                        if (String(item.maChucVu) === String(currentMaCV)) {
                            option.selected = true;
                        }
                        selectModal.add(option);
                    });
                }
            } catch (e) {
                console.error("Lỗi load chức vụ:", e);
            }
        }
         // --- HÀM LOAD ĐƠN VỊ ---
        async function loadDonViData() {
            const selectFilter = document.getElementById('selectFilterDonVi');
            const selectModal = document.getElementById('selectDonViLamViec');
            const currentDV = "@ViewBag.CurrentDonVi"; // Nhận giá trị từ Controller

            try {
                const response = await fetch('https://localhost:7286/api/quanlykhobai/gettenkhobai');
                const data = await response.json();

                data.forEach(item => {
                    // 1. Thêm vào bộ lọc (Dropdown lọc)
                    if (selectFilter) {
                        const optFilter = new Option(item.tenKhoBai, item.tenKhoBai);
                        if (item.tenKhoBai === currentDV) {
                            optFilter.selected = true;
                        }
                        selectFilter.add(optFilter);
                    }

                    // 2. Thêm vào dropdown trong Modal
                    if (selectModal) {
                        selectModal.add(new Option(item.tenKhoBai, item.tenKhoBai));
                    }
                });
            } catch (e) { console.error("Lỗi load đơn vị:", e); }
        }
        // --- HÀM XỬ LÝ CẬP NHẬT NHÂN VIÊN ---
         async function handleUpdateEmployee() {
            const btnSave = document.getElementById('btnSaveUpdate');
            const maNhanVien = document.getElementById('editMaNguoiDung').value;

            const updateData = {
                hoTenNhanVien: document.getElementById('editHoTen').value,
                ngaySinh: document.getElementById('editNgaySinh').value,                
                baoHiemXaHoi: document.getElementById('editBHXH').value || "",
                maChucVu: parseInt(document.getElementById('selectChucVu').value),
                donViLamViec: document.getElementById('selectDonViLamViec').value
            };

            btnSave.disabled = true;
            btnSave.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';

            try {
                // THAY ĐỔI: URL format và method PUT
                const response = await fetch(`https://localhost:7022/api/quanlynguoidung/capnhatnhanvien/${maNhanVien}`, {
                    method: 'PUT', // Phải là PUT theo [HttpPut]
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updateData)
                });

                // Đọc text trước để tránh lỗi "Unexpected end of JSON"
                const text = await response.text();
                const result = text ? JSON.parse(text) : {};

                if (response.ok) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: result.message || "Cập nhật thành công!",
                        timer: 1500
                    });
                    location.reload();
                } else {
                    Swal.fire("Lỗi", result.message || "Không thể cập nhật", "error");
                }
            } catch (error) {
                console.error("Error:", error);
                Swal.fire("Lỗi kết nối", "Vui lòng kiểm tra lại API", "error");
            } finally {
                btnSave.disabled = false;
                btnSave.innerHTML = 'Lưu thay đổi';
            }
        }
    </script>
    
</main>
