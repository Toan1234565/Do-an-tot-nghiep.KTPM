        async function handleUpdatePersonal() {
            const btnSave = document.getElementById('btnSavePersonal');
            const maNguoiDung = "@Model.MaNguoiDung";

            // Chuẩn bị object data khớp với SuaThongTinCaNhanUpdate ở Backend
            const updateData = {
                hoTenNhanVien: document.getElementById('personalHoTen').value,
                email: document.getElementById('personalEmail').value,
                soDienThoai: document.getElementById('personalSdt').value,
                ngaySinh: document.getElementById('personalNgaySinh').value,
                gioiTinh: document.getElementById('personalGioiTinh').value,
                soCccd: document.getElementById('personalCccd').value,
                soTaiKhoan: document.getElementById('personalStk').value
            };

            btnSave.disabled = true;
            btnSave.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';

            try {
                // Gọi đến API [HttpPost("sua-thong-tin/{maNguoiDung}")]
                const response = await fetch(`https://localhost:7022/api/quanlytaikhoan/sua-thong-tin/${maNguoiDung}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updateData)
                });

                const result = await response.json();

                if (response.ok) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Thành công',
                        text: result.message || "Thông tin cá nhân đã được cập nhật!",
                        timer: 1500
                    });
                    location.reload(); // Tải lại trang để thấy dữ liệu mới
                } else {
                    Swal.fire("Lỗi", result.message || "Cập nhật thất bại", "error");
                }
            } catch (error) {
                console.error("Error:", error);
                Swal.fire("Lỗi kết nối", "Không thể kết nối đến máy chủ", "error");
            } finally {
                btnSave.disabled = false;
                btnSave.innerHTML = 'Cập nhật ngay';
            }
        }
    </script>
    
</main>
