               async function handleDoiMatKhau() {
            // 1. Khai báo các phần tử DOM
            const matKhauCu = document.getElementById('matKhauCu').value.trim();
            const matKhauMoi = document.getElementById('matKhauMoi').value.trim();
            const xacNhanMatKhau = document.getElementById('xacNhanMatKhau').value.trim();
            const errorMsg = document.getElementById('errorMsg');
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const btnSubmit = document.querySelector('#modalDoiMatKhau .btn-primary');

            // Lấy mã người dùng từ biến Razor (đảm bảo biến này có giá trị > 0)
            const maNguoiDung = "@maNguoiDungDangNhap";

            // 2. Kiểm tra dữ liệu đầu vào (Validation)
            if (maNguoiDung === "0" || !maNguoiDung) {
                Swal.fire("Lỗi", "Phiên làm việc hết hạn, vui lòng đăng nhập lại.", "error");
                return;
            }

            if (!matKhauCu || !matKhauMoi || !xacNhanMatKhau) {
                errorMsg.innerText = "Vui lòng nhập đầy đủ thông tin.";
                errorMsg.style.display = 'block';
                return;
            }

            if (matKhauMoi !== xacNhanMatKhau) {
                errorMsg.innerText = "Mật khẩu xác nhận không khớp.";
                errorMsg.style.display = 'block';
                return;
            }

            if (matKhauMoi.length < 6) {
                errorMsg.innerText = "Mật khẩu mới phải từ 6 ký tự trở lên.";
                errorMsg.style.display = 'block';
                return;
            }

            // 3. Hiển thị trạng thái Loading
            errorMsg.style.display = 'none';
            btnSubmit.disabled = true;
            btnText.classList.add('d-none');
            btnSpinner.classList.remove('d-none');

            try {
                const url = `https://localhost:7022/api/quanlytaikhoan/doimatkhau/${maNguoiDung}`;

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    // credentials: 'include', // Mở comment nếu API yêu cầu Cookie/Session từ trình duyệt
                    body: JSON.stringify({
                        matKhauCu: matKhauCu,
                        matKhauMoi: matKhauMoi
                    })
                });

                // Đọc phản hồi dưới dạng văn bản trước để tránh lỗi Parse JSON nếu server trả về HTML
                const responseText = await response.text();
                let result;

                

                if (response.ok) {
                    // Đóng Modal
                    const modalElement = document.getElementById('modalDoiMatKhau');
                    const modalInstance = bootstrap.Modal.getInstance(modalElement);
                    if (modalInstance) modalInstance.hide();

                    // Thông báo thành công
                    await Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message || 'Mật khẩu đã được thay đổi thành công.',
                        timer: 2000,
                        showConfirmButton: false
                    });

                    // Reset Form
                    document.getElementById('formDoiMatKhau').reset();
                    // location.reload(); // Mở comment nếu muốn tải lại trang
                } else {
                    // Lỗi logic (Ví dụ: sai mật khẩu cũ)
                    errorMsg.innerText = result.message || "Đã có lỗi xảy ra.";
                    errorMsg.style.display = 'block';
                }

            } catch (error) {
                console.error("Lỗi:", error);
                Swal.fire("Lỗi kết nối", error.message || "Không thể kết nối đến máy chủ API.", "error");
            } finally {
                // 4. Tắt trạng thái Loading
                btnSubmit.disabled = false;
                btnText.classList.remove('d-none');
                btnSpinner.classList.add('d-none');
            }
        }

