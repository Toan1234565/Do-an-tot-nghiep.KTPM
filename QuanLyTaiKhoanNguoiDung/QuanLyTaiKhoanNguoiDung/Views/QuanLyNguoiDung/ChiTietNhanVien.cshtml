@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // 1. Lấy HttpContext an toàn
    var context = HttpContextAccessor.HttpContext;
    var session = context?.Session;
    string maNguoiDungStr = "0"; // Mặc định là chuỗi "0"
    int maNguoiDungDangNhap = 0;

    if (session != null)
    {     
        // 2. Lấy MaNguoiDung từ Session (Lưu ý: Session.GetString trả về string)
        maNguoiDungStr = session.GetString("MaNguoiDung") ?? "0";

        // 3. Chuyển đổi sang int an toàn để dùng cho logic backend
        int.TryParse(maNguoiDungStr, out maNguoiDungDangNhap);
    }
}
@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyDiaChi
@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyNguoiDung.QuanLyNhanVien
@model NguoiDungModel
@{
    var diaChi = ViewBag.DiaChi as DiaChiModel;
}

<style>
    :root {
        --primary: #4361ee;
        --secondary: #3f37c9;
        --success: #2ec4b6;
        --warning: #ff9f1c;
        --danger: #e71d36;
        --light-bg: #f8f9fa;
        --card-shadow: 0 0.75rem 1.5rem rgba(18, 38, 63, 0.03);
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    .card-custom {
        border: none;
        border-radius: 12px;
        box-shadow: var(--card-shadow);
        background: #fff;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .profile-card-header {
        background: linear-gradient(to right, var(--primary), var(--secondary));
        height: 100px;
    }

    .profile-avatar-wrapper {
        margin-top: -50px;
        padding: 0 1.5rem;
    }

    .profile-avatar-wrapper img {
        width: 100px;
        height: 100px;
        border: 4px solid #fff;
        background: #fff;
        object-fit: cover;
    }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #94a3b8;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .info-value {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-value i {
        color: var(--primary);
        width: 18px;
        text-align: center;
    }

    .status-badge {
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-completed { background: #d1fae5; color: #065f46; }
    .status-pending { background: #fef3c7; color: #92400e; }

    .btn-edit {
        background: var(--primary);
        color: white;
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        border: none;
        transition: 0.3s;
    }

    .btn-edit:hover {
        background: var(--secondary);
        transform: translateY(-2px);
    }
</style>

