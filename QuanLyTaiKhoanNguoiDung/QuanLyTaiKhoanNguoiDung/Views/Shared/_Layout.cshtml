                        </form>
                    </li>
                </ul>
            </nav>
        </aside>
    }

    <div class="main-wrapper @(showMenu ? "has-menu-margin" : "auth-layout")">
        @if (showMenu)
        {
            <header class="bg-white border-bottom p-3 d-flex justify-content-between align-items-center shadow-sm">
                <span class="nav-link">Chào, <strong>@hoTenHienThi</strong></span>
                <div class="user-profile">
                    <a href="@Url.Action("ChiTietNhanVien", "QuanLyNguoiDung", new { maNhanVien = maNguoiDungStr })">
                        <img src="https://ui-avatars.com/api/?name=@(tenDangNhap)&background=2ecc71&color=fff"
                             class="rounded-circle border" width="35" height="35" alt="avatar">
                    </a>
                </div>
            </header>
        }

        <main role="main" class="content-body">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSubmenu(element) {
            const submenu = element.nextElementSibling;
            const icon = element.querySelector('.submenu-arrow');
            $(submenu).slideToggle(300);
            $(icon).toggleClass('rotate-180');
        }

        $(document).ready(function() {
            const currentPath = window.location.pathname;
            $('.sidebar-link, .submenu-list li a').each(function() {
                const href = $(this).attr('href');
                if(href !== '#' && currentPath.includes(href)) {
                    $(this).addClass('active');
                    $(this).closest('.submenu-list').show();
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>