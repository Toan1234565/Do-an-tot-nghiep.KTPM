                        </a>
                    </li>

                    <li>
                        <a href="/HeThong/CauHinh" class="sidebar-link">
                            <i class="fas fa-cogs"></i>
                            <span>Cấu hình hệ thống</span>
                        </a>
                    </li>
                    <li class="mt-auto border-top pt-2">
                        <form asp-controller="QuanLyPhanQuyen" asp-action="DangXuat" method="get" id="logoutForm">
                            <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()" class="sidebar-link text-danger" style="text-decoration: none; display: flex; align-items: center; gap: 10px;">
                                <i class="fas fa-sign-out-alt"></i>
                                <span>Đăng xuất</span>
