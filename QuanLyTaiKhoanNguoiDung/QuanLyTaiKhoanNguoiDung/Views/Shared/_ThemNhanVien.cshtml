@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyNguoiDung.QuanLyPhanQuyen
@using QuanLyTaiKhoanNguoiDung.Models12.ServerQuanLyTaiSan.QuanLyKhoBai

<form id="formThemNhanVien">
    <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">
        <i class="fas fa-key me-2"></i>Thông tin đăng nhập
    </h6>
    <div class="row mb-4">
        <div class="col-md-6 mb-2">
            <label class="form-label small fw-bold">Tên đăng nhập *</label>
            <input type="text" class="form-control shadow-sm" name="TenDangNhap" required placeholder="Ví dụ: nhanvien.kho01">
        </div>
        <div class="col-md-6 mb-2">
            <label class="form-label small fw-bold">Email (Nhận mật khẩu) *</label>
            <input type="email" class="form-control shadow-sm" name="Email" required placeholder="nhanvien@congty.com">
        </div>
    </div>

    <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">
        <i class="fas fa-id-card me-2"></i>Hồ sơ cá nhân
    </h6>
    <div class="row mb-3">
        <div class="col-md-8 mb-2">
            <label class="form-label small fw-bold">Họ và tên nhân viên *</label>
            <input type="text" class="form-control shadow-sm" name="HoTenNhanVien" required placeholder="Nhập đầy đủ họ tên">
        </div>
        <div class="col-md-4 mb-2">
            <label class="form-label small fw-bold">Chức vụ *</label>
            <select name="maChucVu" class="form-select border rounded-3 shadow-sm" onchange="this.form.submit()">
                <option value="">-- Chức vụ --</option>
                @if (ViewBag.DanhSachChucVu != null)
                {
                    foreach (var cv in (List<ChucVuModel>)ViewBag.DanhSachChucVu)
                    {
                        <option value="@cv.MaChucVu" selected="@(ViewBag.CurrentMaChucVu == cv.MaChucVu)">@cv.TenChucVu</option>
                    }
                }
            </select>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-12 mb-2">
            <label class="form-label small fw-bold">Đơn vị / Kho bãi làm việc *</label>
            <select name="maKho" id="selectMaKho" class="form-select shadow-sm" required>
                <option value="">-- Chọn kho bãi --</option>
                @if (ViewBag.DanhSachKho != null)
                {
                    foreach (var kho in (List<TenKhobaiModels>)ViewBag.DanhSachKho)
                    {
                        <option value="@kho.MaKho">@kho.TenKhoBai</option>
                    }
                }
            </select>
        </div>
    </div>

    <div class="row mb-3">        
        <div class="col-md-6 mb-2">
            <label class="form-label small fw-bold">Số điện thoại *</label>
            <input type="text" class="form-control shadow-sm" name="SoDienThoai" required>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4 mb-2">
            <label class="form-label small fw-bold">Ngày sinh</label>
            <input type="date" class="form-control shadow-sm" name="NgaySinh">
        </div>
        <div class="col-md-4 mb-2">
            <label class="form-label small fw-bold">Giới tính</label>
            <select class="form-select shadow-sm" name="GioiTinh">
                <option value="Nam">Nam</option>
                <option value="Nữ">Nữ</option>
            </select>
        </div>
        <div class="col-md-4 mb-2">
            <label class="form-label small fw-bold">Số CCCD</label>
            <input type="text" class="form-control shadow-sm" name="SoCccd">
        </div>
    </div>

    <div id="vungThongTinTaiXe" class="mt-4 p-3 border border-warning rounded-3 bg-light shadow-sm" style="display: none; border-left: 5px solid #ffc107 !important;">
        <h6 class="text-warning fw-bold mb-3">
            <i class="fas fa-steering-wheel me-2"></i>Thông tin bằng lái tài xế
        </h6>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label small fw-bold">Số bằng lái *</label>
                <input type="text" class="form-control" name="SoBangLai" placeholder="Nhập số GPLX">
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-bold">Loại bằng lái *</label>
                <select class="form-select" name="LoaiBangLai">
                    <option value="">-- Chọn hạng bằng --</option>
                    <option value="B2">Hạng B2</option>
                    <option value="C">Hạng C</option>
                    <option value="D">Hạng D</option>
                    <option value="FC">Hạng FC</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <label class="form-label small fw-bold">Ngày cấp bằng</label>
                <input type="date" class="form-control" name="NgayCapBang">
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-bold">Ngày hết hạn *</label>
                <input type="date" class="form-control" name="NgayHetHanBang">
            </div>
        </div>
    </div>

    <div class="mt-4 pt-3 border-top text-end">
        <button type="button" class="btn btn-outline-secondary px-4 me-2" data-bs-dismiss="modal">Đóng</button>
        <button type="submit" class="btn btn-primary px-5 fw-bold shadow" id="btnSubmitForm">Lưu nhân viên</button>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Sử dụng Event Delegation để tránh lỗi khi Partial View được load động
        const body = document.body;
        const MA_CHUC_VU_TAI_XE = "16";

        // 1. Logic ẩn/hiện thông tin tài xế
        $(document).on('change', '#selectChucVu', function () {
            const vungTaiXe = document.getElementById('vungThongTinTaiXe');
            if (this.value === MA_CHUC_VU_TAI_XE) {
                $(vungTaiXe).slideDown(400);
                setTaiXeRequired(vungTaiXe, true);
            } else {
                $(vungTaiXe).slideUp(300);
                setTaiXeRequired(vungTaiXe, false);
            }
        });

        function setTaiXeRequired(container, isRequired) {
            if (!container) return;
            const inputs = container.querySelectorAll('input[name="SoBangLai"], select[name="LoaiBangLai"], input[name="NgayHetHanBang"]');
            inputs.forEach(el => {
                el.required = isRequired;
                if (!isRequired) el.value = ''; // Reset giá trị nếu ẩn
            });
        }

        // 2. Xử lý Gửi dữ liệu (Submit Form)
        $(document).on('submit', '#formThemNhanVien', async function (e) {
            e.preventDefault();
            const form = this;
            const btnSubmit = document.getElementById('btnSubmitForm');

            // Hiệu ứng Loading
            btnSubmit.disabled = true;
            const originalText = btnSubmit.innerHTML;
            btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...';

            try {
                const formData = new FormData(form);
                const rawData = Object.fromEntries(formData.entries());

                // Lấy tên đơn vị từ select text
                const selectKho = document.getElementById('selectMaKho');
                const tenKhoText = selectKho.options[selectKho.selectedIndex].text;

                // Xây dựng Payload chuẩn API
                const payload = {
                    TenDangNhap: rawData.TenDangNhap,
                    MatKhau: rawData.MatKhau,
                    HoTenNhanVien: rawData.HoTenNhanVien,
                    MaChucVu: parseInt(rawData.maChucVu),
                    MaKho: rawData.maKho ? parseInt(rawData.maKho) : null,
                    DonViLamViec: tenKhoText,
                    Email: rawData.Email,
                    SoDienThoai: rawData.SoDienThoai,
                    NgaySinh: rawData.NgaySinh || null,
                    GioiTinh: rawData.GioiTinh,
                    SoCccd: rawData.SoCccd,
                    // Dữ liệu tài xế lồng nhau
                    ThongTinTaiXe: rawData.maChucVu === MA_CHUC_VU_TAI_XE ? {
                        SoBangLai: rawData.SoBangLai,
                        LoaiBangLai: rawData.LoaiBangLai,
                        NgayCapBang: rawData.NgayCapBang || null,
                        NgayHetHanBang: rawData.NgayHetHanBang,
                        KinhNghiemNam: 0,
                        TrangThaiHoatDong: "Sẵn sàng",
                        DiemUyTin: 10
                    } : null
                };

                const response = await fetch('https://localhost:7022/api/quanlynguoidung/themnhanvien', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message || 'Đã thêm nhân viên mới thành công.',
                        confirmButtonColor: '#3085d6'
                    }).then(() => {
                        $('#ThemNhanVienModal').modal('hide');
                        location.reload();
                    });
                } else {
                    // Xử lý lỗi từ Backend (Ví dụ: trùng Email, tên đăng nhập)
                    Swal.fire({
                        icon: 'warning',
                        title: 'Thông báo',
                        text: result.message || 'Dữ liệu không hợp lệ, vui lòng kiểm tra lại.'
                    });
                    resetButton(btnSubmit, originalText);
                }
            } catch (error) {
                console.error("Fetch Error:", error);
                Swal.fire('Lỗi kết nối', 'Không thể kết nối đến máy chủ API hoặc lỗi Dependency Injection (DI) tại Server.', 'error');
                resetButton(btnSubmit, originalText);
            }
        });

        // 3. Reset form khi đóng modal để sạch dữ liệu cho lần sau
        $('#ThemNhanVienModal').on('hidden.bs.modal', function () {
            const form = document.getElementById('formThemNhanVien');
            if(form) form.reset();
            $('#vungThongTinTaiXe').hide();
        });

        function resetButton(btn, text) {
            btn.disabled = false;
            btn.innerHTML = text;
        }
    });

    // Hàm global để toggle mật khẩu (vì gọi trực tiếp từ onclick trong HTML)
    function togglePassword() {
        const passInput = document.getElementById("passInput");
        const icon = document.getElementById("toggleIcon");
        if (passInput) {
            if (passInput.type === "password") {
                passInput.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                passInput.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    }
</script>