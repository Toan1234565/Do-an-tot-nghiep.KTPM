@using QuanLyTaiKhoanNguoiDung.Models12.SeverQuanLyKhachHang.QuanLyKhachHang
@model IEnumerable<MucDoDichVuModesl>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản Lý Dịch Vụ - Logistics</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="~/css/giaodiendanhsach.css" asp-append-version="true" />
    <style>
       

        /* Badge & Icons */
        .service-icon-box {
            width: 40px;
            height: 40px;
            background: #eef2ff;
            color: var(--primary-color);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stat-badge {
            background: #dcfce7;
            color: #15803d;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
        }

        .loading-shimmer {
            color: #94a3b8;
        }

        /* Nút thao tác */
        .btn-edit {
            color: #64748b;
            background: #f1f5f9;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 6px;
            transition: all 0.2s;
        }

            .btn-edit:hover {
                background: var(--primary-color);
                color: white;
            }
    </style>
</head>
<body>
    <main class="container-fluid py-4 px-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div class="d-flex align-items-center">
                <h3 class="fw-bold text-dark m-0">
                    <i class="fa-solid fa-layer-group me-2 text-primary"></i>Quản Lý Mức Độ Dịch Vụ
                </h3>
                <span class="text-muted small ms-3 d-none d-sm-inline">
                    Cập nhật lần cuối: @DateTime.Now.ToString("HH:mm")
                </span>
            </div>

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-primary fw-bold px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addServiceModal">
                    <i class="fa-solid fa-plus me-2"></i>Thêm Dịch Vụ
                </button>

                <div class="position-relative">
                    <button type="button"
                            class="btn btn-light rounded-circle shadow-sm btn-nhat-ky d-flex align-items-center justify-content-center"
                            style="width: 42px; height: 42px; border: 1px solid #dee2e6;"
                            data-bs-toggle="modal"
                            data-bs-target="#detailModal"
                            data-service="Quản lý mức độ dịch vụ"
                            title="Xem nhật ký hoạt động">
                        <i class="fa-solid fa-bell text-primary fs-5"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                            <span class="visually-hidden">Hoạt động mới</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="stat-icon bg-primary-subtle text-primary"><i class="fa-solid fa-cubes"></i></div>
                    <div>
                        <div class="text-muted small fw-medium">Tổng dịch vụ</div>
                        <div class="h4 fw-bold mb-0">@Model?.Count()</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="stat-icon bg-success-subtle text-success"><i class="fa-solid fa-cart-shopping"></i></div>
                    <div>
                        <div class="text-muted small fw-medium">Tổng lượt đặt hàng</div>
                        <div class="h4 fw-bold mb-0 text-success" id="totalUsage"><i class="fas fa-circle-notch fa-spin"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-wrapper">
            <div class="filter-bar">
                <div class="row g-2">
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                            <input type="text" id="filterSearch" class="form-control border-start-0 shadow-none" 
                                   placeholder="Tìm theo tên hoặc mã..." value="@ViewBag.CurrentSearch">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select id="filterClass" class="form-select shadow-none">
                            <option value="all">Tất cả phân loại</option>
                            <option value="premium">✨ Cao cấp</option>
                            <option value="standard">📦 Cơ bản</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select id="filterStatus" class="form-select shadow-none" onchange="applyFilters()">
                            <!option value="all" @(ViewBag.CurrentStatus == "all" ? "selected" : "")>Tất cả trạng thái</!option>
                            <!option value="active" @(ViewBag.CurrentStatus == "active" ? "selected" : "")>🟢 Đang hoạt động</!option>
                            <!option value="paused" @(ViewBag.CurrentStatus == "paused" ? "selected" : "")>🔴 Tạm dừng</!option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-dark w-100 fw-medium" onclick="resetFilters()">
                            <i class="fa-solid fa-arrow-rotate-left me-1"></i> Làm mới
                        </button>
                    </div>
                </div>
            </div>

            <div>
                <table class="table custom-table" id="serviceTable">
                    <thead>
                        <tr>
                            <th>Thông tin dịch vụ</th>
                            <th>Cam kết xử lý</th>
                            <th>Hệ số phí</th>
                            <th>Phân loại</th>
                            <th>Thống kê đơn</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                <tr class="service-row"
                                    data-name="@item.TenDichVu?.ToLower()"
                                    data-id="@item.MaDichVu"
                                    data-class="@(item.LaCaoCap == true ? "premium" : "standard")"
                                    data-status="@(item.TrangThai == true ? "active" : "paused")">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="service-icon-box me-3">
                                                <i class="fa-solid fa-truck-fast"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.TenDichVu</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">ID: #@item.MaDichVu</div>
                                                <div class="text-muted" style="font-size: 0.75rem;">Ngày áp dụng: @item.NgayBatDau</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="fw-semibold">@item.ThoiGianCamKet</span> <small class="text-muted">Giờ</small></td>
                                    <td><span class="text-primary fw-bold">× @item.HeSoNhiPhan</span></td>
                                    <td>
                                        @if (item.LaCaoCap == true)
                                        {
                                            <span class="badge bg-warning text-dark" style="font-size: 0.65rem;"><i class="fa-solid fa-crown me-1"></i>PREMIUM</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-secondary border" style="font-size: 0.65rem;">STANDARD</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="usage-count" id="usage-@item.MaDichVu">
                                            <span class="loading-shimmer small"><i class="fa-solid fa-spinner fa-spin"></i> Đang tính...</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.TrangThai == true)
                                        {
                                            <div class="d-flex align-items-center text-success small fw-bold">
                                                <span class="p-1 bg-success rounded-circle me-2"></span> Hoạt động
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center text-danger small fw-bold">
                                                <span class="p-1 bg-danger rounded-circle me-2"></span> Tạm dừng
                                            </div>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn-edit me-1" title="Xem lịch sử" onclick="showHistory(@item.MaDichVu)">
                                            <i class="fa-solid fa-clock-rotate-left"></i>
                                        </button>
                                        <button class="btn-edit" title="Chỉnh sửa" onclick='editPrice(@Html.Raw(Json.Serialize(item)))'>
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination pagination-sm justify-content-end">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link border-0" href="@Url.Action("DanhSachDonHang", new { page = ViewBag.CurrentPage - 1 })">Trước</a>
                        </li>
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link border-0 mx-1 rounded" href="@Url.Action("DanhSachDonHang", new { page = i })">@i</a>
                            </li>
                        }
                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link border-0" href="@Url.Action("DanhSachDonHang", new { page = ViewBag.CurrentPage + 1 })">Sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
       

        
        <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Nhật ký hệ thống</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="modalBodyNhatKy">
                        @await Html.PartialAsync("_NhatKyPartial")
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="addServiceModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title fw-bold">Thêm Mức Độ Dịch Vụ Mới</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form id="addServiceForm">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên dịch vụ</label>
                                <input type="text" class="form-control" name="tenDichVu" required placeholder="VD: Giao hàng hỏa tốc">
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Thời gian cam kết (giờ)</label>
                                    <input type="number" class="form-control" name="thoiGianCamKet" required value="24">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Hệ số phí</label>
                                    <input type="number" step="0.1" class="form-control" name="heSoNhiPhan" required value="1.0">
                                </div>
                            </div>
                            <div class="mb-3 d-flex gap-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="laCaoCap" id="laCaoCap">
                                    <label class="form-check-label" for="laCaoCap">Dịch vụ cao cấp</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="trangThai" id="trangThai" checked>
                                    <label class="form-check-label" for="trangThai">Hoạt động</label>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" class="btn btn-primary px-4" onclick="submitAddService()">Lưu dữ liệu</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="editServiceModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-warning">
                        <h5 class="modal-title fw-bold">Chỉnh Sửa Mức Độ Dịch Vụ</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form id="editServiceForm">
                            <input type="hidden" id="editMaDichVu">
                            <input type="hidden" id="oldThoiGianCamKet">
                            <input type="hidden" id="oldHeSoNhiPhan">

                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên dịch vụ</label>
                                <input type="text" class="form-control" id="editTenDichVu" required>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold text-danger">Thời gian cam kết (giờ) *</label>
                                    <input type="number" class="form-control border-danger" id="editThoiGianCamKet" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold text-danger">Hệ số phí *</label>
                                    <input type="number" step="0.1" class="form-control border-danger" id="editHeSoNhiPhan" required>
                                </div>
                            </div>
                            <div id="versioningAlert" class="alert alert-info py-2 d-none" style="font-size: 0.85rem;">
                                <i class="fa-solid fa-circle-info me-2"></i>Dữ liệu cốt lõi thay đổi: Hệ thống sẽ <b>tạo phiên bản mới</b> và đóng phiên bản cũ.
                            </div>
                            <div class="mb-3 d-flex gap-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="editLaCaoCap">
                                    <label class="form-check-label">Dịch vụ cao cấp</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="editTrangThai">
                                    <label class="form-check-label">Hoạt động</label>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-outline-danger me-auto" onclick="confirmDisable()">Vô hiệu hóa</button>
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" class="btn btn-primary px-4" onclick="submitEditService()">Cập nhật</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="historyModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-dark text-white">
                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch sử các phiên bản</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Thời gian hiệu lực</th>
                                        <th>Cam kết</th>
                                        <th>Hệ số phí</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody id="historyTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const API_CONFIG = {
            BASE_URL: "https://localhost:7264/api",
            AUTH_PORTAL: "https://localhost:7022",
            ENDPOINTS: {
                THEM_MOI: "/mucdichvu/themmoi",
                CHINH_SUA: "/mucdichvu/chinhsua",
                VO_HIEU_HOA: "/mucdichvu/vohieuhoa",
                LICH_SU: "/mucdichvu/lichsu"
            }
        };

        // --- 1. THÊM MỚI ---
               // --- 1. THÊM MỚI (Khớp với MucDoDichVuCReate) ---
        async function submitAddService() {
            const form = document.getElementById('addServiceForm');
            const formData = new FormData(form);

            // Lưu ý: Tên thuộc tính phải khớp hoàn toàn với Class MucDoDichVuCReate trong C#
            const data = {
                TenDichVu: formData.get('tenDichVu'),
                ThoiGianCamKet: parseInt(formData.get('thoiGianCamKet')) || 0,
                HeSoNhiPhan: parseFloat(formData.get('heSoNhiPhan')) || 0,
                LaCaoCap: document.getElementById('laCaoCap').checked,
                TrangThai: document.getElementById('trangThai').checked,
                MaDichVu: 0 // Backend của bạn có gọi model.MaDichVu nên cần gửi kèm để tránh null
            };

            try {
                showLoading('Đang khởi tạo dịch vụ...');
                const response = await fetch(`${API_CONFIG.BASE_URL}${API_CONFIG.ENDPOINTS.THEM_MOI}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data), // Gửi JSON object
                    credentials: 'include'
                });

                // Nếu response không ok, đọc nội dung lỗi để biết trường nào sai
                if (!response.ok) {
                    const errorData = await response.json();
                    console.error("Lỗi Validation:", errorData);
                    Swal.fire('Thất bại', errorData.message || 'Dữ liệu nhập vào không hợp lệ', 'error');
                    return;
                }

                await handleApiResponse(response);
            } catch (error) {
                handleNetworkError(error);
            }
        }



        // --- 2. CHUẨN BỊ EDIT (Đổ dữ liệu vào Modal) ---
        function editPrice(item) {
            if (!item.trangThai) {
                Swal.fire({
                    title: 'Dịch vụ đã đóng',
                    text: 'Bản ghi này không còn hoạt động. Bạn chỉ có thể xem lịch sử thay đổi.',
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: 'Xem lịch sử',
                    cancelButtonText: 'Đóng'
                }).then((result) => {
                    if (result.isConfirmed) showHistory(item.maDichVu);
                });
                return;
            }

            // Đổ dữ liệu vào Modal
            document.getElementById('editMaDichVu').value = item.maDichVu;
            document.getElementById('editTenDichVu').value = item.tenDichVu;
            document.getElementById('editThoiGianCamKet').value = item.thoiGianCamKet;
            document.getElementById('editHeSoNhiPhan').value = item.heSoNhiPhan;
            document.getElementById('editLaCaoCap').checked = item.laCaoCap;
            document.getElementById('editTrangThai').checked = item.trangThai;

            // Xử lý cảnh báo thay đổi (Versioning)
            const checkVersioning = () => {
                const isChanged = document.getElementById('editThoiGianCamKet').value != item.thoiGianCamKet ||
                                  document.getElementById('editHeSoNhiPhan').value != item.heSoNhiPhan;
                const alertEl = document.getElementById('versioningAlert');
                if (alertEl) alertEl.classList.toggle('d-none', !isChanged);
            };

            document.getElementById('editThoiGianCamKet').oninput = checkVersioning;
            document.getElementById('editHeSoNhiPhan').oninput = checkVersioning;

            const editModal = new bootstrap.Modal(document.getElementById('editServiceModal'));
            editModal.show();
        }

        // --- 3. GỬI CẬP NHẬT ---
               // --- 2. CHỈNH SỬA (Khớp với MucDoDichVuUpdata) ---
        async function submitEditService() {
            // Backend yêu cầu MaDichVu > 0
            const maDichVu = parseInt(document.getElementById('editMaDichVu').value);

            const data = {
                MaDichVu: maDichVu,
                TenDichVu: document.getElementById('editTenDichVu').value,
                ThoiGianCamKet: parseInt(document.getElementById('editThoiGianCamKet').value) || 0,
                HeSoNhiPhan: parseFloat(document.getElementById('editHeSoNhiPhan').value) || 0,
                LaCaoCap: document.getElementById('editLaCaoCap').checked,
                TrangThai: document.getElementById('editTrangThai').checked
            };

            try {
                showLoading('Đang cập nhật hệ thống...');
                const response = await fetch(`${API_CONFIG.BASE_URL}${API_CONFIG.ENDPOINTS.CHINH_SUA}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'include'
                });

                if (!response.ok) {
                    const errorData = await response.json();
                    Swal.fire('Lỗi cập nhật', errorData.message || 'Không thể chỉnh sửa', 'error');
                    return;
                }

                await handleApiResponse(response);
            } catch (error) {
                handleNetworkError(error);
            }
        }

        // --- 4. VÔ HIỆU HÓA (Hàm bị thiếu của bạn) ---
        async function confirmDisable() {
            const id = document.getElementById('editMaDichVu').value;
            if (!id) return;

            const result = await Swal.fire({
                title: 'Xác nhận vô hiệu hóa?',
                text: "Dịch vụ sẽ ngừng hoạt động. Bạn sẽ cần tạo phiên bản mới nếu muốn kích hoạt lại!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý dừng',
                cancelButtonText: 'Hủy'
            });

            if (result.isConfirmed) {
                try {
                    showLoading('Đang xử lý...');
                    const response = await fetch(`${API_CONFIG.BASE_URL}${API_CONFIG.ENDPOINTS.VO_HIEU_HOA}/${id}`, {
                        method: 'PUT',
                        credentials: 'include'
                    });
                    await handleApiResponse(response);
                } catch (error) {
                    handleNetworkError(error);
                }
            }
        }

        // --- 5. TRUY VẾT LỊCH SỬ ---
        async function showHistory(id) {
            const tbody = document.getElementById('historyTableBody');
            if (!tbody) return;

            tbody.innerHTML = '<tr><td colspan="4" class="text-center"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>';

            const historyModal = new bootstrap.Modal(document.getElementById('historyModal'));
            historyModal.show();

            try {
                const response = await fetch(`${API_CONFIG.BASE_URL}${API_CONFIG.ENDPOINTS.LICH_SU}/${id}`, { credentials: 'include' });
                const data = await response.json();

                if (!data || data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center">Không có dữ liệu lịch sử</td></tr>';
                    return;
                }

                tbody.innerHTML = data.map(item => `
                    <tr class="${item.trangThai ? 'table-success' : ''}">
                        <td>
                            <div class="fw-bold">${new Date(item.ngayBatDau).toLocaleDateString('vi-VN')}</div>
                            <small class="text-muted">Đến: ${item.ngayKetThuc ? new Date(item.ngayKetThuc).toLocaleDateString('vi-VN') : 'Hiện tại'}</small>
                        </td>
                        <td>${item.thoiGianCamKet} giờ</td>
                        <td><span class="badge bg-light text-dark border">x${item.heSoNhiPhan}</span></td>
                        <td>
                            <span class="badge ${item.trangThai ? 'bg-success' : 'bg-secondary'}">
                                ${item.trangThai ? 'Đang áp dụng' : 'Đã thay thế'}
                            </span>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-danger text-center">Lỗi tải dữ liệu</td></tr>';
            }
        }

        // --- HELPER FUNCTIONS ---
        function showLoading(title) {
            Swal.fire({
                title: title,
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });
        }

        async function handleApiResponse(response) {
            if (response.status === 401) {
                Swal.fire('Hết hạn!', 'Vui lòng đăng nhập lại.', 'warning')
                    .then(() => window.location.href = `${API_CONFIG.AUTH_PORTAL}/Login`);
                return;
            }

            const result = await response.json();
            if (response.ok) {
                Swal.fire('Thành công', result.message || 'Thao tác thành công', 'success')
                    .then(() => location.reload());
            } else {
                // Hiển thị lỗi chi tiết từ Validation (nếu có)
                Swal.fire('Thất bại', result.message || 'Dữ liệu không hợp lệ (Lỗi 400)', 'error');
            }
        }

        function handleNetworkError(err) {
            console.error("Network Error:", err);
            Swal.fire('Lỗi kết nối', 'Server không phản hồi hoặc lỗi mạng.', 'error');
        }
    </script>
</body>
</html>