@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyKhachHang
@model IEnumerable<HopDongVanChuyenModels>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản Lý Hợp Đồng Vận Chuyển</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="~/css/giaodiendanhsach.css" asp-append-version="true" />
    <style>
        

        .contract-icon {
            width: 40px;
            height: 40px;
            background: #eef2ff;
            color: var(--primary-color);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
        }

        .badge-status {
            font-size: 0.75rem;
            padding: 5px 12px;
            border-radius: 50px;
            font-weight: 600;
        }

        .btn-detail {
            background-color: #f8fafc;
            color: var(--primary-color);
            border: 1px solid var(--primary-color);
            transition: all 0.3s ease;
        }

            .btn-detail:hover {
                background-color: var(--primary-color);
                color: white;
            }
    </style>
</head>
<body>
    <main class="container-fluid py-4">
        <div class="main-card">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="mb-0 fs-4">
                    <i class="fa-solid fa-tags me-2 text-primary"></i>Quản Lý hợp đồng
                </h1>

                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalThemHopDong">
                        <i class="fa-solid fa-plus me-1"></i> Thêm hợp đồng
                    </button>
                    

                    <div class="position-relative">
                        <button type="button"
                                class="btn btn-light position-relative p-0 d-flex align-items-center justify-content-center rounded-circle border shadow-sm btn-nhat-ky"
                                style="width: 42px; height: 42px; transition: all 0.3s;"
                                data-bs-toggle="modal"
                                data-bs-target="#detailModal"
                                data-service="Quản lý hợp đồng"
                                title="Xem nhật ký hoạt động">
                            <i class="fa-solid fa-bell fs-5 text-primary"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </button>
                    </div>
                    <a href="@Url.Action("DanhSachHopDong")" class="btn btn-light btn-sm border rounded-pill px-3">
                        <i class="fa-solid fa-arrows-rotate me-1 text-muted"></i> Làm mới
                    </a>
                </div>
            </div>
           @* Filter Form *@
            <form id="filterForm" method="get" action="@Url.Action("DanhSachHopDong")" class="bg-light border rounded-3 p-3 mb-4 shadow-sm">
                <div class="row g-3">
                    @* Tìm kiếm *@
                    <div class="col-md-3">
                        <label class="small fw-bold text-muted mb-1">Tìm kiếm</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white"><i class="fas fa-search"></i></span>
                            <input type="text" name="Search" class="form-control" placeholder="Tên hợp đồng..." value="@ViewBag.Search" />
                        </div>
                    </div>

                    @* Lọc Trạng Thái (Mới thêm) *@
                    <div class="col-md-2">
                        <label class="small fw-bold text-muted mb-1">Trạng thái</label>
                        <select name="trangThai" class="form-select form-select-sm">
                            <option value="Tất cả" selected="@(ViewBag.TrangThai == "Tất cả" ? "selected" : null)">Tất cả</option>
                            <option value="Đang thực hiện" selected="@(ViewBag.TrangThai == "Đang thực hiện" ? "selected" : null)">Đang thực hiện</option>
                            <option value="Hết hiệu lực" selected="@(ViewBag.TrangThai == "Hết hiệu lực" ? "selected" : null)">Hết hiệu lực</option>
                            <option value="Hủy bỏ" selected="@(ViewBag.TrangThai == "Hủy bỏ" ? "selected" : null)">Hủy bỏ</option>
                        </select>
                    </div>

                    @* Từ ngày *@
                    <div class="col-md-3">
                        <label class="small fw-bold text-muted mb-1">Từ ngày</label>
                        <input type="date" name="thoiGianBD" class="form-control form-control-sm" value="@ViewBag.ThoiGianBD" />
                    </div>

                    @* Đến ngày *@
                    <div class="col-md-3">
                        <label class="small fw-bold text-muted mb-1">Đến ngày</label>
                        <input type="date" name="thoiGianKT" class="form-control form-control-sm" value="@ViewBag.ThoiGianKT" />
                    </div>

                    @* Nút Lọc *@
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="fas fa-filter"></i>
                        </button>
                    </div>
                </div>
            </form>
            <div>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Tên Hợp Đồng</th>
                            <th>Thời hạn</th>
                            <th>Loại hàng hóa</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr onclick="location.href='@Url.Action("ChiTietHopDong", new { id = item.MaHopDong })'" style="cursor: pointer;">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="contract-icon me-3">
                                                <i class="fa-solid fa-file-lines"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.TenHopDong</div>
                                                <div class="small text-muted">Mã HD: #@item.MaHopDong</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small"><b>Ký:</b> @item.NgayKy?.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-danger"><b>Hết:</b> @item.NgayHetHan?.ToString("dd/MM/yyyy")</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary opacity-75">@item.LoaiHangHoa</span>
                                    </td>
                                    <td>
                                        <span class="badge-status">@item.TrangThai</span>
                                    </td>
                                    <td class="text-end">
                                        <a href="@Url.Action("ChiTietHopDong", new { id = item.MaHopDong })" class="btn btn-detail btn-sm rounded-pill px-3">
                                            <i class="fa-solid fa-eye me-1"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center py-5 text-muted">Không tìm thấy hợp đồng nào.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination pagination-sm justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link shadow-none" href="@Url.Action("DanhSachHopDong", new { Search = ViewBag.Search, thoiGianBD = ViewBag.ThoiGianBD, thoiGianKT = ViewBag.ThoiGianKT, page = i })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </main>
    <div class="modal fade" id="modalThemHopDong" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fa-solid fa-file-circle-plus me-2"></i>Thêm Hợp Đồng Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="formThemHopDong" enctype="multipart/form-data">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small">Tên hợp đồng <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="add_TenHopDong" name="TenHopDong" placeholder="Ví dụ: Hợp đồng vận chuyển hàng điện tử" required>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small">Số điện thoại khách hàng <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                                    <input type="text" class="form-control" id="add_SoDienThoai" placeholder="Nhập đủ 10 số..." maxlength="10">
                                    <span id="phone_status" class="input-group-text d-none"></span>
                                </div>
                            </div>
                            <div id="new_customer_fields" class="mt-3 border p-3 rounded bg-light d-none">
                                <h6 class="text-primary mb-3"><i class="fa-solid fa-user-plus me-2"></i>Thông tin khách hàng mới</h6>
                             
                                <
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label class="small fw-bold">Tên liên hệ</label>
                                        <input type="text" class="form-control form-control-sm" id="add_TenLienHe" placeholder="Nguyễn Văn A">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="small fw-bold">Tên công ty</label>
                                        <input type="text" class="form-control form-control-sm" id="add_TenCongTy" placeholder="Công ty ABC">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small fw-bold">Thành phố</label>
                                        <input type="text" class="form-control form-control-sm" id="add_ThanhPho" placeholder="Hà Nội">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small fw-bold">Quận/Huyện</label>
                                        <input type="text" class="form-control form-control-sm" id="add_Phuong" placeholder="Cầu Giấy">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small fw-bold">Địa chỉ chi tiết</label>
                                        <input type="text" class="form-control form-control-sm" id="add_Duong" placeholder="Số 123 đường...">
                                    </div>
                                </div>
                            </div>
                           
                            <input type="hidden" id="saved_MaKhachHang" value="">

                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Loại hàng hóa</label>
                                <input type="text" class="form-control" id="add_LoaiHangHoa" name="LoaiHangHoa" placeholder="Ví dụ: Đồ gia dụng">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Trạng thái</label>
                                <select class="form-select" id="add_TrangThai" name="TrangThai">
                                    <option value="Đang thực hiện">Đang thực hiện</option>
                                    <option value="Hết hiệu lực">Hết hiệu lực</option>
                                    <option value="Hủy bỏ">Hủy bỏ</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Ngày ký kết</label>
                                <input type="date" class="form-control" id="add_NgayKy" name="NgayKy">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Ngày hết hạn</label>
                                <input type="date" class="form-control" id="add_NgayHetHan" name="NgayHetHan">
                            </div>
                            <div class="col-12 mt-4">
                                <label class="form-label fw-bold small text-primary">Tải lên File mới (PDF, Word) để thay thế</label>
                                <input type="file" class="form-control" id="add_File" accept=".pdf,.doc,.docx">
                                
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" onclick="thucHienThemMoi()">
                        <i class="fa-solid fa-save me-2"></i>Lưu hợp đồng
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nhật ký hệ thống</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="modalBodyNhatKy">
                    @await Html.PartialAsync("_NhatKyPartial")
                </div>
            </div>
        </div>
    </div>
</body>
</html>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


<script>
    // 1. Xử lý kiểm tra Số điện thoại khi nhập
    document.getElementById('add_SoDienThoai').addEventListener('input', async function(e) {
        const sdt = e.target.value.trim();
        const statusIcon = document.getElementById('phone_status');
        const extraFields = document.getElementById('new_customer_fields');
        const savedMaKH = document.getElementById('saved_MaKhachHang');

        // Chỉ xử lý khi nhập đủ 10 chữ số
        if (sdt.length === 10) {
            statusIcon.classList.remove('d-none');
            statusIcon.innerHTML = '<i class="fas fa-spinner fa-spin text-primary"></i>';

            try {
                const response = await fetch('https://localhost:7149/api/quanlykhachhang/check_so_dien_thoai', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ SoDienThoai: sdt }),
                    credentials: 'include'
                });

                if (response.ok) {
                    const data = await response.json();

                    // Trường hợp tìm thấy khách hàng cũ
                    if (data && data.maKhachHang) {
                        statusIcon.innerHTML = '<i class="fas fa-check-circle text-success" title="Khách hàng cũ"></i>';
                        extraFields.style.display = 'none'; // Ẩn ô nhập thông tin mới
                        savedMaKH.value = data.maKhachHang;

                        // Xóa dữ liệu cũ trong các ô nhập thông tin khách hàng mới (nếu có)
                        xoaTrangThongTinKhachHangMoi();
                    }
                    else {
                        hienThiNhapKhachHangMoi(statusIcon, extraFields, savedMaKH);
                    }
                } else {
                    // API trả về 404 hoặc lỗi khác -> Coi như khách hàng mới
                    hienThiNhapKhachHangMoi(statusIcon, extraFields, savedMaKH);
                }
            } catch (error) {
                console.error("Lỗi check SDT:", error);
                hienThiNhapKhachHangMoi(statusIcon, extraFields, savedMaKH);
            }
        } else {
            // Khi đang nhập dở hoặc xóa bớt số
            statusIcon.classList.add('d-none');
            extraFields.style.display = 'none';
            savedMaKH.value = "";
        }
    });

    // Hàm bổ trợ hiển thị ô nhập khách hàng mới
    function hienThiNhapKhachHangMoi(icon, fields, hiddenInput) {
        icon.innerHTML = '<i class="fas fa-user-plus text-warning" title="Khách hàng mới"></i>';
        fields.style.display = 'block'; // Hiện ô nhập thông tin
        hiddenInput.value = ""; // Đánh dấu là tạo mới
    }

    function xoaTrangThongTinKhachHangMoi() {
        document.getElementById('add_TenLienHe').value = "";
        document.getElementById('add_TenCongTy').value = "";
        document.getElementById('add_ThanhPho').value = "";
        document.getElementById('add_Phuong').value = "";
        document.getElementById('add_Duong').value = "";
    }

    // 2. Hàm thực hiện Lưu (Giữ nguyên logic cũ của bạn nhưng bọc trong try-catch chặt chẽ)
    async function thucHienThemMoi() {
        const form = document.getElementById('formThemHopDong');
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        Swal.fire({
            title: 'Đang xử lý...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        try {
            const sdt = document.getElementById('add_SoDienThoai').value.trim();
            let finalMaKH = document.getElementById('saved_MaKhachHang').value;

            // Nếu là khách hàng mới (chưa có MaKH)
            if (!finalMaKH) {
                const customerPayload = {
                    SoDienThoai: sdt,
                    TenLienHe: document.getElementById('add_TenLienHe').value,
                    TenCongTy: document.getElementById('add_TenCongTy').value,
                    DiaChi: {
                        ThanhPho: document.getElementById('add_ThanhPho').value,
                        Phuong: document.getElementById('add_Phuong').value,
                        Duong: document.getElementById('add_Duong').value
                    }
                };

                const resCustomer = await fetch('https://localhost:7149/api/quanlykhachhang/them_moi_khach_hang', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(customerPayload),
                    credentials: 'include'
                });

                if (!resCustomer.ok) throw new Error("Không thể tạo thông tin khách hàng mới.");
                const customerData = await resCustomer.json();
                finalMaKH = customerData.maKhachHang;
            }

            // Gửi dữ liệu hợp đồng
            const formData = new FormData();
            formData.append("TenHopDong", document.getElementById('add_TenHopDong').value.trim());
            formData.append("MaKhachHang", finalMaKH);
            formData.append("LoaiHangHoa", document.getElementById('add_LoaiHangHoa').value.trim());
            formData.append("TrangThai", document.getElementById('add_TrangThai').value);
            formData.append("NgayKy", document.getElementById('add_NgayKy').value);
            formData.append("NgayHetHan", document.getElementById('add_NgayHetHan').value);

            const fileInput = document.getElementById('add_File');
            if (fileInput.files.length > 0) formData.append("file", fileInput.files[0]);

            const response = await fetch('https://localhost:7149/api/quanlyhopdong/them-moi', {
                method: 'POST',
                body: formData,
                credentials: 'include'
            });

            if (response.ok) {
                await Swal.fire('Thành công!', 'Hợp đồng đã được lưu.', 'success');
                location.reload();
            } else {
                const err = await response.json();
                throw new Error(err.message || 'Lỗi khi lưu hợp đồng');
            }
        } catch (error) {
            Swal.fire('Lỗi', error.message, 'error');
        }
    }
</script>