@model QuanLyTaiKhoanNguoiDung.Models12.QuanLyKhachHang.HopDongVanChuyenModels

@{
    ViewData["Title"] = "Chi Tiết Hợp Đồng";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body { background-color: #f4f7f6; font-family: 'Inter', sans-serif; }
    .container { background-color: #f8f9fa; border-radius: 20px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .card { border: none; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); margin-bottom: 2rem; }
    .card-header { background: white; border-bottom: 1px solid #eee; padding: 1.25rem; border-radius: 15px 15px 0 0 !important; }
    .info-label { color: #6c757d; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 0.25rem; }
    .info-value { color: #2d3436; font-weight: 500; }
    .status-badge { padding: 0.5rem 1rem; border-radius: 50px; font-weight: 600; font-size: 0.85rem; }
    .client-box { background: #eef2ff; border-radius: 12px; padding: 1.5rem; }
    .address-box { border-left: 3px solid #4361ee; padding-left: 1rem; }
</style>

<div class="container py-5">
    
    <div class="d-flex justify-content-between align-items-center px-2 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/QuanLyHopDong/DanhSachHopDong" class="text-decoration-none">Quản lý</a></li>
                    <li class="breadcrumb-item active">Chi tiết hợp đồng</li>
                </ol>
            </nav>
            <h3 class="fw-bold m-0" style="color: #333;">@Model?.TenHopDong</h3>
            <span class="text-muted small">Mã hệ thống: #@Model?.MaHopDong</span>
        </div>
        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 10px; background: white;">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-file-contract text-primary me-2"></i>Thông tin chung</h5>
                    <button class="btn btn-sm btn-outline-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#modalSuaHopDong">
                        <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa
                    </button>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-label">Loại hàng hóa</div>
                            <div class="info-value">@Model?.LoaiHangHoa</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">Ngày ký kết</div>
                            <div class="info-value text-primary">@Model?.NgayKy?.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="info-label">Ngày hết hạn</div>
                            <div class="info-value text-danger">@Model?.NgayHetHan?.ToString("dd/MM/yyyy")</div>
                        </div>

                        <div class="col-12">
                            <hr class="text-muted opacity-25">
                            <div class="info-label">Tệp đính kèm</div>
                            @if (Model.HasFile)
                            {
                                <div class="d-flex align-items-center p-3 border rounded-3 bg-light mt-2">
                                    <i class="fa-solid fa-file-pdf fa-2x text-danger me-3"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold text-truncate" style="max-width: 250px;" title="@Model.TenFileGoc">@Model.TenFileGoc</div>
                                        <small class="text-muted">Định dạng file đính kèm</small>
                                    </div>
                                    <div class="btn-group shadow-sm">
                                        <a href="@Url.Action("TaiFile", new { id = Model.MaHopDong, inline = true })"
                                           target="_blank"
                                           class="btn btn-outline-primary px-3">
                                            <i class="fa-solid fa-eye me-1"></i> Xem trực tiếp
                                        </a>

                                        <a href="@Url.Action("TaiFile", new { id = Model.MaHopDong })"
                                           class="btn btn-primary px-3">
                                            <i class="fa-solid fa-download me-1"></i> Tải về máy
                                        </a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning py-2 mt-2">
                                    <i class="fa-solid fa-triangle-exclamation me-2"></i>Chưa tải lên file hợp đồng chính thức.
                                </div>
                            }                          
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-user-tie text-primary me-2"></i>Khách hàng</h5>
                </div>
                <div class="card-body">
                    <div class="client-box mb-4">
                        <div class="fw-bold h5 text-primary mb-1">@Model.MaKhachHangNavigation?.TenCongTy</div>
                        <div class="small text-muted mb-3">Liên hệ: @Model.MaKhachHangNavigation?.TenLienHe</div>
                        <div class="d-flex align-items-center mb-2">
                            <i class="fa-solid fa-phone me-2 text-muted small"></i>
                            <span class="info-value small">@Model.MaKhachHangNavigation?.SoDienThoai</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-envelope me-2 text-muted small"></i>
                            <span class="info-value small">@Model.MaKhachHangNavigation?.Email</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSuaHopDong" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalLabel">Cập nhật thông tin hợp đồng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formCapNhat">
                    <input type="hidden" id="edit_MaHopDong" value="@Model.MaHopDong">
                    <input type="hidden" id="edit_MaKhachHang" value="@Model.MaKhachHang">
                    
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold small">Tên công ty</label>
                            <input type="text" class="form-control" value="@Model.MaKhachHangNavigation?.TenCongTy" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold small">Tên liên hệ</label>
                            <input type="text" class="form-control" value="@Model.MaKhachHangNavigation?.TenLienHe" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold small">Tên hợp đồng</label>
                            <input type="text" class="form-control" id="edit_TenHopDong" value="@Model.TenHopDong" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Loại hàng hóa</label>
                            <input type="text" class="form-control" id="edit_LoaiHangHoa" value="@Model.LoaiHangHoa">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Trạng thái</label>
                            <select class="form-select" id="edit_TrangThai">
                                <option value="Đang thực hiện" selected="@(Model.TrangThai == "Đang thực hiện")">Đang thực hiện</option>
                                <option value="Hoàn thành" selected="@(Model.TrangThai == "Hết hiệu lực")">Hết liệu lực</option>
                                <option value="Hủy bỏ" selected="@(Model.TrangThai == "Hủy bỏ")">Hủy bỏ</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Ngày ký kết</label>
                            <input type="date" class="form-control" id="edit_NgayKy" value="@Model.NgayKy?.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Ngày hết hạn</label>
                            <input type="date" class="form-control" id="edit_NgayHetHan" value="@Model.NgayHetHan?.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-12 mt-4">
                            <label class="form-label fw-bold small text-primary">Tải lên File mới (PDF, Word) để thay thế</label>
                            <input type="file" class="form-control" id="edit_File" accept=".pdf,.doc,.docx">
                            @if (Model.HasFile) {
                                <div class="mt-1 small text-muted"><i class="fa-solid fa-paperclip"></i> File hiện có: @Model.TenFileGoc</div>
                            }
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" onclick="thucHienCapNhat()">
                    <i class="fa-solid fa-save me-2"></i>Lưu thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    async function thucHienCapNhat() {
        const id = document.getElementById('edit_MaHopDong').value;
        const tenHD = document.getElementById('edit_TenHopDong').value.trim();

        if (!tenHD) {
            Swal.fire('Chú ý', 'Vui lòng không để trống tên hợp đồng', 'warning');
            return;
        }

        const formData = new FormData();
        formData.append("MaHopDong", id);
        formData.append("TenHopDong", tenHD);
        formData.append("LoaiHangHoa", document.getElementById('edit_LoaiHangHoa').value.trim());
        formData.append("TrangThai", document.getElementById('edit_TrangThai').value);

        const ngayKy = document.getElementById('edit_NgayKy').value;
        if (ngayKy) formData.append("NgayKy", ngayKy);

        const ngayHetHan = document.getElementById('edit_NgayHetHan').value;
        if (ngayHetHan) formData.append("NgayHetHan", ngayHetHan);

        const fileInput = document.getElementById('edit_File');
        if (fileInput.files.length > 0) {
            formData.append("file", fileInput.files[0]);
        }

        Swal.fire({
            title: 'Đang lưu dữ liệu...',
            allowOutsideClick: false,
            didOpen: () => Swal.showLoading()
        });

        try {
            const response = await fetch(`https://localhost:7149/api/quanlyhopdong/cap-nhat/${id}`, {
                method: 'PUT',
                body: formData,
                // QUAN TRỌNG: credentials phải nằm cùng cấp với method và body
                credentials: 'include'
            });

            const result = await response.json();

            if (response.ok && result.success) {
                await Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: result.message,
                    timer: 2000,
                    showConfirmButton: false
                });
                location.reload();
            } else {
                let errorDetail = result.message || "Có lỗi xảy ra khi cập nhật.";
                if (result.errors) {
                    errorDetail = Object.values(result.errors).flat().join("<br>");
                }
                Swal.fire('Thất bại', errorDetail, 'error');
            }
        } catch (error) {
            console.error("Fetch Error:", error);
            Swal.fire('Lỗi kết nối', 'Không thể kết nối đến máy chủ API.', 'error');
        }
    }
</script>
<script>
    function viewFile(id) {
        // Đường dẫn gọi đến Action Download của bạn
        const url = `@Url.Action("DownloadFile", "HopDong")?id=${id}`;

        // Mở file trong tab mới
        // Lưu ý: Để xem trực tiếp được, Server/Controller phải trả về 'inline' thay vì 'attachment'
        // trong header Content-Disposition. Nếu không nó vẫn sẽ tải về.
        window.open(url, '_blank');
    }

    // Giữ nguyên hàm thucHienCapNhat() cũ của bạn ở đây...
</script>
