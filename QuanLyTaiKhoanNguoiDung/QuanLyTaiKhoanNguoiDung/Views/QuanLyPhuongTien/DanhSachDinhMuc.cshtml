@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyPhuongTien
@model IEnumerable<LoaiXeModels>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản Lý Định Mức Bảo Trì</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="~/css/giaodiendanhsach.css" asp-append-version="true" />
    <style>
      

        .group-header {
            background-color: #fcfdfe;
            font-weight: 700;
            color: var(--primary-color);
            border-right: 1px solid #edf2f7;
        }

        .badge-km {
            background: #eef2ff;
            color: #4361ee;
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 700;
        }

        .badge-month {
            background: #fff7ed;
            color: #c2410c;
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 600;
        }

        .btn-add-new {
            background: var(--primary-color);
            color: white;
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-add-new:hover {
                background: var(--secondary-color);
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
                color: white;
            }

        .btn-edit {
            color: #94a3b8;
            transition: all 0.2s;
            background: none;
            border: none;
        }

            .btn-edit:hover {
                color: var(--primary-color);
                background: #eef2ff;
            }

        .maintenance-card {
            background: white;
            border-radius: 15px;
            border: 1px solid #eef2f6;
            margin-bottom: 1.5rem; /* Đây là lệnh để tách các khối */
            transition: all 0.3s ease;
            padding: 1.5rem;
        }

            .maintenance-card:hover {
                box-shadow: 0 10px 20px rgba(0,0,0,0.05);
                transform: translateY(-3px);
            }

        .item-row {
            border-bottom: 1px solid #f8fafc;
            padding: 12px 0;
        }

            .item-row:last-child {
                border-bottom: none;
            }
    </style>
</head>
<body>
    <main class="container-fluid py-4">
        <div class="main-card">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <h2 class="page-title mb-0">
                    <i class="fa-solid fa-screwdriver-wrench me-3 text-primary"></i>Định Mức Bảo Trì
                </h2>
                <button class="btn btn-add-new" id="btnOpenAddModal">
                    <i class="fas fa-plus me-2"></i>Thêm định mức mới
                </button>
                <div class="position-relative">
                    <button type="button"
                            class="btn btn-light position-relative p-0 d-flex align-items-center justify-content-center rounded-circle border shadow-sm btn-nhat-ky"
                            style="width: 42px; height: 42px; transition: all 0.3s;"
                            data-bs-toggle="modal"
                            data-bs-target="#detailModal"
                            data-service="Quản lý phương tiện"
                            title="Xem nhật ký hoạt động">
                        <i class="fa-solid fa-bell fs-5 text-primary"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                            <span class="visually-hidden">New alerts</span>
                        </span>
                    </button>
                </div>
            </div>

            <div class="filter-section">
                <form method="get" action="@Url.Action("DanhSachDinhMuc")" class="row align-items-end g-3">
                    <div class="col-12 col-md-4">
                        <label class="filter-label"><i class="fa-solid fa-filter me-1"></i> Lọc theo loại xe</label>
                        <select name="maLoaiXe" class="form-select border-0 shadow-sm" onchange="this.form.submit()" style="border-radius: 10px; height: 45px;">
                            <option value="">Tất cả các loại xe</option>
                            @if (ViewBag.DanhSachLoaiXe != null)
                            {
                                foreach (var loai in ViewBag.DanhSachLoaiXe)
                                {
                                    <option value="@loai.MaLoaiXe" selected="@(ViewBag.CurrentMaLoaiXe == loai.MaLoaiXe)">
                                        @loai.TenLoai
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </form>
            </div>

           <div class="maintenance-container">
                @if (Model != null && Model.Any())
                {
                    foreach (var group in Model)
                    {
                        var listHangMuc = group.DanhSachHangMuc ?? new List<DinhMucModels>();
            
                        <div class="card mb-4 border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
                            <div class="card-header border-0 py-3 d-flex justify-content-between align-items-center" style="background-color: #fcfdfe;">
                                <div>
                                    <h5 class="fw-bold text-primary mb-0" style="letter-spacing: -0.2px;">
                                        <i class="fa-solid fa-truck-moving me-2"></i>@group.TenLoai
                                    </h5>
                                    <small class="text-muted">Có @listHangMuc.Count hạng mục bảo trì</small>
                                </div>
                            </div>

                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="custom-table">
                                        <thead class="table-light">
                                            <tr style="font-size: 0.75rem; text-transform: uppercase; color: #64748b;">
                                                <th class="ps-4 py-3" width="40%">Hạng mục bảo trì</th>
                                                <th class="text-center py-3">Định mức (Km)</th>
                                                <th class="text-center py-3">Định mức (Tháng)</th>
                                                <th class="text-center py-3" width="10%">Sửa</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var hangMuc in listHangMuc)
                                            {
                                                <tr>
                                                    <td class="ps-4 py-3 fw-medium text-dark">@hangMuc.TenHangMuc</td>
                                                    <td class="text-center py-3">
                                                        <span class="badge-km px-3 py-2">@string.Format("{0:N0}", hangMuc.DinhMucKm) Km</span>
                                                    </td>
                                                    <td class="text-center py-3">
                                                        <span class="badge-month px-3 py-2">@hangMuc.DinhMucThang Tháng</span>
                                                    </td>
                                                    <td class="text-center py-3">
                                                        <button class="btn-edit p-2 rounded-circle shadow-sm" onclick="editDinhMuc(@hangMuc.MaDinhMuc)">
                                                            <i class="fas fa-pencil-alt text-primary"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="main-card text-center py-5 shadow-sm border-0">
                        <div class="py-4 opacity-50">
                            <i class="fas fa-box-open fa-4x mb-3 text-muted"></i>
                            <h5 class="fw-bold">Không tìm thấy dữ liệu</h5>
                            <p class="text-muted">Vui lòng kiểm tra lại bộ lọc hoặc thêm định mức mới.</p>
                        </div>
                    </div>
                }
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                    <span class="small text-muted">Trang @ViewBag.CurrentPage / @ViewBag.TotalPages</span>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link shadow-none border-0 mx-1 rounded" href="@Url.Action("DanhSachDinhMuc", new { maLoaiXe = ViewBag.CurrentMaLoaiXe, page = i })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
        <div class="modal fade" id="detailModal" data-bs-backdrop="static">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Nhật ký hệ thống</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="modalBodyNhatKy">
                        @await Html.PartialAsync("_NhatKyPartial")
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade" id="ModalDinhMuc" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 20px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="modalTitle">Thêm định mức mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="formDinhMuc">
                        <input type="hidden" id="MaDinhMuc" name="MaDinhMuc" value="0">
                        <div class="mb-3">
                            <label class="filter-label">Loại xe</label>
                            <select class="form-select shadow-sm" id="MaLoaiXe" name="MaLoaiXe" required>
                                <option value="">-- Chọn loại xe --</option>
                                @if (ViewBag.DanhSachLoaiXe != null)
                                {
                                    foreach (var loai in ViewBag.DanhSachLoaiXe)
                                    {
                                        <option value="@loai.MaLoaiXe">@loai.TenLoai</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="filter-label">Tên hạng mục</label>
                            <input type="text" class="form-control shadow-sm" id="TenHangMuc" name="TenHangMuc" required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="filter-label">Định mức (Km)</label>
                                <input type="number" class="form-control shadow-sm" id="DinhMucKm" name="DinhMucKm" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="filter-label">Định mức (Tháng)</label>
                                <input type="number" class="form-control shadow-sm" id="DinhMucThang" name="DinhMucThang" required>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" onclick="saveDinhMuc()">Lưu dữ liệu</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const modalEl = new bootstrap.Modal(document.getElementById('ModalDinhMuc'));

        // Mở modal thêm mới
        $('#btnOpenAddModal').click(function() {
            $('#formDinhMuc')[0].reset();
            $('#MaDinhMuc').val(0);
            $('#modalTitle').text('Thêm định mức mới');
            modalEl.show();
        });

        // Mở modal sửa
        function editDinhMuc(id) {
            Swal.fire({ title: 'Đang tải...', didOpen: () => Swal.showLoading() });

            // Sửa $.get thành $.ajax để thêm được cấu hình credentials
            $.ajax({
                url: `https://localhost:7286/api/quanlydinhmuc/chi-tiet/${id}`,
                type: 'GET',
                xhrFields: {
                    withCredentials: true // Gửi kèm Cookie/Session cho GET
                },
                success: function(data) {
                    Swal.close();
                    $('#MaDinhMuc').val(data.maDinhMuc);
                    $('#MaLoaiXe').val(data.maLoaiXe);
                    $('#TenHangMuc').val(data.tenHangMuc);
                    $('#DinhMucKm').val(data.dinhMucKm);
                    $('#DinhMucThang').val(data.dinhMucThang);
                    $('#modalTitle').text('Chỉnh sửa định mức');
                    modalEl.show();
                },
                error: function() {
                    Swal.fire('Lỗi', 'Không thể lấy dữ liệu', 'error');
                }
            });
        }

        // Lưu dữ liệu
        function saveDinhMuc() {
            const id = parseInt($('#MaDinhMuc').val());
            const data = {
                MaDinhMuc: id,
                MaLoaiXe: parseInt($('#MaLoaiXe').val()),
                TenHangMuc: $('#TenHangMuc').val(),
                DinhMucKm: parseInt($('#DinhMucKm').val()),
                DinhMucThang: parseInt($('#DinhMucThang').val())
            };

            if (!data.MaLoaiXe || !data.TenHangMuc) {
                Swal.fire('Chú ý', 'Vui lòng điền đủ thông tin', 'warning');
                return;
            }

            const url = id === 0 ? 'https://localhost:7286/api/quanlydinhmuc/them-dinh-muc' : `https://localhost:7286/api/quanlydinhmuc/sua-dinh-muc/${id}`;
            const method = id === 0 ? 'POST' : 'PUT';

            $.ajax({
                url: url,
                type: method,
                contentType: 'application/json',
                data: JSON.stringify(data),
                // SỬA Ở ĐÂY: Sử dụng xhrFields thay vì credentials
                xhrFields: {
                    withCredentials: true
                },
                success: function(res) {
                    modalEl.hide();
                    Swal.fire('Thành công', res.message, 'success').then(() => location.reload());
                },
                error: function(xhr) {
                    // Nếu backend trả về 401 Unauthorized, báo lỗi đăng nhập
                    if (xhr.status === 401) {
                        Swal.fire('Lỗi', 'Phiên đăng nhập hết hạn!', 'error');
                    } else {
                        Swal.fire('Lỗi', xhr.responseText || 'Thao tác thất bại', 'error');
                    }
                }
            });
        }
    </script>
</body>
</html>