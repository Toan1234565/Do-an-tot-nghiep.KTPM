@model List<QuanLyTaiKhoanNguoiDung.Models12.QuanLyNhatKyHeThong.NhatKyHeThongModels>

<div class="table-responsive">
    <table class="table table-sm table-bordered hover align-middle" style="font-size: 0.85rem;">
        <thead class="table-dark">
            <tr>
                <th>Thời gian</th>
                <th>Thao tác</th>
                <th>Người thực hiện</th>
                <th>Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ThoiGianThucHien?.ToString("HH:mm dd/MM")</td>
                    <td><span class="badge bg-primary">@item.LoaiThaoTac</span></td>
                    <td>@item.NguoiThucHien</td>
                    <td>
                        <button class="btn btn-sm btn-link p-0 btn-show-json"
                                data-cu='@item.DuLieuCu' data-moi='@item.DuLieuMoi'>
                            Xem
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>