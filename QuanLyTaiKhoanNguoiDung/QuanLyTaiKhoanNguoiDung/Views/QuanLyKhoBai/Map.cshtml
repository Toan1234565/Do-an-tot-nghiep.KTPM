@using Newtonsoft.Json
@model List<QuanLyTaiKhoanNguoiDung.Models12.QuanLyDiaChi.DiaChiModel>

@{
    ViewData["Title"] = "Bản đồ hệ thống kho bãi";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    #map {
        height: 650px;
        width: 100%;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        border: 1px solid #ddd;
    }

    .map-wrapper {
        padding: 20px;
        background: #fdfdfd;
        border-radius: 20px;
    }

    /* Tùy chỉnh cửa sổ Popup khi click vào điểm cắm */
    .leaflet-popup-content-wrapper {
        border-radius: 10px;
        padding: 0;
        overflow: hidden;
    }

    .popup-card {
        width: 220px;
    }

    .popup-card-header {
        background: #d32f2f; /* Màu đỏ Highlands */
        color: white;
        padding: 10px;
        font-weight: bold;
        display: flex;
        align-items: center;
    }

    .popup-card-body {
        padding: 12px;
        font-size: 13.5px;
        line-height: 1.6;
    }
</style>

<div class="container-fluid map-wrapper mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0"><i class="fa-solid fa-map-location-dot text-danger me-2"></i>Mạng lưới Kho bãi</h2>
        <a asp-action="DanhSachKhoBai" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-list me-1"></i> Trở về danh sách
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div id="map"></div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // 1. Khởi tạo bản đồ (Tâm Việt Nam)
        var map = L.map('map').setView([16.047079, 108.206230], 6);

        // 2. SỬA TẠI ĐÂY: Dùng Google Maps thay cho OpenStreetMap
        L.tileLayer('https://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}', {
            maxZoom: 20,
            subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
            attribution: '&copy; Google Maps'
        }).addTo(map);

        // 3. Định nghĩa Icon màu đỏ
        var redIcon = L.icon({
            iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
            shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
            iconSize: [25, 41],
            iconAnchor: [12, 41],
            popupAnchor: [1, -34],
            shadowSize: [41, 41]
        });

        // 4. Vẽ Marker từ dữ liệu Database
        var locations = @Html.Raw(JsonConvert.SerializeObject(Model))
        console.log("Dữ liệu nhận được:", locations);
        if (locations && locations.length > 0) {
            locations.forEach(function (loc) {
                var lat = parseFloat(loc.ViDo);
                var lng = parseFloat(loc.KinhDo);

                if (!isNaN(lat) && !isNaN(lng)) {
                    var marker = L.marker([lat, lng], { icon: redIcon }).addTo(map);

                    var popupContent = `
                        <div class="popup-card">
                            <div class="popup-card-header">
                                <i class="fa-solid fa-warehouse me-2"></i> KHO: ${loc.ThanhPho || 'Chi nhánh'}
                            </div>
                            <div class="popup-card-body">
                                <b>Địa chỉ:</b> ${loc.Duong}, ${loc.Phuong}<br>
                                <b>Khu vực:</b> ${loc.ThanhPho}<br>
                                <hr class="my-2">
                                <a href="/QuanLyKhoBai/ChiTietKhoBaiByDiaChi?maDiaChi=${loc.MaDiaChi}"
                                   class="btn btn-danger btn-sm w-100 py-2" style="color:white; text-decoration:none;">
                                   Xem chi tiết
                                </a>
                            </div>
                        </div>
                    `;
                    marker.bindPopup(popupContent);
                }
            });
        }
    });
</script>