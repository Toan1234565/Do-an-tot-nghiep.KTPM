@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyKhoBai
@model IEnumerable<QuanLyTaiKhoanNguoiDung.Models12.QuanLyKhoBai.QuanLyKhobaiModels>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Lý Kho Bãi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="~/css/giaodiendanhsach.css" asp-append-version="true" />
    <style>
        

        /* Badges cải tiến */
        .status-badge {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            display: inline-block;
        }

        .st-active {
            background: #d1fae5;
            color: #065f46;
        }

        .st-full {
            background: #fee2e2;
            color: #991b1b;
        }

        .st-maintenance {
            background: #fef3c7;
            color: #92400e;
        }

        .btn-add-new {
            background: var(--primary-color);
            color: white;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
            border: none;
            box-shadow: 0 4px 14px rgba(67, 97, 238, 0.3);
        }

        #map {
            height: 450px;
            width: 100%;
            border-radius: 16px;
            margin-bottom: 20px;
            border: 1px solid #ddd;
            display: none; /* Mặc định ẩn, hiện khi bấm nút */
        }

        .map-popup-link {
            display: block;
            width: 100%;
            text-align: center;
            background: #4361ee;
            color: white !important;
            padding: 5px;
            border-radius: 4px;
            text-decoration: none;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <main class="container-fluid py-4">
        <div class="main-card">
            <div class="page-header d-flex justify-content-between align-items-center">
                <h1><i class="fa-solid fa-warehouse me-2 text-primary"></i>Hệ Thống Quản Lý Kho Bãi</h1>

                <div class="d-flex gap-2">
                    <button class="btn btn-add-new" data-bs-toggle="modal" data-bs-target="#ThemKhoBai">
                        <i class="fas fa-plus-circle me-2"></i>Thêm kho bãi mới
                    </button>
                    <button class="btn btn-outline-primary" onclick="toggleMap()" id="btnToggleMap">
                        <i class="fas fa-map-marked-alt me-2"></i>Xem bản đồ kho bãi
                    </button>

                    <div id="map"></div>
                    <div class="position-relative">
                        <button type="button"
                                class="btn btn-light position-relative p-0 d-flex align-items-center justify-content-center rounded-circle border shadow-sm btn-nhat-ky"
                                style="width: 42px; height: 42px; transition: all 0.3s;"
                                data-bs-toggle="modal"
                                data-bs-target="#detailModal"
                                data-service="Quản lý kho bãi"
                                title="Xem nhật ký hoạt động">
                            <i class="fa-solid fa-bell fs-5 text-primary"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            <form method="get" asp-action="DanhSachKhoBai" class="row g-3 mb-4 p-3 bg-light rounded-4 border mx-0">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control border-start-0" placeholder="Tìm tên hoặc mã kho..." value="@ViewBag.SearchTerm" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="loaikho" class="form-select" onchange="this.form.submit()">
                        <option value="Tất cả">-- Tất cả loại kho --</option>
                        @if (ViewBag.LoaiKhoList != null)
                        {
                            foreach (var item in (List<LoaiKhoModel>)ViewBag.LoaiKhoList)
                            {
                                <option value="@item.TenLoaiKho" selected="@(ViewBag.Loaikho == item.TenLoaiKho)">@item.TenLoaiKho</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="trangthai" class="form-select" onchange="this.form.submit()">
                        @{
                            var statusList = new List<string> { "Tất cả", "Hoạt động", "Ngừng hoạt động", "Bảo trì", "Đang đầy" };
                            foreach (var status in statusList)
                            {
                                <option value="@status" selected="@(ViewBag.Trangthai == status)">@status</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">Lọc dữ liệu</button>
                </div>
            </form>

            <div>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 5%">STT</th>
                            <th style="width: 20%">Thông tin kho bãi</th>
                            <th class="text-center">Số hàng trong kho</th>
                            <th class="text-center">Diện tích & Dung tích</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Liên hệ</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = ((ViewBag.CurrentPage - 1) * 20) + 1;
                            foreach (var item in Model)
                            {
                                <tr onclick="location.href='@Url.Action("ChiTietKhoBai", "QuanLyKhoBai", new { maKho = item.MaKho })'"
                                    style="cursor: pointer;"
                                    class="align-middle">
                                    <td class="text-center fw-bold text-muted">@stt</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3 text-primary">
                                                <i class="fas fa-warehouse fa-lg"></i>
                                            </div>
                                            <div>
                                                <span class="fw-bold text-dark text-decoration-none d-block">@item.TenKhoBai</span>
                                                <span class="badge bg-light text-muted border fw-normal">
                                                    <i class="fa-solid fa-tag me-1"></i>@(item.TenLoaiKho ?? "Chưa phân loại")
                                                </span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("ChiTietKhoBai", "QuanLyKhoBai", new { maKho = item.MaKho })" class="fw-bold text-dark text-decoration-none d-block">
                                            Chờ tạo API bên Đơn hàng rồi mới tính toán được số hàng trong kho.
                                        </a>
                                    
                                    </td>
                                    <td>
                                        <div class="fw-medium"><i class="fas fa-ruler-combined me-2 text-muted"></i>@item.DienTichM2 m²</div>
                                        <div class="small text-muted"><i class="fas fa-cube me-2 text-muted"></i>@item.DungTichM3 m³</div>
                                    </td>
                                    <td >
                                        @{
                                            var statusClass = item.TrangThai == "Hoạt động" ? "st-active" :
                                            (item.TrangThai == "Đang đầy" ? "st-full" : "st-maintenance");
                                        }
                                        <span class="status-badge @statusClass">
                                            <i class="fas fa-circle me-1" style="font-size: 0.5rem"></i> @item.TrangThai
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-secondary">@item.SoDienThoaiKho</div>
                                        <div class="small text-muted">ID: @item.MaKho</div>
                                    </td>
                                    <td class="text-center" onclick="event.stopPropagation();">
                                        <button type="button"
                                                onclick="openEditModal('@item.MaKho')"
                                                class="btn btn-sm btn-outline-primary border-0 shadow-sm"
                                                title="Chỉnh sửa thông tin">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="80" class="mb-3 opacity-25">
                                    <p class="text-muted">Không tìm thấy kho bãi nào phù hợp với bộ lọc.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <p class="text-muted small mb-0">Trang @ViewBag.CurrentPage trên tổng số @ViewBag.TotalPages</p>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link shadow-sm border-0 mx-1 rounded"
                                       href="@Url.Action("DanhSachKhoBai", new { searchTerm = ViewBag.SearchTerm, loaikho = ViewBag.Loaikho, trangthai = ViewBag.Trangthai, page = i })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
        <div class="modal fade" id="ThemKhoBai" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-light">
                        <h5 class="modal-title fw-bold"><i class="fas fa-warehouse me-2 text-primary"></i>Đăng Ký Kho Bãi Mới</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="formThemKhoBai">
                            <div class="row mb-3">
                                <div class="col-md-8">
                                    <label class="form-label fw-bold small">Tên kho bãi *</label>
                                    <input type="text" class="form-control" name="TenKhoBai" required placeholder="Ví dụ: Kho lạnh số 1">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Số điện thoại</label>
                                    <input type="text" class="form-control" name="SoDienThoaiKho">
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Loại kho *</label>
                                    <div class="input-group">
                                        <select class="form-select" name="MaLoaiKho" id="selectLoaiKho" required>
                                            <option value="">-- Chọn loại kho --</option>
                                            @if (ViewBag.LoaiKhoList != null)
                                            {
                                                foreach (var loai in (List<LoaiKhoModel>)ViewBag.LoaiKhoList)
                                                {
                                                    <option value="@loai.MaLoaiKho">@loai.TenLoaiKho</option>
                                                }
                                            }
                                        </select>
                                        <button class="btn btn-outline-primary" type="button" onclick="themMoiLoaiKho()"><i class="fas fa-plus"></i></button>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small">Tỉnh / Thành phố *</label>
                                        <select class="form-select" id="city" name="ThanhPho" required>
                                            <option value="" selected>Chọn Tỉnh Thành</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small">Quận / Huyện *</label>
                                        <select class="form-select" id="district" name="QuanHuyen" required>
                                            <option value="" selected>Chọn Quận Huyện</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small">Phường / Xã *</label>
                                        <select class="form-select" id="ward" name="Phuong" required>
                                            <option value="" selected>Chọn Phường Xã</option>
                                        </select>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-12">
                                            <label class="form-label fw-bold small">Số nhà / Tên đường *</label>
                                            <input type="text" class="form-control" name="Duong" required placeholder="VD: 123 Đường ABC">
                                        </div>
                                    </div>
                                </div>

                                <input type="hidden" name="ViDo" id="ViDo">
                                <input type="hidden" name="KinhDo" id="KinhDo">
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Diện tích (m²)</label>
                                    <input type="number" step="0.01" class="form-control" name="DienTichM2">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Dung tích (m³)</label>
                                    <input type="number" step="0.01" class="form-control" name="DungTichM3">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Sức chứa</label>
                                    <input type="number" step="0.1" class="form-control" name="SucChua">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Trạng thái</label>
                                    <select class="form-select" name="TrangThai">
                                        <option value="Hoạt động">Hoạt động</option>
                                        <option value="Ngừng hoạt động">Ngừng hoạt động</option>
                                        <option value="Bảo trì">Bảo trì</option>
                                        <option value="Đang đầy">Đang đầy</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Người quản lý kho *</label>
                                    <div class="form-group">
                                        <select id="selectNhanVien" name="MaQuanLy" class="form-control">
                                            <option value="">-- Chọn nhân viên --</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 pt-3 border-top text-end">
                                <button type="button" class="btn btn-light px-4 me-2" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-primary px-5 fw-bold">Xác nhận Lưu</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="SuaKhoBai" data-bs-backdrop="static">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-primary bg-opacity-10">
                        <h5 class="modal-title fw-bold text-primary"><i class="fas fa-edit me-2"></i>Cập Nhật Thông Tin Kho Bãi</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form id="formSuaKhoBai">
                            <input type="hidden" name="MaKho" id="edit_MaKho">
                            <input type="hidden" name="MaDiaChi" id="edit_MaDiaChi">
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold small">Người quản lý kho *</label>
                                    <select class="form-select" name="MaQuanLy" id="edit_MaQuanLy">
                                        <option value="">-- Chọn nhân viên --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-8">
                                    <label class="form-label fw-bold small">Tên kho bãi *</label>
                                    <input type="text" class="form-control" name="TenKhoBai" id="edit_TenKhoBai" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Số điện thoại</label>
                                    <input type="text" class="form-control" name="SoDienThoaiKho" id="edit_SoDienThoaiKho">
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Loại kho *</label>
                                    <select class="form-select" name="MaLoaiKho" id="edit_MaLoaiKho" required>
                                        <option value="">-- Chọn loại kho --</option>
                                        @foreach (var loai in (List<LoaiKhoModel>)ViewBag.LoaiKhoList)
                                        {
                                            <option value="@loai.MaLoaiKho">@loai.TenLoaiKho</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Trạng thái</label>
                                    <select class="form-select" name="TrangThai" id="edit_TrangThai">
                                        <option value="Hoạt động">Hoạt động</option>
                                        <option value="Ngừng hoạt động">Ngừng hoạt động</option>
                                        <option value="Bảo trì">Bảo trì</option>
                                        <option value="Đang đầy">Đang đầy</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Diện tích (m²)</label>
                                    <input type="number" step="0.01" class="form-control" name="DienTichM2" id="edit_DienTichM2">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Dung tích (m³)</label>
                                    <input type="number" step="0.01" class="form-control" name="DungTichM3" id="edit_DungTichM3">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Sức chứa</label>
                                    <input type="number" step="0.1" class="form-control" name="SucChua" id="edit_SucChua">
                                </div>
                            </div>

                            <div class="mt-4 pt-3 border-top text-end">
                                <button type="button" class="btn btn-light px-4 me-2" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-primary px-5 fw-bold">Cập nhật thay đổi</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Nhật ký hệ thống</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="modalBodyNhatKy">
                        @await Html.PartialAsync("_NhatKyPartial")
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const host = "https://provinces.open-api.vn/api/";

        // 1. Load Tỉnh/Thành
        var renderCity = () => {
            fetch(host + "?depth=1")
                .then(res => res.json())
                .then(data => {
                    data.forEach(item => {
                        document.querySelector("#city").innerHTML += `<option value="${item.name}" data-id="${item.code}">${item.name}</option>`;
                    });
                });
        }
        renderCity();

        // 2. Load Quận/Huyện khi chọn Tỉnh
        document.querySelector("#city").addEventListener("change", function() {
            let code = this.options[this.selectedIndex].getAttribute("data-id");
            if (code) {
                fetch(host + "p/" + code + "?depth=2")
                    .then(res => res.json())
                    .then(data => {
                        document.querySelector("#district").innerHTML = '<option value="">Chọn Quận Huyện</option>';
                        data.districts.forEach(item => {
                            document.querySelector("#district").innerHTML += `<option value="${item.name}" data-id="${item.code}">${item.name}</option>`;
                        });
                    });
            }
        });

        // 3. Load Phường/Xã VÀ Tự động lấy Tọa độ
        document.querySelector("#district").addEventListener("change", function() {
            let code = this.options[this.selectedIndex].getAttribute("data-id");
            if (code) {
                fetch(host + "d/" + code + "?depth=2")
                    .then(res => res.json())
                    .then(data => {
                        document.querySelector("#ward").innerHTML = '<option value="">Chọn Phường Xã</option>';
                        data.wards.forEach(item => {
                            document.querySelector("#ward").innerHTML += `<option value="${item.name}">${item.name}</option>`;
                        });
                    });
            }
        });

        // 4. Khi chọn xong Phường, gọi API để lấy Kinh độ/Vĩ độ
        document.querySelector("#ward").addEventListener("change", async function() {
            const city = document.querySelector("#city").value;
            const district = document.querySelector("#district").value;
            const ward = this.value;
            const duong = document.querySelector('[name="Duong"]').value;

            const fullAddress = `${duong}, ${ward}, ${district}, ${city}, Vietnam`;

            // Gọi API OpenStreetMap (Nominatim)
            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(fullAddress)}`);
                const data = await response.json();

                if (data && data.length > 0) {
                    document.querySelector("#ViDo").value = data[0].lat;
                    document.querySelector("#KinhDo").value = data[0].lon;
                    console.log("Tọa độ tìm thấy:", data[0].lat, data[0].lon);
                }
            } catch (error) {
                console.error("Lỗi lấy tọa độ:", error);
            }
        });
    </script>
   <script>
         /**
         * 1. TẢI DANH SÁCH NHÂN VIÊN KHO (Dùng chung cho cả Thêm và Sửa)
         */
         async function loadNhanVienKho() {
            const selectAdd = document.getElementById('selectNhanVien');
            const selectEdit = document.getElementById('edit_MaQuanLy');

            // Nếu cả hai đều đã có dữ liệu (số lượng option > 1) thì không cần load lại
            if (selectEdit && selectEdit.options.length > 1) return;

            const apiUrl = 'https://localhost:7022/api/quanlynguoidung/danhsachnhanvienkho';

            try {
                const response = await fetch(apiUrl, { credentials: 'include' });
                if (!response.ok) throw new Error('Không thể tải nhân viên');

                const data = await response.json();
                const optionsHtml = data.map(nv =>
                    `<option value="${nv.maNguoiDung}">${nv.hoTenNhanVien} (${nv.tenChucVu})</option>`
                ).join('');

                const defaultOption = '<option value="">-- Chọn nhân viên --</option>';

                if (selectAdd) selectAdd.innerHTML = defaultOption + optionsHtml;
                if (selectEdit) selectEdit.innerHTML = defaultOption + optionsHtml;

                console.log("Đã tải xong danh sách nhân viên vào Select");
            } catch (error) {
                console.error('Lỗi loadNhanVienKho:', error);
            }
        }
       

        /**
         * 2. XỬ LÝ THÊM MỚI KHO BÃI (GỒM 2 BƯỚC: ĐỊA CHỈ -> KHO BÃI)
         */
        document.addEventListener("DOMContentLoaded", function () {
            loadNhanVienKho(); // Gọi tải nhân viên khi trang sẵn sàng

            const form = document.getElementById('formThemKhoBai');
            if (!form) return;

            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                Swal.fire({
                    title: 'Đang xử lý dữ liệu...',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                try {
                    // --- BƯỚC 1: LƯU ĐỊA CHỈ (PORT 7149) ---
                    const addressPayload = {
                        Duong: form.querySelector('[name="Duong"]').value,
                        Phuong: form.querySelector('[name="Phuong"]').value,
                        ThanhPho: form.querySelector('[name="ThanhPho"]').value,
                        MaBuuDien: "70000",
                        ViDo: parseFloat(document.getElementById('ViDo').value) || 0,
                        KinhDo: parseFloat(document.getElementById('KinhDo').value) || 0
                    };

                    const addressResponse = await fetch('https://localhost:7149/api/quanlydiachi/themdiachi', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify(addressPayload)
                    });

                    if (!addressResponse.ok) throw new Error("Lỗi khi lưu địa chỉ.");
                    const addressResult = await addressResponse.json();

                    // --- BƯỚC 2: LƯU KHO BÃI (PORT 7286) ---
                    const warehousePayload = {
                        TenKhoBai: form.querySelector('[name="TenKhoBai"]').value,
                        SoDienThoaiKho: form.querySelector('[name="SoDienThoaiKho"]').value,
                        MaLoaiKho: parseInt(form.querySelector('[name="MaLoaiKho"]').value),
                        MaDiaChi: addressResult.maDiaChi,
                        DienTichM2: parseFloat(form.querySelector('[name="DienTichM2"]').value) || 0,
                        DungTichM3: parseFloat(form.querySelector('[name="DungTichM3"]').value) || 0,
                        SucChua: parseFloat(form.querySelector('[name="SucChua"]').value) || 0,
                        TrangThai: form.querySelector('[name="TrangThai"]').value,
                        MaQuanLy: form.querySelector('[name="MaQuanLy"]')?.value ? parseInt(form.querySelector('[name="MaQuanLy"]').value) : null
                    };

                    const warehouseResponse = await fetch('https://localhost:7286/api/quanlykhobai/themkhomoi', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify(warehousePayload)
                    });

                    if (!warehouseResponse.ok) throw new Error("Lỗi khi lưu kho bãi.");

                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: 'Dữ liệu đã được đồng bộ hóa.',
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => location.reload());

                } catch (error) {
                    Swal.fire({ icon: 'error', title: 'Thất bại', text: error.message });
                }
            });
        });

        /**
         * 3. THÊM MỚI LOẠI KHO (SỬ DỤNG JQUERY AJAX)
         */
        function themMoiLoaiKho() {
            Swal.fire({
                title: 'Thêm loại kho mới',
                html: `
                    <div class="text-start">
                        <label class="form-label small fw-bold">Tên loại kho *</label>
                        <input id="swal-input1" class="swal2-input m-0 w-100">
                        <label class="form-label small fw-bold mt-3">Ghi chú</label>
                        <textarea id="swal-input2" class="swal2-textarea m-0 w-100"></textarea>
                    </div>`,
                showCancelButton: true,
                preConfirm: () => {
                    const ten = document.getElementById('swal-input1').value;
                    if (!ten) return Swal.showValidationMessage('Vui lòng nhập tên loại kho!');
                    return { TenLoaiKho: ten, GhiChu: document.getElementById('swal-input2').value };
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Đang lưu...', didOpen: () => Swal.showLoading() });

                    $.ajax({
                        url: 'https://localhost:7286/api/quanlykhobai/themloaikhomoi',
                        type: 'POST',
                        contentType: 'application/json',
                        xhrFields: { withCredentials: true }, // QUAN TRỌNG: Tương đương credentials: 'include' trong fetch
                        data: JSON.stringify(result.value),
                        success: function () {
                            Swal.fire('Thành công!', '', 'success').then(() => location.reload());
                        },
                        error: function () {
                            Swal.fire('Lỗi!', 'Không thể kết nối server.', 'error');
                        }
                    });
                }
            });
        }

            /**
         * 3. MỞ MODAL CHỈNH SỬA
         */
        async function openEditModal(maKho) {
            Swal.fire({ title: 'Đang tải...', didOpen: () => Swal.showLoading() });

            try {
                // BƯỚC 1: Đợi tải xong danh sách nhân viên
                await loadNhanVienKho();

                // BƯỚC 2: Lấy chi tiết kho
                const response = await fetch(`https://localhost:7286/api/quanlykhobai/chitietkhobai/${maKho}`, {
                    credentials: 'include'
                });
                const data = await response.json();

                // BƯỚC 3: Map dữ liệu vào các ô input
                document.getElementById('edit_MaKho').value = data.maKho;
                document.getElementById('edit_MaDiaChi').value = data.maDiaChi;
                document.getElementById('edit_TenKhoBai').value = data.tenKhoBai;
                document.getElementById('edit_SoDienThoaiKho').value = data.soDienThoaiKho;
                document.getElementById('edit_MaLoaiKho').value = data.maLoaiKho;
                document.getElementById('edit_TrangThai').value = data.trangThai;
                document.getElementById('edit_DienTichM2').value = data.dienTichM2;
                document.getElementById('edit_DungTichM3').value = data.dungTichM3;
                document.getElementById('edit_SucChua').value = data.sucChua;
                document.getElementById('edit_MaQuanLy').value = data.maQuanLy;

                const selectLoaiKho = document.getElementById('edit_MaLoaiKho');
                selectLoaiKho.value = data.maLoaiKho;
                // BƯỚC 4: Gán người quản lý (Chuyển ID về String để Select nhận diện đúng)
                const selectEdit = document.getElementById('edit_MaQuanLy');
                if (selectEdit && data.maQuanLy) {
                    selectEdit.value = data.maQuanLy.toString();
                } else {
                    selectEdit.value = "";
                }

                Swal.close();
                new bootstrap.Modal(document.getElementById('SuaKhoBai')).show();
            } catch (error) {
                Swal.fire("Lỗi!", "Không thể load dữ liệu: " + error.message, "error");
            }
        }

        /**
         * 4. XỬ LÝ SUBMIT CẬP NHẬT (PUT)
         */
        document.getElementById('formSuaKhoBai')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const maKho = document.getElementById('edit_MaKho').value;

            // Tạo payload bao gồm MaQuanLy
            const payload = {
                MaKho: parseInt(maKho),
                TenKhoBai: this.querySelector('[name="TenKhoBai"]').value,
                SoDienThoaiKho: this.querySelector('[name="SoDienThoaiKho"]').value,
                MaLoaiKho: parseInt(this.querySelector('[name="MaLoaiKho"]').value),
                DienTichM2: parseFloat(this.querySelector('[name="DienTichM2"]').value) || 0,
                DungTichM3: parseFloat(this.querySelector('[name="DungTichM3"]').value) || 0,
                SucChua: parseFloat(this.querySelector('[name="SucChua"]').value) || 0,
                TrangThai: this.querySelector('[name="TrangThai"]').value,
                MaDiaChi: parseInt(document.getElementById('edit_MaDiaChi').value),
                // Thêm MaQuanLy vào đây
                MaQuanLy: document.getElementById('edit_MaQuanLy').value ? parseInt(document.getElementById('edit_MaQuanLy').value) : null
            };

            try {
                const response = await fetch(`https://localhost:7286/api/quanlykhobai/cap-nhat-kho/${maKho}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    Swal.fire('Thành công', 'Dữ liệu đã cập nhật', 'success').then(() => location.reload());
                } else {
                    const err = await response.json();
                    throw new Error(err.message || "Lỗi cập nhật");
                }
            } catch (error) {
                Swal.fire("Thất bại", error.message, "error");
            }
        });
   </script>
</body>
</html>