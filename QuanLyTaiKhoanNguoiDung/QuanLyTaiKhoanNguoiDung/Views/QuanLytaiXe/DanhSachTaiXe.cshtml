@using QuanLyTaiKhoanNguoiDung.Models
@using QuanLyTaiKhoanNguoiDung.Models12
@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyNguoiDung
@using QuanLyTaiKhoanNguoiDung.Models12.QuanLyNguoiDung.QuanLyTaiXe
@model IEnumerable<QuanLyTaiXeModels>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Lý Tài Xế</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"> 
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"> 
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="~/css/giaodiendanhsach.css" asp-append-version="true" />
    <style>
        
        .status-badge {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .bg-active {
            background: #d1fae5;
            color: #065f46;
        }

        .bg-busy {
            background: #fef3c7;
            color: #92400e;
        }

        .bg-locked {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-action {
            background-color: #f8fafc;
            color: var(--primary-color);
            border: 1px solid var(--primary-color);
            transition: all 0.3s ease;
        }

            .btn-action:hover {
                background-color: var(--primary-color);
                color: white;
            }

        .score-box {
            font-weight: 700;
            color: var(--primary-color);
            background: #eef2ff;
            padding: 4px 8px;
            border-radius: 6px;
        }
        .btn-nhat-ky:hover {
            background-color: #e9ecef !important;
            transform: scale(1.1);
        }

        .btn-nhat-ky:hover i {
            animation: ring 0.5s ease;
        }

       
    </style>
</head>
<body>
    <main class="container-fluid py-4">
       <div class="main-card">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <div class="page-header d-flex justify-content-between align-items-center mb-4">
                <h1 class="h4 fw-bold m-0 text-dark">
                    <i class="fa-solid fa-id-card me-2 text-primary"></i>Quản Lý Hồ Sơ Tài Xế
                </h1>
    
                <div class="d-flex gap-3 align-items-center">
                    <a href="@Url.Action("DanhSachTaiXe")" class="btn btn-light btn-sm border rounded-pill px-3 shadow-sm">
                        <i class="fa-solid fa-arrows-rotate me-1 text-muted"></i> Làm mới
                    </a>

                    <div class="position-relative">
                        <button type="button" 
                                class="btn btn-link text-dark position-relative p-2 bg-light rounded-circle border shadow-sm btn-nhat-ky" 
                                style="width: 40px; height: 40px; transition: all 0.3s;"
                                data-bs-toggle="modal" 
                                data-bs-target="#detailModal" 
                                data-service="Quản lý nhân viên"
                                title="Xem nhật ký hoạt động">
                            <i class="fa-solid fa-bell fs-5 text-primary"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            @* Form Filter *@
            <form id="filterForm" method="get" action="@Url.Action("DanhSachTaiXe")" class="bg-white border rounded-4 p-4 mb-4 shadow-sm">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label small fw-bold text-secondary"><i class="fas fa-search me-1"></i> Tìm kiếm</label>
                        <input type="text" name="search" class="form-control bg-light auto-submit" placeholder="Tên, SĐT, Bằng lái..." value="@ViewBag.CurrentSearch" />
                    </div>

                   <div class="col-lg-2 col-md-6">
                        <label class="form-label small fw-bold text-secondary">
                            <i class="fas fa-warehouse me-1"></i> Kho bãi
                        </label>
                        <select name="maKho" id="selectFilterKho" class="form-select bg-light auto-submit">
                            <option value="">-- Tất cả kho --</option>
                        </select>
                    </div>
                   <div class="col-lg-2 col-md-6">
                        <label class="form-label small fw-bold text-secondary">
                            <i class="fas fa-toggle-on me-1"></i> Trạng thái
                        </label>
                        <select name="trangthai" class="form-select bg-light auto-submit">
                            <option value="true" selected="@(ViewBag.CurrentTrangThai == true)">Đang hoạt động</option>
                            <option value="false" selected="@(ViewBag.CurrentTrangThai == false)">Đã vô hiệu hóa</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-6">
                         <label class="form-label small fw-bold text-secondary">
                             <i class="fas fa-toggle-on me-1"></i> Trạng thái hoạt động
                         </label>
                         <select name="trangthaihoatdong" class="form-select bg-light auto-submit" 
                                 @(ViewBag.CurrentTrangThai == false ? "disabled" : "")>
                             <option value="" selected="@(string.IsNullOrEmpty(ViewBag.CurrentTrangThaiHoatDong))">Tất cả</option>
                             <option value="Đang hoạt động" selected="@(ViewBag.CurrentTrangThaiHoatDong == "Đang hoạt động")">Đang hoạt động</option>
                             <option value="Sẵn sàng" selected="@(ViewBag.CurrentTrangThaiHoatDong == "Sẵn sàng")">Sẵn sàng</option>                           
                             <option value="Bị khóa" selected="@(ViewBag.CurrentTrangThaiHoatDong == "Bị khóa")">Bị khóa</option>
                         </select>
                    </div>
                    <div class="col-lg-2 col-md-4">
                        <label class="form-label small fw-bold text-secondary"><i class="fas fa-shuttle-van me-1"></i> Loại bằng</label>
                        <select name="loaiBang" class="form-select bg-light auto-submit">
                            <option value="">Tất cả</option>
                            @foreach (var b in new[] { "B1", "B2", "C", "D", "E", "FC" })
                            {
                                <option value="@b" selected='@(ViewBag.CurrentLoaiBang == b)'>Bằng @b</option>
                            }
                        </select>
                    </div>

                    <div class="col-lg-3 col-md-4">
                        <label class="form-label small fw-bold text-secondary"><i class="fas fa-sort me-1"></i> Sắp xếp</label>
                        <div class="input-group">
                            <select name="sortBy" class="form-select bg-light auto-submit">
                                <option value="MaNguoiDung" selected='@(ViewBag.CurrentSortBy == "MaNguoiDung")'>Mặc định</option>
                                <option value="kinhnghiem" selected='@(ViewBag.CurrentSortBy == "kinhnghiem")'>Kinh nghiệm</option>
                                <option value="diemuytin" selected='@(ViewBag.CurrentSortBy == "diemuytin")'>Điểm uy tín</option>
                            </select>
                            <select name="isDescending" class="form-select bg-light auto-submit" style="max-width: 100px;">
                                <option value="true" selected='@(ViewBag.IsDescending == true)'>Giảm</option>
                                <option value="false" selected='@(ViewBag.IsDescending == false)'>Tăng</option>
                            </select>
                        </div>
                    </div>

                </div>
            </form>

            <div >
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Tài xế</th>
                            <th>Số bằng lái</th>
                            <th>Loại bằng</th>
                            <th>Kinh nghiệm</th>
                            <th>Điểm uy tín</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr onclick="location.href='@Url.Action("ChiTietTaiXe", "QuanLyTaiXe", new { id = item.MaNguoiDung })'">
                                    <td>
                                        <div class="fw-bold text-dark">@(item.HoTenTaiXe ?? "N/A")</div>
                                        <div class="small text-muted">Mã: #@item.MaNguoiDung</div>
                                    </td>
                                    <td><span class="font-monospace">@(item.SoBangLai ?? "---")</span></td>
                                    <td><span class="badge bg-secondary">@(item.LoaiBangLai ?? "N/A")</span></td>
                                    <td>@item.KinhNghiemNam năm</td>
                                    <td><span class="score-box">@item.DiemUyTin</span></td>
                                    <td>
                                        @{
                                            var statusClass = item.TrangThaiHoatDong switch {
                                                "Đang hoạt động" => "bg-active",
                                                "Đang chuyến" => "bg-busy",
                                                "Bị khóa" => "bg-locked",
                                                _ => "bg-light text-muted"
                                            };
                                        }
                                        <span class="status-badge @statusClass">@(item.TrangThaiHoatDong ?? "N/A")</span>
                                    </td>
                                    <td>
                                        @if (item.TrangThai == true) // Giả định true là đang hoạt động
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-sm"
                                                        onclick="event.stopPropagation(); vôHiệuHóa('@item.MaNguoiDung')">
                                                    <i class="fas fa-ban"></i> Vô hiệu hóa
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-success btn-sm"
                                                        onclick="event.stopPropagation(); kichHoat('@item.MaNguoiDung')">
                                                    <i class="fas fa-check"></i> Kích hoạt
                                                </button>
                                            }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted">Không tìm thấy hồ sơ nào.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Phân trang *@
            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("DanhSachTaiXe", new { 
                                    search = ViewBag.CurrentSearch, 
                                    loaiBang = ViewBag.CurrentLoaiBang, 
                                    maKho = ViewBag.CurrentMaKho,
                                    sortBy = ViewBag.CurrentSortBy, 
                                    isDescending = ViewBag.IsDescending, 
                                    page = i 
                                })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
        <div class="modal fade" id="expiryModal" tabindex="-1" aria-labelledby="expiryModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" style="border-radius: 16px; border: none; overflow: hidden;">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="expiryModalLabel">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> Danh Sách Bằng Lái Sắp Hết Hạn
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Tài xế</th>
                                        <th>Số bằng lái</th>
                                        <th>Ngày hết hạn</th>
                                        <th class="text-center">Còn lại</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="expiryTableBody">
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="modal-footer d-flex justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <label class="small fw-bold text-muted">Số ngày:</label>
                            <input type="number" id="exportDays" class="form-control form-control-sm" value="30" style="width: 70px;">
                        </div>
                        <div>
                            <button onclick="downloadReport()" class="btn btn-action btn-sm rounded-pill px-3 fw-medium">
                                <i class="fa-solid fa-file-export me-1"></i> Xuất báo cáo Excel
                            </button>
                            <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nhật ký hệ thống</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="modalBodyNhatKy">
                    @await Html.PartialAsync("_NhatKyPartial")
                </div>
            </div>
        </div>
    </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
     <script src="~/js/quanlytaikhoan/kichhoat-vohieuhoa.js"></script>
    <script>
       $(document).ready(function() {
            // Hàm kiểm tra và xử lý trạng thái dropdown
            function toggleTrangThaiHoatDong() {
                var trangThaiTaiKhoan = $('select[name="trangthai"]').val();
                var $selectHoatDong = $('select[name="trangthaihoatdong"]');

                if (trangThaiTaiKhoan === "false") {
                    // Nếu chọn Vô hiệu hóa: reset giá trị về "" và disable dropdown
                    $selectHoatDong.val("").prop('disabled', true);
                    // Thêm class để người dùng thấy rõ là bị khóa (tùy chọn)
                    $selectHoatDong.addClass('bg-secondary-subtle');
                } else {
                    // Nếu chọn Đang hoạt động: cho phép chọn lại
                    $selectHoatDong.prop('disabled', false);
                    $selectHoatDong.removeClass('bg-secondary-subtle');
                }
            }

            // Chạy ngay khi trang load để giữ đúng trạng thái sau khi Submit form
            toggleTrangThaiHoatDong();

            // Chạy khi người dùng thay đổi lựa chọn
            $('select[name="trangthai"]').on('change', function() {
                toggleTrangThaiHoatDong();
        
                // Nếu form của bạn có class auto-submit để tự load lại trang:
                if ($(this).hasClass('auto-submit')) {
                    $(this).closest('form').submit();
                }
            });
        });
        document.addEventListener("DOMContentLoaded", function () {
            const filterForm = document.getElementById('filterForm');
            const autoSubmitElements = document.querySelectorAll('.auto-submit');

            // Tự động submit form khi thay đổi filter
            autoSubmitElements.forEach(item => {
                if (item.tagName === 'SELECT') {
                    item.addEventListener('change', () => filterForm.submit());
                }

                if (item.type === 'text') {
                    let timeout = null;
                    item.addEventListener('input', () => {
                        clearTimeout(timeout);
                        timeout = setTimeout(() => filterForm.submit(), 800);
                    });
                }
            });

            // Kiểm tra cảnh báo hết hạn ngay khi load trang
            checkLicenseExpiry();
        });

        // Hàm gọi API kiểm tra hết hạn bằng lái
        async function checkLicenseExpiry() {
            try {
                const response = await fetch('https://localhost:7022/api/quanlytaixe/canh-bao-het-han?days=30');
                if (!response.ok) throw new Error('Network response was not ok');

                const result = await response.json();
                const badge = document.getElementById('expiryCount');

                if (result.totalWarnings > 0) {
                    badge.innerText = result.totalWarnings;
                    badge.style.display = 'block';
                    window.expiryData = result.data; // Lưu dữ liệu vào biến global
                } else {
                    badge.style.display = 'none';
                    window.expiryData = [];
                }
            } catch (error) {
                console.error("Không thể tải dữ liệu cảnh báo:", error);
            }
        }

        // Hàm hiển thị danh sách cảnh báo lên Modal
        function showExpiryAlerts() {
            const tableBody = document.getElementById('expiryTableBody');

            if (!window.expiryData || window.expiryData.length === 0) {
                alert('Hiện tại không có tài xế nào sắp hết hạn bằng lái.');
                return;
            }

            // Render danh sách vào bảng
            const rowsHtml = window.expiryData.map(item => {
                const dayClass = item.soNgayConLai <= 7 ? 'bg-danger' : 'bg-warning';

                return `
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">${item.hoTenTaiXe}</div>
                            <div class="small text-muted">${item.soDienThoai || 'Chưa cập nhật'}</div>
                        </td>
                        <td><code class="text-primary">${item.soBangLai}</code></td>
                        <td><span class="text-danger fw-medium">${item.ngayHetHan}</span></td>
                        <td class="text-center">
                            <span class="badge ${dayClass} rounded-pill">
                                ${item.soNgayConLai} ngày
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/QuanLyTaiXe/ChiTietTaiXe/${item.maNguoiDung}" class="btn btn-sm btn-outline-primary rounded-circle" title="Xem chi tiết">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <button onclick="guiYeuCauCapLai(${item.maNguoiDung}, '${item.hoTenTaiXe}')"
                                        class="btn btn-sm btn-outline-danger rounded-circle" title="Gửi yêu cầu cấp lại">
                                    <i class="fa-solid fa-paper-plane"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');

            tableBody.innerHTML = rowsHtml;

            // Khởi tạo và hiển thị Bootstrap Modal
            const expiryModal = new bootstrap.Modal(document.getElementById('expiryModal'));
            expiryModal.show();
        }

        // Hàm gửi API yêu cầu cấp lại
        async function guiYeuCauCapLai(maNguoiDung, tenTaiXe) {
            if (!confirm(`Bạn có chắc muốn gửi yêu cầu cấp lại giấy phép cho tài xế ${tenTaiXe}?`)) return;

            try {
                const url = `https://localhost:7022/api/QuanLyTaiXe/GuiThongBaoCapLai?id=${maNguoiDung}`;

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                // Đọc dữ liệu dưới dạng text trước để tránh lỗi parse JSON nếu phản hồi trống
                const responseText = await response.text();
                let result = {};

                try {
                    result = responseText ? JSON.parse(responseText) : {};
                } catch (e) {
                    console.error("Phản hồi không phải JSON:", responseText);
                }

                if (response.ok) {
                    alert(result.message || `Đã gửi thông báo thành công tới tài xế ${tenTaiXe}!`);
                } else {
                    // Xử lý các lỗi 400, 404, 500 từ server trả về
                    alert(`Lỗi: ${result.message || 'Hệ thống không tìm thấy đường dẫn API (404) hoặc lỗi Server.'}`);
                }

            } catch (error) {
                console.error("Lỗi kết nối:", error);
                alert('Không thể kết nối tới máy chủ. Vui lòng kiểm tra lại kết nối mạng hoặc cổng API (7022).');
            }
        }
        function downloadReport() {
            const daysInput = document.getElementById('exportDays');
            const days = daysInput ? daysInput.value : 30;

            Swal.fire({
                title: 'Xác nhận xuất báo cáo',
                text: `Hệ thống sẽ tạo file Excel danh sách bằng lái sắp hết hạn trong ${days} ngày tới.`,
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#4361ee',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="fa-solid fa-download me-2"></i>Tải về ngay',
                cancelButtonText: 'Hủy'
                // Đã xóa dòng border: 'none' gây lỗi
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Đang khởi tạo file...',
                        text: 'Vui lòng chờ trong giây lát',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    const url = `https://localhost:7022/api/quanlytaixe/xuat-bao-cao-het-han?days=${days}`;

                    fetch(url)
                        .then(response => {
                            if (response.ok) return response.blob();
                            // Nếu lỗi 500, ném lỗi để xuống catch xử lý
                            return response.text().then(text => { throw new Error(text || 'Lỗi server (500)') });
                        })
                        .then(blob => {
                            const urlBlob = window.URL.createObjectURL(blob);
                            const a = document.createElement('a');
                            a.href = urlBlob;
                            a.download = `BaoCao_HetHanBangLai_${days}Ngay.xlsx`;
                            document.body.appendChild(a);
                            a.click();
                            document.body.removeChild(a); // Xóa element sau khi click
                            window.URL.revokeObjectURL(urlBlob);
                            Swal.close();
                        })
                        .catch(error => {
                            console.error("Export Error:", error);
                            Swal.fire('Thất bại!', 'Không thể xuất file. Vui lòng kiểm tra lại Server API.', 'error');
                        });
                }
            });
        }
        // --- HÀM LOAD ĐƠN VỊ ---
       document.addEventListener("DOMContentLoaded", function () {
            // 1. Load danh sách kho từ API
            loadDanhSachKho();

            // 2. Logic Auto Submit Form
            const filterForm = document.getElementById('filterForm');
            document.querySelectorAll('.auto-submit').forEach(item => {
                item.addEventListener('change', () => filterForm.submit());
            });
        });

        async function loadDanhSachKho() {
            const selectFilter = document.getElementById('selectFilterKho');
            // Lấy mã kho hiện tại từ URL để set 'selected' sau khi load xong
            const urlParams = new URLSearchParams(window.location.search);
            const currentMaKho = urlParams.get('maKho');

            try {
                const response = await fetch('https://localhost:7286/api/quanlykhobai/gettenkhobai');
                if (!response.ok) throw new Error('Không thể kết nối API Kho');
        
                const data = await response.json();

                data.forEach(item => {
                    // Xác định ID (linh hoạt theo tên trường API trả về)
                    const valueId = item.maKhoBai || item.maKho || item.id;
                    const textTen = item.tenKhoBai || item.tenKho;

                    const option = new Option(textTen, valueId);
            
                    // Nếu ID trùng với maKho trên URL thì đánh dấu selected
                    if (currentMaKho && String(valueId) === String(currentMaKho)) {
                        option.selected = true;
                    }
            
                    selectFilter.add(option);
                });
            } catch (e) {
                console.error("Lỗi load đơn vị kho:", e);
                // Hiển thị một tùy chọn lỗi nếu cần
                const optError = new Option("Lỗi tải danh sách kho", "");
                optError.disabled = true;
                selectFilter.add(optError);
            }
        }
    </script>
</body>
</html>