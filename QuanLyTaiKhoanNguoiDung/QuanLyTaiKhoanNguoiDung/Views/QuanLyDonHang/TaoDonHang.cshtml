<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logistics System 2026 | Tạo Đơn Hàng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #2563eb;
            --primary-light: #eff6ff;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --bg: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--bg);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            color: var(--text-main);
        }

        /* Cấu trúc Card hiện đại */
        .card-custom {
            border: 1px solid var(--border-color);
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            margin-bottom: 1.5rem;
            background: #fff;
            overflow: hidden;
        }

        .card-header {
            background: #fff;
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem;
            font-weight: 700;
            color: var(--text-main);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
        }

        /* Lựa chọn dịch vụ (Dạng list đơn giản) */
        .service-option {
            cursor: pointer;
            border: 2px solid var(--border-color);
            transition: all 0.2s ease;
            border-radius: 12px;
            padding: 16px;
            background: #fff;
            position: relative;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .service-option:hover {
                border-color: var(--primary);
                background: var(--primary-light);
            }

            .service-option.selected {
                border-color: var(--primary);
                background: var(--primary-light);
                box-shadow: 0 0 0 1px var(--primary);
            }

        /* Kiện hàng */
        .package-item {
            background: #ffffff;
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            margin-bottom: 1rem;
            position: relative;
            transition: all 0.2s;
        }

            .package-item:hover {
                border-color: var(--primary);
                box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.1);
            }

        /* Input & Form */
        .form-label {
            margin-bottom: 0.5rem;
            color: var(--text-muted);
        }

        .form-control, .form-select {
            border-radius: 10px;
            padding: 0.625rem 1rem;
            border: 1.5px solid var(--border-color);
            background-color: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .form-control:focus, .form-select:focus {
                box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
                border-color: var(--primary);
                outline: none;
            }

        /* Badge số lượng / hệ số */
        .badge-custom {
            padding: 0.4em 0.8em;
            border-radius: 8px;
            font-weight: 600;
        }

        /* Màn hình Loading */
        #loading {
            position: fixed;
            inset: 0;
            background: rgba(255, 255, 255, 0.8);
            z-index: 9999;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
        }

        /* Thanh Summary dính bên phải */
        .sticky-summary {
            top: 1.5rem;
        }

        /* Hiệu ứng Button chính */
        .btn-primary {
            background-color: var(--primary);
            border: none;
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            transition: transform 0.1s, background-color 0.2s;
        }

            .btn-primary:active {
                transform: scale(0.98);
            }

        
    </style>
</head>
<body>

    <div id="loading">
        <div class="spinner-grow text-primary" role="status"></div>
        <span class="mt-3 fw-bold text-dark">Hệ thống đang xử lý...</span>
    </div>

    <nav class="navbar navbar-dark bg-primary shadow-sm mb-4">
        <div class="container">
            <span class="navbar-brand fw-bold">
                <i class="bi bi-truck-flatbed me-2"></i>LOGISTICS PRO <span class="badge bg-white text-primary ms-2">v2026</span>
            </span>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="row">
            <div class="col-lg-8">
                <div class="card card-custom">
                    <div class="card-header"><i class="bi bi-people-fill me-2"></i>Thông tin vận chuyển</div>
                    <div class="card-body">
                        <div class="row g-4">
                            <div class="col-md-6 border-end-md">
                                <label class="form-label fw-bold small text-primary">BÊN GỬI</label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input type="tel" class="form-control" id="soDienThoai" placeholder="SĐT người gửi" onchange="checkKhachHang()">
                                </div>
                                <input type="text" class="form-control" id="tenKhachHang" placeholder="Họ tên người gửi">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-success">BÊN NHẬN</label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input type="tel" class="form-control" id="sdtNguoiNhan" placeholder="SĐT người nhận">
                                </div>
                                <div class="input-group mb-2">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input type="text" class="form-control" id="tenNguoiNhan" placeholder="Họ tên người nhận">
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card card-custom h-100">
                            <div class="card-header text-primary"><i class="bi bi-geo-alt-fill me-2"></i>Điểm lấy hàng</div>
                            <div class="card-body">
                                <select class="form-select mb-2" id="lay_thanhPho" onchange="fetchDistricts('lay')">
                                    <option value="">Chọn Tỉnh/Thành phố</option>
                                </select>
                                <select class="form-select mb-2" id="lay_quanHuyen" onchange="fetchWards('lay')">
                                    <option value="">Chọn Quận/Huyện</option>
                                </select>
                                <select class="form-select mb-2" id="lay_phuongXa" onchange="autoCalculate()">
                                    <option value="">Chọn Phường/Xã</option>
                                </select>
                                <input type="text" class="form-control" id="lay_duong" placeholder="Số nhà, tên đường...">
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card card-custom h-100">
                            <div class="card-header text-success"><i class="bi bi-geo-fill me-2"></i>Điểm giao hàng</div>
                            <div class="card-body">
                                <select class="form-select mb-2" id="giao_thanhPho" onchange="fetchDistricts('giao')">
                                    <option value="">Chọn Tỉnh/Thành phố</option>
                                </select>
                                <select class="form-select mb-2" id="giao_quanHuyen" onchange="fetchWards('giao')">
                                    <option value="">Chọn Quận/Huyện</option>
                                </select>
                                <select class="form-select mb-2" id="giao_phuongXa" onchange="autoCalculate()">
                                    <option value="">Chọn Phường/Xã</option>
                                </select>
                                <input type="text" class="form-control" id="giao_duong" placeholder="Số nhà, tên đường...">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-custom mt-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-box-seam me-2"></i>Chi tiết hàng hóa</span>
                        <button class="btn btn-sm btn-outline-primary" onclick="addPackage()">
                            <i class="bi bi-plus-lg"></i> Thêm kiện
                        </button>
                    </div>
                    <div class="card-body bg-light-subtle" id="packageList">
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card card-custom sticky-summary sticky-top">
                    <div class="card-header"><i class="bi bi-receipt me-2"></i>Dịch vụ & Thanh toán</div>
                    <div class="card-body">
                        <label class="small fw-bold mb-3 text-secondary">PHƯƠNG THỨC VẬN CHUYỂN</label>
                        <div id="serviceContainer" class="mb-4 d-flex flex-column gap-2">
                        </div>

                        <div class="mb-4">
                            <label class="small fw-bold text-secondary">KHUYẾN MÃI</label>
                            <div class="input-group">
                                <input type="text" id="maGiamGia" class="form-control" placeholder="Nhập mã hoặc chọn..." readonly>
                                <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalKhuyenMai" onclick="loadAvailablePromotions()">Chọn mã</button>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="small fw-bold text-secondary mb-2 text-uppercase">PHƯƠNG THỨC THANH TOÁN</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-credit-card text-primary"></i></span>
                                <select id="selectPTTT" class="form-select fw-semibold" onchange="selectPTTT(this.value)">
                                    <option value="">-- Đang tải phương thức --</option>
                                </select>
                            </div>
                        </div>
                        <div class="card mt-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <span>Tạm tính :</span>
                                    <span id="display_tongTienDuKien">0 đ</span>
                                </div>
                                <div class="d-flex justify-content-between text-danger">
                                    <span>Giảm giá:</span>
                                    <span id="display_soTienGiam">0 đ</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between fw-bold h5">
                                    <span>Tổng thanh toán:</span>
                                    <span id="display_tongThanhToan" class="text-primary">0 đ</span>
                                </div>
                                <div id="promo_note" class="text-end"></div>
                            </div>
                        </div>

                        <button class="btn btn-primary w-100 mt-4 py-3 fw-bold shadow-lg" onclick="submitOrder()">
                            XÁC NHẬN TẠO ĐƠN
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalKhuyenMai" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 20px;">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Ưu đãi dành cho bạn</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="promotion-list" class="d-flex flex-column gap-2">
                        <div class="text-center py-3">Đang kiểm tra mã giảm giá...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>  
    <div class="modal fade" id="modalQR" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Quét mã thanh toán</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <p class="small text-muted">Vui lòng quét mã bên dưới để hoàn tất thanh toán cho đơn hàng.</p>
                    <div id="qrContainer" class="p-3 border rounded bg-light mb-3">
                        <img id="imgQR" src="" alt="Mã QR Thanh Toán" class="img-fluid" style="max-width: 250px;">
                    </div>
                    <div class="fw-bold text-primary h5" id="qrAmount">0 đ</div>
                    <p class="text-danger small italic">* Nội dung chuyển khoản: <span id="qrContent" class="fw-bold"></span></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-success" onclick="location.reload()">Tôi đã thanh toán</button>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // --- CẤU HÌNH HẰNG SỐ ---
        const PORT_7149 = "https://localhost:7149";
        const PORT_7264 = "https://localhost:7264";
        const API_PROVINCE = "https://provinces.open-api.vn/api";

        // --- TRẠNG THÁI ỨNG DỤNG ---
        let state = {
            maKhachHang: 0,
            loaiHangs: [],
            mucDichVus: [],
            selectedDV: null,
            tongTienGoc: 0,
            soTienGiam: 0,
            maGiamGiaChon: null,
            phuongThucThanhToans: [],
            selectedPTTT: null,
            tongThanhToan: 0
        };

        // Biến dùng cho kỹ thuật Debounce kỹ thuật số điện thoại
        let checkKhachHangTimeout = null;

        // --- HÀM BỔ TRỢ (UTILITIES) ---
        function cleanCityName(name) {
            if (!name) return "";
            return name.replace(/^(Thành phố|Tỉnh)\s+/i, "").trim();
        }

        function safeSetText(id, text) {
            const el = document.getElementById(id);
            if (el) el.innerText = text;
        }

        function showLoading(s) {
            const el = document.getElementById('loading');
            if (el) el.style.display = s ? 'flex' : 'none';
        }

        // --- LOGIC NGHIỆP VỤ ---

        /**
         * Kiểm tra số điện thoại khách hàng (Có Debounce chống spam API)
         */
        function onPhoneInput() {
            clearTimeout(checkKhachHangTimeout);
            checkKhachHangTimeout = setTimeout(() => {
                checkKhachHang();
            }, 350); // Chờ 350ms sau khi người dùng dừng gõ mới gọi API
        }

        async function checkKhachHang() {
            const inputSdt = document.getElementById('soDienThoai');
            if (!inputSdt) return;

            const sdt = inputSdt.value.trim();

            // Độ dài số điện thoại VN thông thường từ 10-11 số
            if (sdt.length < 10) {
                state.maKhachHang = 0;
                return;
            }

            try {
                const res = await axios.get(`${PORT_7149}/api/quanlykhachhang/check-phone`, {
                    params: { soDienThoai: sdt }
                });

                const result = res.data;
                const inputTenKH = document.getElementById('tenKhachHang');

                if (result && result.exists && result.data) {
                    if (inputTenKH) {
                        inputTenKH.value = result.data.tenLienHe || result.data.tenCongTy || "";
                    }
                    state.maKhachHang = result.data.maKhachHang || 0;
                    console.log("Đã tìm thấy khách hàng cũ:", state.maKhachHang);
                    autoCalculate();
                } else {
                    state.maKhachHang = 0;
                }
            } catch (e) {
                console.error("Lỗi khi kiểm tra khách hàng:", e);
                state.maKhachHang = 0;
            }
        }

        /**
         * Khởi tạo dữ liệu trang
         */
        window.addEventListener('DOMContentLoaded', async () => {
            // Gắn sự kiện input cho Số điện thoại để dùng debounce
            const inputSdt = document.getElementById('soDienThoai');
            if (inputSdt) {
                inputSdt.addEventListener('input', onPhoneInput);
            }

            showLoading(true);
            try {
                const [p, lh, dv, pttt] = await Promise.all([
                    axios.get(`${API_PROVINCE}/p/`).catch(err => { console.error("Lỗi API Tỉnh thành:", err); return { data: [] }; }),
                    axios.get(`${PORT_7264}/api/danhmucloaihang/laytatcaloaihang`).catch(err => { console.error("Lỗi API Loại hàng:", err); return { data: [] }; }),
                    axios.get(`${PORT_7264}/api/mucdichvu/dsmucdichvu?trangThai=active`).catch(err => { console.error("Lỗi API Dịch vụ:", err); return { data: [] }; }),
                    axios.get(`${PORT_7264}/api/quanlydonhang/PTTT`).catch(err => { console.error("Lỗi API PTTT:", err); return { data: [] }; })
                ]);

                // Gán dữ liệu vào state
                state.loaiHangs = lh.data || [];
                state.mucDichVus = dv.data || [];
                state.phuongThucThanhToans = pttt.data || [];

                // Render tỉnh thành
                if (p.data && p.data.length > 0) {
                    const pOptions = p.data.map(i => `<option value="${i.name}" data-code="${i.code}">${i.name}</option>`).join('');
                    const elLayTp = document.getElementById('lay_thanhPho');
                    const elGiaoTp = document.getElementById('giao_thanhPho');

                    if (elLayTp) elLayTp.innerHTML += pOptions;
                    if (elGiaoTp) elGiaoTp.innerHTML += pOptions;
                }

                addPackage();
                renderDichVu();
                renderPTTT();

            } catch (e) {
                console.error("Lỗi nghiêm trọng khi khởi tạo trang:", e);
                alert("Không thể kết nối đến hệ thống máy chủ. Vui lòng thử lại sau!");
            } finally {
                showLoading(false);
            }
        });

        /**
         * Tải Quận/Huyện dựa vào Tỉnh/Thành
         */
        async function fetchDistricts(type) {
            const pSelect = document.getElementById(`${type}_thanhPho`);
            const dSelect = document.getElementById(`${type}_quanHuyen`);
            const wSelect = document.getElementById(`${type}_phuongXa`);

            if (!pSelect || !dSelect) return;

            const selectedOption = pSelect.options[pSelect.selectedIndex];
            if (!selectedOption) return;

            const pCode = selectedOption.getAttribute('data-code');

            dSelect.innerHTML = '<option value="">Chọn Quận/Huyện</option>';
            if (wSelect) wSelect.innerHTML = '<option value="">Chọn Phường/Xã</option>';

            if (!pCode) return;

            try {
                const res = await axios.get(`${API_PROVINCE}/p/${pCode}?depth=2`);
                if (res.data && res.data.districts) {
                    dSelect.innerHTML += res.data.districts.map(d =>
                        `<option value="${d.name}" data-code="${d.code}">${d.name}</option>`
                    ).join('');
                }
                autoCalculate();
            } catch (e) {
                console.error("Lỗi tải quận huyện:", e);
            }
        }

        /**
         * Tải Phường/Xã dựa vào Quận/Huyện
         */
        async function fetchWards(type) {
            const dSelect = document.getElementById(`${type}_quanHuyen`);
            const wSelect = document.getElementById(`${type}_phuongXa`);

            if (!dSelect || !wSelect) return;

            const selectedOption = dSelect.options[dSelect.selectedIndex];
            if (!selectedOption) return;

            const dCode = selectedOption.getAttribute('data-code');

            wSelect.innerHTML = '<option value="">Chọn Phường/Xã</option>';

            if (!dCode) return;

            try {
                const res = await axios.get(`${API_PROVINCE}/d/${dCode}?depth=2`);
                if (res.data && res.data.wards) {
                    wSelect.innerHTML += res.data.wards.map(w =>
                        `<option value="${w.name}" data-code="${w.code}">${w.name}</option>`
                    ).join('');
                }
                autoCalculate();
            } catch (e) {
                console.error("Lỗi tải phường xã:", e);
            }
        }

        /**
         * Tự động phân tích dịch vụ và tính giá gốc cho các kiện hàng
         */
        async function autoCalculate() {
            const elLayTp = document.getElementById('lay_thanhPho');
            const elGiaoTp = document.getElementById('giao_thanhPho');
            const elSoKm = document.getElementById('soKm');

            if (!elLayTp || !elGiaoTp) return;

            const tpLay = cleanCityName(elLayTp.value);
            const tpGiao = cleanCityName(elGiaoTp.value);
            const soKmHanhTrinh = elSoKm ? (parseFloat(elSoKm.value) || 0) : 0;

            if (!tpLay || !tpGiao) return;

            const kiens = document.querySelectorAll('.package-item');
            if (kiens.length === 0) return;

            let totalGoc = 0;

            const promises = Array.from(kiens).map(async (k) => {
                const elWeight = k.querySelector('[name="khoiLuong"]');
                const elVolume = k.querySelector('[name="theTich"]');
                const elQty = k.querySelector('[name="soLuongKienHang"]');
                const elMaLH = k.querySelector('[name="maLoaiHang"]');

                const weight = elWeight ? (parseFloat(elWeight.value) || 0) : 0;
                const volume = elVolume ? (parseFloat(elVolume.value) || 0) : 0;
                const qty = elQty ? (parseInt(elQty.value) || 1) : 1;
                const maLH = elMaLH ? (parseInt(elMaLH.value) || 0) : 0;

                const payload = {
                    thanhPhoLay: tpLay,
                    thanhPhoGiao: tpGiao,
                    khoiLuongTong: weight,
                    theTichTong: volume,
                    maLoaiHang: maLH,
                    soKm: soKmHanhTrinh
                };

                try {
                    const res = await axios.post(`${PORT_7264}/api/quanlydonhang/phan-tich-dich-vu-phu-hop`, payload);

                    let noteEl = k.querySelector('.price-note');
                    if (!noteEl) {
                        noteEl = document.createElement('div');
                        noteEl.className = 'price-note alert alert-info py-1 px-2 mt-2 mb-0';
                        noteEl.style.fontSize = '0.8rem';
                        k.appendChild(noteEl);
                    }

                    if (res.data && res.data.length > 0) {
                        const opt = res.data[0];
                        k.dataset.maBangGiaThucTe = opt.maBangGia || 0;
                        k.dataset.donGia = opt.tongTienDuKien || 0;

                        totalGoc += ((opt.tongTienDuKien || 0) * qty);

                        noteEl.innerHTML = `
                            <div class="d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-truck-loading me-1"></i> <strong>${opt.tenDichVu || ""}</strong></span>
                                <span class="badge bg-danger">${(opt.tongTienDuKien || 0).toLocaleString()}đ/kiện</span>
                            </div>
                            <div class="text-muted" style="font-size: 0.75rem">${opt.moTaGia || ""}</div>
                        `;
                    } else {
                        k.dataset.maBangGiaThucTe = 0;
                        k.dataset.donGia = 0;
                        noteEl.innerHTML = `<span class="text-warning"><i class="fas fa-exclamation-triangle"></i> Không tìm thấy bảng giá hợp lệ.</span>`;
                    }
                } catch (e) {
                    console.error("Lỗi API tính giá kiện hàng:", e);
                }
            });

            await Promise.all(promises);
            state.tongTienGoc = totalGoc;

            if (state.maGiamGiaChon) {
                await reValidateVoucher();
            } else {
                updateUI();
            }
        }

        /**
         * Hiển thị danh sách mức dịch vụ (Tiết kiệm, hỏa tốc...)
         */
        function renderDichVu() {
            const container = document.getElementById('serviceContainer');
            if (!container) return;

            if (!state.mucDichVus || state.mucDichVus.length === 0) {
                container.innerHTML = '<p class="text-muted small">Đang tải dịch vụ...</p>';
                return;
            }

            const selectedId = state.selectedDV ? String(state.selectedDV.maDichVu) : null;

            container.innerHTML = state.mucDichVus.map(dv => {
                const id = String(dv.maDichVu);
                const name = dv.tenDichVu || "Dịch vụ vận chuyển";
                const heSo = dv.heSoNhiPhan || 1;
                const isSelected = (selectedId === id);

                return `
                    <div class="service-option ${isSelected ? 'selected' : ''}"
                         onclick="selectDV('${id}')"
                         style="cursor: pointer;">
                        <div class="d-flex justify-content-between align-items-center w-100">
                            <div style="pointer-events: none;">
                                <div class="fw-bold ${isSelected ? 'text-primary' : ''}">${name}</div>
                                <div class="small text-muted">Hệ số: <span class="badge bg-secondary">x${heSo}</span></div>
                            </div>
                            <i class="bi ${isSelected ? 'bi-check-circle-fill text-primary' : 'bi-circle text-muted'} h5 mb-0"></i>
                        </div>
                    </div>`;
            }).join('');
        }

        function selectDV(id) {
            const selected = state.mucDichVus.find(dv => String(dv.maDichVu) === String(id));
            if (selected) {
                state.selectedDV = selected;
                renderDichVu();
                updateUI();
            }
        }

        /**
         * Tải mã giảm giá khả dụng lên Modal
         */
        async function loadAvailablePromotions() {
            const container = document.getElementById('promotion-list');
            if (!container) return;

            const heSo = state.selectedDV ? state.selectedDV.heSoNhiPhan : 1;
            const tongTienHienTai = state.tongTienGoc * heSo;

            if (tongTienHienTai <= 0) {
                container.innerHTML = `
                    <div class="alert alert-warning small border-0 shadow-sm">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Vui lòng chọn địa chỉ và hàng hóa để tính giá trước khi xem khuyến mãi.
                    </div>`;
                return;
            }

            container.innerHTML = '<div class="text-center p-3"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tìm mã giảm giá...</div>';

            try {
                const res = await axios.get(`${PORT_7264}/api/quanlykhuyenmai/khuyen-mai-kha-dung`, {
                    params: {
                        tongTienDonHang: Math.round(tongTienHienTai),
                        maKhachHang: parseInt(state.maKhachHang) || 0
                    }
                });
                renderPromotionList(res.data);
            } catch (e) {
                console.error("Lỗi tải danh sách KM:", e);
                container.innerHTML = '<div class="alert alert-danger small">Không thể kết nối máy chủ để tải khuyến mãi.</div>';
            }
        }

        function renderPromotionList(promotions) {
            const container = document.getElementById('promotion-list');
            if (!container) return;

            if (!promotions || promotions.length === 0) {
                container.innerHTML = `
                    <div class="text-center p-4">
                        <img src="https://cdn-icons-png.flaticon.com/512/6598/6598519.png" width="60" class="opacity-50 mb-3">
                        <p class="text-muted small">Rất tiếc, chưa có mã nào phù hợp với đơn hàng này.</p>
                    </div>`;
                return;
            }

            container.innerHTML = promotions.map(km => {
                const code = km.codeKhuyenMai || km.code || km.maCode;
                const ten = km.tenChuongTrinh || "Mã giảm giá";
                const moTa = km.moTa || "Ưu đãi đơn hàng";
                const isUsed = km.daSuDung === true;

                return `
                    <div class="promotion-item border rounded p-3 mb-2 shadow-sm ${isUsed ? 'opacity-50 grayscale' : 'hover-shadow'}"
                         ${!isUsed ? `onclick="selectVoucher('${code}')"` : ''}
                         style="cursor:${isUsed ? 'not-allowed' : 'pointer'}; position: relative;">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="me-3">
                                <span class="badge bg-danger mb-1">${code}</span>
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">${ten}</div>
                                <div class="text-muted" style="font-size: 0.75rem; line-height: 1.2;">${moTa}</div>
                            </div>
                            <button class="btn btn-sm ${isUsed ? 'btn-secondary' : 'btn-primary'} text-nowrap">
                                ${isUsed ? 'Đã dùng' : 'Áp dụng'}
                            </button>
                        </div>
                    </div>`;
            }).join('');
        }

        async function selectVoucher(code) {
            if (!code) return;

            state.maGiamGiaChon = code;
            const inputMa = document.getElementById('maGiamGia');
            if (inputMa) inputMa.value = code;

            const modalEl = document.getElementById('modalKhuyenMai');
            if (modalEl && typeof bootstrap !== 'undefined') {
                const modalInstance = bootstrap.Modal.getInstance(modalEl);
                if (modalInstance) {
                    modalInstance.hide();
                    modalEl.addEventListener('hidden.bs.modal', function () {
                        document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
                        document.body.classList.remove('modal-open');
                        document.body.style.overflow = '';
                        document.body.style.paddingRight = '';
                    }, { once: true });
                }
            }
            await reValidateVoucher();
        }

        async function reValidateVoucher() {
            if (!state.maGiamGiaChon) {
                state.soTienGiam = 0;
                updateUI();
                return;
            }

            const heSo = state.selectedDV ? state.selectedDV.heSoNhiPhan : 1;
            const tongTienHienTai = state.tongTienGoc * heSo;

            try {
                const res = await axios.post(`${PORT_7149}/api/quanlykhuyenmai/ap-dung`, {
                    code: state.maGiamGiaChon,
                    tongTienDonHang: Math.round(tongTienHienTai),
                    maKhachHang: state.maKhachHang
                });

                if (res.data && res.data.success) {
                    state.soTienGiam = res.data.data.soTienGiam || 0;
                } else {
                    throw new Error(res.data?.message || "Mã không hợp lệ.");
                }
            } catch (e) {
                console.warn("Hủy áp dụng mã KM:", e.response?.data?.message || e.message);
                state.maGiamGiaChon = null;
                state.soTienGiam = 0;
                const inputMa = document.getElementById('maGiamGia');
                if (inputMa) inputMa.value = "";
            }
            updateUI();
        }

        /**
         * Cập nhật số tiền hiển thị lên Giao diện công khai công thức
         */
        function updateUI() {
            const heSo = state.selectedDV ? state.selectedDV.heSoNhiPhan : 1;
            const tongDuKien = state.tongTienGoc * heSo;
            const tongThucTe = Math.max(0, tongDuKien - state.soTienGiam);

            state.tongThanhToan = tongThucTe;

            safeSetText('display_tongTienDuKien', tongDuKien.toLocaleString() + " đ");

            const elGiam = document.getElementById('display_soTienGiam');
            if (elGiam) {
                elGiam.innerText = (state.soTienGiam > 0 ? "-" : "") + state.soTienGiam.toLocaleString() + " đ";
            }

            safeSetText('display_tongThanhToan', tongThucTe.toLocaleString() + " đ");

            const promoNote = document.getElementById('promo_note');
            if (promoNote) {
                promoNote.innerHTML = state.maGiamGiaChon
                    ? `<span class="text-success small"><i class="bi bi-check-circle"></i> Đã áp dụng mã: ${state.maGiamGiaChon}</span>`
                    : "";
            }
        }

        /**
         * Phương thức thanh toán (Dropdown)
         */
        function renderPTTT() {
            const selectEl = document.getElementById('selectPTTT');
            if (!selectEl) return;

            if (!state.phuongThucThanhToans || state.phuongThucThanhToans.length === 0) {
                selectEl.innerHTML = '<option value="">-- Không có phương thức thanh toán --</option>';
                return;
            }

            selectEl.innerHTML = '<option value="">-- Chọn phương thức thanh toán --</option>' +
                state.phuongThucThanhToans.map(pt => {
                    const isSelected = (state.selectedPTTT == pt.maPttt) ? 'selected' : '';
                    return `<option value="${pt.maPttt}" ${isSelected}>${pt.tenPttt}</option>`;
                }).join('');
        }

        function selectPTTT(id) {
            state.selectedPTTT = parseInt(id) || id;
            console.log("Đã chọn PTTT ID:", state.selectedPTTT);
        }

        /**
         * Hiển thị QR Code thanh toán
         */
        function showQRCodeFromUrl(qrUrl, soTien, maDonHang) {
            const imgQR = document.getElementById('imgQR');
            const qrAmount = document.getElementById('qrAmount');
            const qrContent = document.getElementById('qrContent');
            const modalQrEl = document.getElementById('modalQR');

            if (imgQR) imgQR.src = qrUrl;
            if (qrAmount) qrAmount.innerText = (soTien || 0).toLocaleString() + " đ";
            if (qrContent) qrContent.innerText = `Thanh toán đơn hàng #${maDonHang || ""}`;

            if (modalQrEl && typeof bootstrap !== 'undefined') {
                const modalQR = new bootstrap.Modal(modalQrEl);
                modalQR.show();

                modalQrEl.addEventListener('hidden.bs.modal', () => {
                    location.reload();
                }, { once: true });
            } else {
                alert("Tạo đơn hàng thành công! Đơn hàng #" + maDonHang);
                location.reload();
            }
        }

        /**
         * Thêm Kiện hàng động
         */
        function addPackage() {
            const container = document.getElementById('packageList');
            if (!container) return;

            const div = document.createElement('div');
            div.className = 'package-item position-relative border p-3 mb-3 rounded bg-white shadow-sm';
            div.innerHTML = `
                <button type="button" class="btn-close position-absolute top-0 end-0 m-2" onclick="this.parentElement.remove(); autoCalculate();"></button>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="small fw-bold text-secondary">Loại hàng</label>
                        <select class="form-select" name="maLoaiHang" onchange="autoCalculate()">
                            ${state.loaiHangs.map(i => `<option value="${i.maLoaiHang}">${i.tenLoaiHang}</option>`).join('')}
                        </select>
                    </div>
                    <div class="col-md-2 col-6">
                        <label class="small fw-bold text-secondary">Nặng (kg)</label>
                        <input type="number" class="form-control" name="khoiLuong" value="1" min="0.1" step="0.1" oninput="autoCalculate()">
                    </div>
                    <div class="col-md-2 col-6">
                        <label class="small fw-bold text-secondary">Khối (m3)</label>
                        <input type="number" class="form-control" name="theTich" value="0.01" min="0.001" step="0.001" oninput="autoCalculate()">
                    </div>
                    <div class="col-md-2 col-6">
                        <label class="small fw-bold text-secondary">Số lượng</label>
                        <input type="number" class="form-control" name="soLuongKienHang" value="1" min="1" oninput="autoCalculate()">
                    </div>
                    <div class="col-md-12">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="small fw-bold text-secondary">Yêu cầu bảo quản</label>
                                <input type="text" class="form-control form-control-sm" name="yeuCauBaoQuan" placeholder="Ví dụ: Giữ lạnh...">
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-secondary">Ghi chú kiện</label>
                                <input type="text" class="form-control form-control-sm" name="ghiChu" placeholder="Ghi chú thêm...">
                            </div>
                        </div>
                    </div>
                </div>`;
            container.appendChild(div);
            autoCalculate();
        }

        /**
         * Submit Đơn hàng (Validation nghiêm ngặt + Trích xuất lỗi API sâu)
         */
        async function submitOrder() {
            // 1. Kiểm tra Mức dịch vụ và PTTT từ state
            if (!state.selectedDV) return alert("Vui lòng chọn mức dịch vụ vận chuyển!");
            if (!state.selectedPTTT) return alert("Vui lòng chọn phương thức thanh toán!");

            // 2. Kiểm tra phần tử DOM tồn tại và lấy giá trị
            const getValById = (id) => {
                const el = document.getElementById(id);
                return el ? el.value.trim() : "";
            };

            const tenKH = getValById('tenKhachHang');
            const sdtKH = getValById('soDienThoai');
            const sdtNhan = getValById('sdtNguoiNhan');
            const tenNhan = getValById('tenNguoiNhan');

            if (!tenKH || !sdtKH || !tenNhan || !sdtNhan) {
                return alert("Vui lòng nhập đầy đủ thông tin người gửi và người nhận!");
            }

            const kiens = document.querySelectorAll('.package-item');
            if (kiens.length === 0) {
                return alert("Đơn hàng phải có ít nhất 1 kiện hàng!");
            }

            // 3. Xây dựng danh sách kiện hàng an toàn
            const danhSachKienHang = Array.from(kiens).map(k => {
                const elWeight = k.querySelector('[name="khoiLuong"]');
                const elVolume = k.querySelector('[name="theTich"]');
                const elQty = k.querySelector('[name="soLuongKienHang"]');
                const elMaLH = k.querySelector('[name="maLoaiHang"]');
                const elYcbq = k.querySelector('[name="yeuCauBaoQuan"]');

                return {
                    khoiLuong: elWeight ? (parseFloat(elWeight.value) || 0) : 0,
                    theTich: elVolume ? (parseFloat(elVolume.value) || 0) : 0,
                    soLuongKienHang: elQty ? (parseInt(elQty.value) || 1) : 1,
                    maLoaiHang: elMaLH ? (parseInt(elMaLH.value) || 0) : 0,
                    maBangGiaVung: parseInt(k.dataset.maBangGiaThucTe) || 0,
                    yeuCauBaoQuan: elYcbq ? elYcbq.value.trim() : ""
                };
            });

            // Kiểm tra xem có kiện hàng nào bị thiếu bảng giá không trước khi submit
            const coKienGiaLoi = danhSachKienHang.some(k => k.maBangGiaVung === 0);
            if (coKienGiaLoi) {
                return alert("Có kiện hàng chưa tìm thấy bảng giá phù hợp. Không thể tạo đơn!");
            }

            // 4. Đóng gói payload gửi lên backend
            const payload = {
                tenDonHang: `Đơn hàng - ${tenKH} - ${new Date().toLocaleDateString()}`,
                soDienThoai: sdtKH,
                tenKhachHang: tenKH,
                tenNguoiNhan: tenNhan,
                sdtNguoiNhan: sdtNhan,
                soKm: parseFloat(getValById('soKm')) || 0,
                maMucDoDv: parseInt(state.selectedDV.maDichVu),
                maPTTT: parseInt(state.selectedPTTT),
                maGiamGia: state.maGiamGiaChon,
                tongTien: state.tongThanhToan,
                soTienGiam: state.soTienGiam,
                diaChiLay: {
                    duong: getValById('lay_duong'),
                    phuong: getValById('lay_phuongXa'),
                    quan: getValById('lay_quanHuyen'),
                    thanhPho: cleanCityName(getValById('lay_thanhPho'))
                },
                diaChiGiao: {
                    duong: getValById('giao_duong'),
                    phuong: getValById('giao_phuongXa'),
                    quan: getValById('giao_quanHuyen'),
                    thanhPho: cleanCityName(getValById('giao_thanhPho'))
                },
                danhSachKienHang: danhSachKienHang
            };

            console.log("Dữ liệu gửi lên Server:", payload);

            showLoading(true);
            try {
                const res = await axios.post(`${PORT_7264}/api/quanlydonhang/tao-moi`, payload);

                if (res.status === 200 || res.data.success) {
                    const result = res.data;
                    if (result && result.qrCodeUrl) {
                        showQRCodeFromUrl(result.qrCodeUrl, result.tongTien, result.maDonHang);
                    } else {
                        alert("Tạo đơn hàng thành công!");
                        location.reload();
                    }
                } else {
                    alert("Yêu cầu không thành công: " + (res.data?.message || "Lỗi không xác định"));
                }
            } catch (e) {
                console.error("Lỗi khi gọi API submit đơn hàng:", e);
                // Trích xuất thông báo lỗi sâu từ Backend (C# BadRequest(new { message = "..." }))
                const msgServer = e.response?.data?.message || e.response?.data || "Không thể kết nối đến máy chủ";
                alert("Lỗi tạo đơn hàng: " + msgServer);
            } finally {
                showLoading(false);
            }
        }
    </script>
</body>
</html>